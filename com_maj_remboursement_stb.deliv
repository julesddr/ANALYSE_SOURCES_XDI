	CARTE_FID,
	DATE_EXPI_FID,
	ID_CDE,
	ID_RBT,
	NB_PT_GLOB,
	INCREMENTAL_FLAG
)
select   	  
	L1_RET_RBT_2.L7_CARTE_FID,
	L1_RET_RBT_2.L8_DATE_EXPI_FID,
	L1_RET_RBT_2.L9_ID_CDE,
