" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L9_article</field><field isKey="false" id="_Vh7iqjSZEe-8XLGEVLwJsw" alias="L34_coloris" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L10_coloris</field><field isKey="false" id="_Vh7irDSZEe-8XLGEVLwJsw" alias="L35_image" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L14_image</field><field isKey="false" id="_Vh7isDSZEe-8XLGEVLwJsw" alias="L36_prixRemise" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L15_prixRemise</field><field isKey="false" id="_Vh7isjSZEe-8XLGEVLwJsw" alias="L37_qte" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L12_qte</field><field isKey="false" id="_Vh7itDSZEe-8XLGEVLwJsw" alias="L38_reference" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L4_reference</field><field isKey="false" id="_Vh7itjSZEe-8XLGEVLwJsw" alias="L39_taille" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L2_taille</field><field isKey="false" id="_Vh7iuDSZEe-8XLGEVLwJsw" alias="L40_description" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L13_description</field><field isKey="false" id="_Vh7iuzSZEe-8XLGEVLwJsw" alias="L41_montantTotal" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L7_montantTotal</field><field isKey="false" id="_Vh7ivTSZEe-8XLGEVLwJsw" alias="L42_numero" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L8_numero</field><field isKey="false" id="_Vh7ivzSZEe-8XLGEVLwJsw" alias="L43_date" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_stage.L20_date</field><field isKey="false" id="_Vh7iwTSZEe-8XLGEVLwJsw" alias="L44_motifRemboursement" aliasWord="" isAggregate="false" location="SRC" forceIsNillab