on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)% (CODE)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="bf33973d1c2eac167bc4f53ed42acd31" type="Code" actionName="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(CODE)
	in	(
		select	CODE
		from	STORELAND.COUPON
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="3d47861b0d3307e5b56e0baaf5f5edb4" type="Code" actionName="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	STORELAND.COUPON T 
set


 (  T.END_DATE_VALID,
		T.REMAIN_USE_COUNT,
		T.STATUS_CODE
             
       ) = 
             (
             select S.END_DATE_VALID,
				S.REMAIN_USE_COUNT,
				S.STATUS_CODE
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)% S
             where  S.CODE=T.CODE
                     )     


where	(CODE)
	in	(
		select	CODE
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="8c75c57fbcef4d8c9742c10ca8a79e4c" type="Code" actionName="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Commit of transaction on target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[commit]]><altId value="_jkWgqFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Integration/Commit of transaction on target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/890 DB Co