	MONTANT_REMBOURSE	NUMBER(10,2) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="f4fc5ab79540aa6e3ff9f2f9c0629df1" type="Code" actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	LIB_REGLEMENT,
	MODE_REGLEMENT,
	MONTANT_REMBOURSE,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT.ID_CDE,
	W_RBT.ID_RBT,
	MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG,
	HISTORIQUE_CAISSES.MOTIFRETOUR,
	coalesce(sum(HISTORIQUE_CAISSES.CANETREALISE)*-1,0),
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN (STORELAND.MODES_REGLEMENT_MAGASIN  MODES_REGLEMENT_MAGASIN
		INNER JOIN STORELAND.HISTORIQUE_CAISSES  HISTORIQUE_CAISSES
		ON MODES_REGLEMENT_MAGASIN.CODEMODEREGLEMENTMAG = HISTORIQUE_CAISSES.MOTIFRETOUR)
	ON to_number(substr(W_RBT.ID_CDE,10,5)) = HISTORIQUE_CAISSES.CODEMAGASIN
and to_number(substr(W_RBT.ID_CDE,1,9)) = HISTORIQUE_CAISSES.NUMTICKETORIGINE
and HISTORIQUE_CAISSES.CODECAISSE = 2 
and HISTORIQUE_CAISSES.TYPELIGNE = 9 
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$')
group by W_RBT.ID_CDE, W_RBT.ID_RBT, MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG, HISTORIQUE_CAISSES.MOTIFRETOUR
minus
select
	ID_CDE,
	ID_RBT,
	LIB_REGLEMENT,
	MODE_REGLEMENT,
	MONTANT_REMBOURSE,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="9a25f4352a417d1a5d0a5c533d847d7c" type="Code" actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_c1jhsGoOEea9fIQJ0nVgng" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table" mandatory="1" id="9829371194f1f32e8f2f014ddaa5cf5a"/><link type="OK" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" mandatory="1" id="daf4b9993079ab2a0efa49944fb860a2"/><link type="OK" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/I