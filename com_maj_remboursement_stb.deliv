	ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_7.stb_parentKey
