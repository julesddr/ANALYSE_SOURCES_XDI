(
	L1_ID_LCDE	NUMBER(3,0) NULL,
	L2_MONTANT_RBT	NUMBER(8,2) NULL,
	L3_MONTANT_RBT_FORCE	NUMBER(8,2) NULL,
	L4_ID_CDE	VARCHAR2(15 BYTE) NULL,
	L5_ID_RBT	NUMBER(2,0) NULL
	
)
]]><altId value="_V-05KVLLEeOo_oU69nSAZg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Creation of load table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Creation of load table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Creation of load table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="e5558cb2db12758317248d9cf9bff482" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/8beff391aa71df9beadf7028b4b831ca_4" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"/><step id="a6f69c6a77a134d5de5be12ac293ec85" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Select on source table (SRC)" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[select		
			RET_LIGNE_RBT.ID_LCDE  L1_ID_LCDE,
			RET_LIGNE_RBT.MONTANT_RBT  L2_MONTANT_RBT,
			RET_LIGNE_RBT.MONTANT_RBT_FORCE  L3_MONTANT_RBT_FORCE,
			RET_RBT.ID_CDE  L4_ID_CDE,
			RET_RBT.ID_RBT  L5_ID_RBT
			
from	ECOMM.RET_RBT  RET_RBT
	INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT
where	(1=1) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)]]><altId value="_V-05M1LLEeOo_oU69nSAZg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Select on source table (SRC)/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Select on source table (SRC)/SQL_ACTION_TYPE" type="String" value="SELECT"/></step><step id="3463ba0f4801bf8dfe3a9c9b7857e6bf" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert into ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"1g6sztwnvayj5").substring(0,26);}e(rhino)%
(L1_ID_LCDE, L2_MONTANT_RBT, L3_MONTANT_RBT_FORCE, L4_ID_CDE, L5_ID_RBT)
values
(:{L1_ID_LCDE}:, :{L2_MONTANT_RBT}:, :{L3_MONTANT_RBT_FORCE}:, :{L4_ID_CDE}:, :{L5_ID_RBT}:)]]><altId value="_V-05OVLLEeOo_oU69nSAZg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)/SQL_ACTION_TYPE" type="String" value="INSERT"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="e67e6a78a6f03de6bb3914f44842deb8" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Analyze of load table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"1g6sztwnvayj5").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_etAKIFLLEeOo_oU69nSAZg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Analyze of load table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Analyze of load table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Analyze of load table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Drop of load table" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Creation of load table" mandatory="1" id="8e47046cd8e3cf9c753494825bf98f49"/><link type="OK" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Creation of load table" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/8beff391aa71df9beadf7028b4b831ca_4" mandatory="1" id="6e4904083a57a79194bbf7c063da9ffd"/><link type="OK" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/8beff391aa71df9beadf7028b4b831ca_4" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Select on source table (SRC)" mandatory="1" id="5a75a6a88ea503f599ee930e1962e822"/><link type="OK" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Select on source table (SRC)" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)" mandatory="1" bindType="DirectBind" id="ba5cf7aea0d17aa41ef1206f4f659429"/><link type="OK" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Load of data (TRG)" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/Analyze of load table (DBMS_STATS.GATHER_TABLE_STATS method)" mandatory="1" id="f8d149ba827b217a3481cc05c649c3ed"/></process><process actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging" isBeginProcess="false"><step id="c3d8bff8e085851fe4bd7e47c0dd80a9" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging" nbCycles="-1" toleratedError="true" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Drop view ETLWORK.S_1g6sztwnvayj5_stage]]><altId value="_8zSzVdu8EeWIdu0rdnx7VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="d045f218bd80a344adf875aa31038e0e" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Drop table ETLWORK.S_1g6sztwnvayj5_stage purge]]><altId value="_8zSzT9u8EeWIdu0rdnx7VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="1a1b9bbaad1664faf99267fe34a05165" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Creation of staging" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.S_1g6sztwnvayj5_stage
NOLOGGING
AS




select	  
	L1_stage.L5_ID_RBT AS L6_ID_RBT,
	sum(coalesce(L1_stage.L3_MONTANT_RBT_FORCE,L1_stage.L2_MONTANT_RBT)) AS L7_MNT_RBT,
	L1_stage.L4_ID_CDE AS L8_ID_CDE,
	L1_stage.L1_ID_LCDE AS L9_ID_LCDE
	
from	ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"1g6sztwnvayj5").substring(0,26);}e(rhino)%  L1_stage
where	(1=1)
