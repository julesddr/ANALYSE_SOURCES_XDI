-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[drop table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% purge]]><altId value="_jkWgMlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="4d489d594879064758b267df4e411e11" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	TYPE_RETOUR	VARCHAR2(15 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="6105f67c0d127c5338cde156840e3598" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	INCREMENTAL_FLAG
)
select   	  
	RET_LIGNE_RBT.ID_CDE,
	RET_LIGNE_RBT.ID_RBT,
	case when max(LCDE.DATH_E_EXPE) is null 
then 'manquant'
when max(LCDE.DATH_E_RETIRE) is null 
then 'remiseEnStock'
else 'retour'
end,
	'I' INCREMENTAL_FLAG
from	ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	INNER JOIN ECOMM.LCDE  LCDE
	ON RET_LIGNE_RBT.ID_CDE = LCDE.ID_CDE
and RET_LIGNE_RBT.ID_LCDE = LCDE.ID_LCDE
where	(1=1)  AND (RET_LIGNE_RBT.F_SERVICE IS NULL AND RET_LIGNE_RBT.MOTIF_RETOUR IS NULL) AND (RET_LIGNE_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_LIGNE_RBT.ID_RBT = ${~/p_id_rbt}$)
group by RET_LIGNE_RBT.ID_CDE, RET_LIGNE_RBT.ID_RBT
minus
select
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	'I' INCREMENTAL_FLAG	
from	ECOMM.RET_RBT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="78decaa863e4dffd8785393b36573052" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_c1jhsGoOEea9fIQJ0nVgng" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table" mandatory="1" id="6d6a8742e03928b907cbc34f6af31210"/><link type="OK" sourceName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" mandatory="1" id="711de3bf1c24c209e6c562954d0186e1"/><link type="OK" sourceName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" targetName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" mandatory="1" id="48256f1828b7908291a0eada0e1dfc9b"/></process><process actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration" isBeginProcess="false"><step id="c137489b33705fbbf0013b76539229ef" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Start" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_jkWgx1EJEeO7Vo9WeM2sCg" origin="compilation"/></step><step id="78fb926d2be3e0d9fee389f4b5990104" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Creation of a unique Index on pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[create unique index ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)%_IDX 
on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% (ID_CDE, ID_RBT)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="b4b11d12668d2656dde9570259616aab" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE,
			ID_RBT
		from	ECOMM.RET_RBT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="73dc2d8e2e6458e8e76441cb860da231" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ECOMM.RET_RBT T 
set


 (  T.TYPE_RETOUR
             
       ) = 
             (
             select S.TYPE_RETOUR
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="26e71d4eabcda8350db3cdd7a8bb87e6" type="Code" actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert  into ECOMM.RET_RBT
	(	ID_CDE,
		ID_RBT,
		TYPE_RETOUR
		
	)
select	ID_CDE,
		ID_RBT,
		TYPE_RETOUR
		
from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% INT
