	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
