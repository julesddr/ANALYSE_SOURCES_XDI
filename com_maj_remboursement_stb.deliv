 à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="5ee2237124f9abcaccc9bdda085a0653" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	MNT_RBT_CAL	NUMBER(8,2) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="3dc007bfd0a753dc26dc7306580579db" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	MNT_RBT_CAL,
	SESSION_ID,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT.MNT_RBT_CAL - W_RBT_PREPA_RGT.MONTANT_AREMBOURSER,
	W_RBT_PREPA_RGT.SESSION_ID,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	ON W_RBT.ID_CDE = W_RBT_PREPA_RGT.ID_CDE
and W_RBT.ID_RBT = W_RBT_PREPA_RGT.ID_RBT
and W_RBT.SESSION_ID = W_RBT_PREPA_RGT.SESSION_ID
where	(1=1)  AND (W_RBT_PREPA_RGT.MODE_REGLEMENT = 26 AND W_RBT_PREPA_RGT.MONTANT_AREMBOURSER IS NOT NULL) AND (W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$')
minus
select
	ID_CDE,
	ID_RBT,
	MNT_RBT_CAL,
	SESSION_ID,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="524f42bdf1602047463832ca881b5c46" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_c1jhsGoOEea9fIQJ0nVgng" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" mandatory="1" id="47285ddede3798e39520a212da2e4ba1"/><link type="OK" sourceName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" mandatory="1" id="642af3f22e0b8ded07d258f487490d01"/><link type="OK" sourceName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" targetName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" mandatory="1" id="59d04803c9986237e71c4ca9644ed08d"/></process><process actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration" isBeginProcess="false"><step id="302bbdea473a62bef80c7699710f2154" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Start" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_jkWgx1EJEeO7Vo9WeM2sCg" origin="compilation"/></step><step id="3ad58e408911765e3c3d54574e3abbf5" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[create unique index ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%_IDX 
on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% (ID_CDE, ID_RBT, SESSION_ID)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="467c2742741805dbef1c76a6e2772cc5" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
		select	ID_CDE,
			ID_RBT,
			SESSION_ID
		from	ETLWORK.W_RBT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="bf6b416bb2caffefab1d244f77b89e6f" type="Code" actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.W_RBT T 
set


 (  T.MNT_RBT_CAL
             
       ) = 
             (
             select S.MNT_RBT_CAL
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.SESSION_ID=T.SESSION_ID
                     )     


where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
		select	ID_CDE, ID_RBT, SESSION_ID
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% I
