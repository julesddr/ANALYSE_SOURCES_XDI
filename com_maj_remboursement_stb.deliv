)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="3621c34c7e67aafb4269dcb1bd4b48e5" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Insertion of preintegration data - APPEND" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	MNT_RBT,
	INCREMENTAL_FLAG
)
select		  
			S1_stage.L8_ID_CDE AS ID_CDE,
			S1_stage.L6_ID_RBT AS ID_RBT,
			sum(S1_stage.L7_MNT_RBT) AS MNT_RBT,
			'I' INCREMENTAL_FLAG
from	ETLWORK.S_1g6sztwnvayj5_stage  S1_stage
where	(1=1) 
group by S1_stage.L8_ID_CDE, S1_stage.L6_ID_RBT
]]><altId value="_jkWgflEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Insertion of preintegration data - APPEND/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Insertion of preintegration data - APPEND/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Insertion of preintegration data - APPEND/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="e32fb8db73f3c4d2bd9630facd9e7d19" type="Code" actionName="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
