process actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging" isBeginProcess="false"><step id="1bfcc28bc824d9ebc427794816d4026a" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop view staging" nbCycles="-1" toleratedError="true" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Drop view ETLWORK.S_1g81bv08b22j0_stage]]><altId value="_8zSzVdu8EeWIdu0rdnx7VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="0bf3c6a9e065abe30af5c18cc7c29ca3" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Drop table ETLWORK.S_1g81bv08b22j0_stage purge]]><altId value="_8zSzT9u8EeWIdu0rdnx7VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="f06945cdb361970b9faabf35f467b7e4" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.S_1g81bv08b22j0_stage
NOLOGGING
AS




select	  DISTINCT 
	CDE.FAC_PRENOM AS L1_prenom,
	TAILLE.LIB_TAILLE AS L2_taille,
	CDE.EMAIL AS L3_login,
	RET_LIGNE_RBT.CODE_EAN AS L4_reference,
	RET_RBT.ID_CDE AS L5_PRD_JLS_FR_FR_REMBOURSEMENT,
	RET_RBT.CARTE_FID AS L6_codecarte,
	RET_RBT.MNT_RBT AS L7_montantTotal,
	substr(RET_RBT.ID_CDE,1,9) AS L8_numero,
	ARTICLE.LIB_COMM AS L9_article,
	ARTICLE.ID_COULEUR AS L10_coloris,
	RET_RBT.NB_PT_GLOB AS L11_nbpoints,
	1 AS L12_qte,
	ARTICLE.LIB_PRODUIT AS L13_description,
	nvl(ARTICLE_URL_PHOTO.VUE_URL,'url inconnue') AS L14_image,
	RET_LIGNE_RBT.MONTANT_RBT AS L15_prixRemise,
	'-9b4-ZVNQnqi2BEVXffYMQ==' AS L16_X_API_KEY,
	CDE.FAC_NOM AS L17_nom,
	CDE.FAC_CIVILITE AS L18_civilite,
	RET_RBT.DATE_EXPI_FID AS L19_expiration,
	CDE.DATH_CDE AS L20_date,
	case 
when RET_REGLEMENT_RBT.CODE_RGT in (3,26)
then RET_REGLEMENT_RBT.LIB_RGT
else 'Carte Cadeau'
end AS L21_modeRemboursement,
	case when RET_RBT.TYPE_RETOUR = 'manquant' 
then RET_RBT.TYPE_RETOUR 
when RET_RBT.TYPE_RETOUR = 'remiseEnStock'
then RET_RBT.TYPE_RETOUR 
else 'retour'
end  AS L22_motifRemboursement
	
from	(((((((ECOMM.RET_RBT  RET_RBT
								INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
								ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT)
							INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
							ON RET_RBT.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_REGLEMENT_RBT.ID_RBT)
						INNER JOIN ECOMM.CDE  CDE
						ON RET_RBT.ID_CDE = CDE.ID_CDE)
					LEFT OUTER JOIN ECOMM.ARTICLE  ARTICLE
					ON RET_LIGNE_RBT.CODE_EAN = ARTICLE.ID_ARTICLE_INT)
				LEFT OUTER JOIN ECOMM.TAILLE  TAILLE
				ON ARTICLE.ID_GRILLE_TAILLE = TAILLE.ID_GRILLE_TAILLE
and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.ARTICLE_URL_PHOTO  ARTICLE_URL_PHOTO
			ON ARTICLE.ID_REF = ARTICLE_URL_PHOTO.ID_REF
and ARTICLE.ID_COULEUR = ARTICLE_URL_PHOTO.ID_COULEUR
and ARTICLE.ID_SAISON = ARTICLE_URL_PHOTO.ID_SAISON
and ARTICLE_URL_PHOTO.ID_VUE = 'V1')
		LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
		ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
and RET_LIGNE_RBT_2.F_SERVICE = 'O' )
	LEFT OUTER JOIN ECOMM.SERVICES_ECOMM  SERVICES_ECOMM
	ON RET_LIGNE_RBT_2.CODE_EAN = SERVICES_ECOMM.ID_ARTICLE_INT
and SERVICES_ECOMM.ID_MODE_LIVRAISON is not null 
and RET_LIGNE_RBT_2.MONTANT_RBT > 0
where	(1=1) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$) AND (RET_LIGNE_RBT.MONTANT_RBT > 0 AND RET_LIGNE_RBT.F_SERVICE IS NULL)



]]><altId value="_8zSzSdu8EeWIdu0rdnx7VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="6f16599322ccb6f4cb4cc7679cd6b22d" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Analyze" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_XbZ0oGqnEeaHq-wCayLdYQ" origin="compilation"/></step><link type="OK" sourceName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop view staging" targetName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging" mandatory="1" id="d3856af30bf919fa34fcb96600bb7a12"/><link type="OK" sourceName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Drop table stagging" targetName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging" mandatory="1" linkCondition="%e(rhino){}e(rhino)%" id="c095b600bfd958d6f6b7bffaa035bae7"/><link type="OK" sourceName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Creation of staging" targetName="com_maj_remboursement/885 ws ImaginoMailClientJules/S1-stage-Staging/Analyze" mandatory="1" id="7f1051e120bcadeec9b68a32b7fda550"/></process><process actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I1-JLS_FR_FR_REMBOURSEMENT-Integration" isBeginProcess="false"><step id