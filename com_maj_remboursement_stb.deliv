where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE,
			ID_RBT,
			MODE_REGLEMENT
		from	ETLWORK.W_RBT_PREPA_RGT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="2b30e9ec00cb5a455e6c6cc78fa4016e" type="Code" actionName="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.W_RBT_PREPA_RGT T 
set


 (  T.MONTANT_AREMBOURSER
             
       ) = 
             (
             select S.MONTANT_AREMBOURSER
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.MODE_REGLEMENT=T.MODE_REGLEMENT
                     )     


where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE, ID_RBT, MODE_REGLEMENT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="98481e867b7533ca83a48bdc891417e5" type="Code" actionName="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Commit of transaction on target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[commit]]><altId value="_jkWgqFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/370 DB Prepa RET_RE