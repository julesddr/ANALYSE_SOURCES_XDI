ault="false"/><parameter vName="extractBase64BinaryToFile" name="com_maj_remboursement/810 ws RefundPayment/L1-RET_MAJ_LOG_KO_RET_MAJ_LOG_OK-Cleanup/extractBase64BinaryToFile" type="Boolean" value="false" input="false" output="false" fault="false"/><parameter vName="filterEmptyRecords" name="com_maj_remboursement/810 ws RefundPayment/L1-RET_MAJ_LOG_KO_RET_MAJ_LOG_OK-Cleanup/filterEmptyRecords" type="Boolean" value="true" input="false" output="false" fault="false"/></step><link type="OK" sourceName="com_maj_remboursement/810 ws RefundPayment/I1-CancelOrRefund-Integration" targetName="com_maj_remboursement/810 ws RefundPayment/L1-RET_MAJ_LOG_KO_RET_MAJ_LOG_OK-Load" mandatory="1" id="3791e67b47da30dd43406df074d03109"/><link type="OK" sourceName="com_maj_remboursement/810 ws RefundPayment/L1-RET_MAJ_LOG_KO_RET_MAJ_LOG_OK-Load" targetName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration" mandatory="1" id="839e5a9a4c6666a1b749fc780803e2ac"/><link type="OK" sourceName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration" targetName="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration" mandatory="1" id="f9a864d9d5312082492e14aad510f057"/><link type="OK" sourceName="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration" targetName="com_maj_remboursement/810 ws RefundPayment/L1-RET_MAJ_LOG_KO_RET_MAJ_LOG_OK-Cleanup" mandatory="1" id="b9c2b50f8b1a1705a674735672c89acf"/></process><process actionName="com_maj_remboursement/810 ws RefundPayment/I1-CancelOrRefund-Integration" isBeginProcess="false"><step id="a2b8695e8607eeaba316c9f030309b4b" type="Code" actionName="com_maj_remboursement/810 ws RefundPayment/I1-CancelOrRefund-Integration/SqlToXml" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcToXmlActionCodeI"><![CDATA[<sqlToXml:descriptor xmlns:sqlToXml="http://www.stambia.com/sqlToXml">
<sourceSet name="L1_CancelOrRefund" distinct="true"><field isKey="true" id="_uL7zQLauEe29Gd4juh2i5A" alias="L1_CancelOrRefund" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">W_RBT_PAYZEN.ID_CDE<from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN</from></field><field isKey="false" id="_PUzKIM1vEe2kV4GPLFYAXg" alias="L2_Authorization" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CASE WHEN RET_REGLEMENT_RBT.CODE_RGT &lt;> 41  THEN 'Basic ${~/Authorization}$' ELSE 'Basic ${~/AuthorizationAlma}$' END<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="true" id="_uL7zRrauEe29Gd4juh2i5A" alias="L3_result" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_YGFEjLa7Ee29Gd4juh2i5A" alias="L4_amount" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_REGLEMENT_RBT.MONTANT_RGT*100<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="false" id="_YGFEira7Ee29Gd4juh2i5A" alias="L5_currency" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">'EUR'</field><field isKey="false" id="_uL7zR7auEe29Gd4juh2i5A" alias="L6_uuid" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">W_RBT_PAYZEN.UUID<from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN</from></field><query><from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN
	INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
	ON W_RBT_PAYZEN.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and W_RBT_PAYZEN.ID_RBT = RET_REGLEMENT_RBT.ID_RBT</from><where> AND (RET_REGLEMENT_RBT.CODE_RGT IN (3, 26, 24, 25, 33, 41)) AND (W_RBT_PAYZEN.ID_CDE = '${~/p_id_cde}$' AND W_RBT_PAYZEN.ID_RBT = ${~/p_id_rbt}$ AND W_RBT_PAYZEN.TYPE_PMT = 'DEBIT' AND W_RBT_PAYZEN.MODE_PMT IN ('CB', 'PAYPAL', 'CARD'))</where></query></sourceSet>
