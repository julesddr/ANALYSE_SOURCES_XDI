on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% (ID_CDE, ID_RBT, MODE_REGLEMENT)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="5e90c9d0f90f495ab1459f3ec7913888" type="Code" actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE,
			ID_RBT,
			MODE_REGLEMENT
		from	ETLWORK.W_RBT_PREPA_RGT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="1f6af7ea320086aca967335606fcf70a" type="Code" actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.W_RBT_PREPA_RGT T 
set


 (  T.MONTANT_REMBOURSE
             ,T.SESSION_ID
       ) = 
             (
             select S.MONTANT_REMBOURSE
                           ,'${/CORE_SESSION_ID}$'
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.MODE_REGLEMENT=T.MODE_REGLEMENT
                     )     


where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE, ID_RBT, MODE_REGLEMENT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="f9dd74f593aeb4e8153650216fa34080" type="Code" actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Commit of transaction on target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[commit]]><altId value="_jkWgqFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Commit of