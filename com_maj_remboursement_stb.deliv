	%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5.stb_key is null and
	%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_7.stb_key is null))  L1_RET_MAJ_LOG
