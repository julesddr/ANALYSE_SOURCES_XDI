<sourceSet name="L1_GetOrder" distinct="true"><field isKey="true" id="_ZKfhILarEe29Gd4juh2i5A" alias="L1_GetOrder" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.ID_CDE<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_ZKfhIrarEe29Gd4juh2i5A" alias="L2_Input" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_A5DTG81vEe2kV4GPLFYAXg" alias="L3_Authorization" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CASE WHEN RET_REGLEMENT_RBT.CODE_RGT is null THEN 'Basic ${~/Authorization}$' ELSE 'Basic ${~/AuthorizationAlma}$' END<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="false" id="_ZKfhI7arEe29Gd4juh2i5A" alias="L4_content" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="true" id="_ZKfhJrarEe29Gd4juh2i5A" alias="L5_result" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_ZKfhJ7arEe29Gd4juh2i5A" alias="L6_orderId" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">to_char(to_number(substr(RET_RBT.ID_CDE,1,9)))<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_A5DTGc1vEe2kV4GPLFYAXg" alias="L7_operationType" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">'DEBIT'</field><query><from>ECOMM.RET_RBT  RET_RBT
	LEFT OUTER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
	ON RET_REGLEMENT_RBT.ID_CDE = RET_RBT.ID_CDE
and RET_REGLEMENT_RBT.ID_RBT = RET_RBT.ID_RBT
and RET_REGLEMENT_RBT.CODE_RGT = 41</from><where> AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)</where></query></sourceSet>
