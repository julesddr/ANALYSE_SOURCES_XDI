(
	DATEH,
	ERROR_CODE,
	ERROR_MESSAGE,
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	INCREMENTAL_FLAG
)
select		  
			sysdate AS DATEH,
			L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L7_ERROR_CODE AS ERROR_CODE,
			L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L8_ERROR_MESSAGE AS ERROR_MESSAGE,
			'${~/p_id_cde}$' AS ID_CDE,
			${~/p_id_rbt}$ AS ID_RBT,
			'KO-'||coalesce(L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L10_detailedStatus,L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L11_errorMessage) AS LOG_PAIEMENT,
			'I' INCREMENTAL_FLAG
from	(
select L7_ERROR_CODE,
	L8_ERROR_MESSAGE,
	L9_status,
	L10_detailedStatus,
	L11_errorMessage
from (((((ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0
						LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1
						ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2
					ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3
				ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4
			ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5
		ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6
	ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6.stb_parentKey
where (1=1)
and not(
	%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6.stb_key is null))  L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_
where	(1=1)  AND (L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L9_status <> 'SUCCESS' OR L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L10_detailedStatus = 'REFUSED')
