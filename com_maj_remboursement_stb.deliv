where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE,
			ID_RBT
		from	ECOMM.RET_MAJ_LOG
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="a91e7575968e299f3ac9070f4b0eed92" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ECOMM.RET_MAJ_LOG T 
set


 (  T.DATEH,
		T.LOG_MAIL
             
       ) = 
             (
             select S.DATEH,
				S.LOG_MAIL
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="50abb87daba610fc5de46f3bb2f3e62c" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Insertion of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert  into ECOMM.RET_MAJ_LOG
