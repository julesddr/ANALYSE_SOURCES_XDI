		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/870 DB RET_RBT(Fid)/I1-RET_RBT_2-Integration/I1-RET_RBT_2-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/870 DB RET_RBT(Fid)/I1-RET_RBT_2-Integration/I1-RET_RBT_2-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/870 DB RET_RBT(Fid)/I1-RET_RBT_2-Integration/I1-RET_RBT_2-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="4ddcae61f90565ba334658e2109d8c64" type="Code" actionName="com_maj_remboursement/870 DB RET_RBT(Fid)/I1-RET_RBT_2-Integration/I1-RET_RBT_2-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ECOMM.RET_RBT T 
set


 (  T.CARTE_FID,
		T.DATE_EXPI_FID,
		T.NB_PT_GLOB
             
       ) = 
             (
             select S.CARTE_FID,
				S.DATE_EXPI_FID,
				S.NB_PT_GLOB
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_RBT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
