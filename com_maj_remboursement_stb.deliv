ionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	MODE_REGLEMENT	NUMBER(2,0) NULL,
	MONTANT_AREMBOURSER	NUMBER(10,2) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="e20a8ba3ce291e441c449b1fb0d8edd0" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.MODE_REGLEMENT,
	case when coalesce(W_RBT.MNT_RBT_CAL,0) < coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
then coalesce(W_RBT.MNT_RBT_CAL,0)
else coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
end ,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	INNER JOIN ETLWORK.W_RBT  W_RBT
	ON W_RBT_PREPA_RGT.ID_CDE = W_RBT.ID_CDE
and W_RBT_PREPA_RGT.ID_RBT = W_RBT.ID_RBT
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$' AND W_RBT.MNT_RBT_CAL > 0) AND (W_RBT_PREPA_RGT.MODE_REGLEMENT IN (21, 28))
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="fe45fbdc1953786bc5c0068c0bd5f11e" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_c1jhsGoOEea9fIQJ0nVgng" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table" mandatory="1" id="4e914a2343a0d57e2199ecfd8b78e5f2"/><link type="OK" sourceName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS" mandatory="1" id="d56628ce57a525ef3bd99d29edfccaf7"/><link type="OK" sourceName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS" targetName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" mandatory="1" id="302a8074a17ee9a0ba0fe2ce6c26c0a1"/></process><process actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration" isBeginProcess="false"><step id="723396184b04c3e62cf0097230f82db7" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Start" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_jkWgx1EJEeO7Vo9WeM2sCg" origin="compilation"/></step><step id="dc0e3e5c7b7d6c87886013819d97006c" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Creation of a unique Index on pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[create unique index ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%_IDX 
on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% (ID_CDE, ID_RBT, MODE_REGLEMENT)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="4dad2e7ed38ef84c4901d5a96b7d11f3" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE,
			ID_RBT,
			MODE_REGLEMENT
		from	ETLWORK.W_RBT_PREPA_RGT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="02cb06075f8f8e3491c52ccd85536b33" type="Code" actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.W_RBT_PREPA_RGT T 
set


 (  T.MONTANT_AREMBOURSER
             
       ) = 
             (
             select S.MONTANT_AREMBOURSER
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.MODE_REGLEMENT=T.MODE_REGLEMENT
                     )     


where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE, ID_RBT, MODE_REGLEMENT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% I
