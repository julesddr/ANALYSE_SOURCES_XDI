ntegration/I2-RET_MAJ_LOG_PB-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="25eebb73bdad91a7947442e31b4cbf38" type="Code" actionName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%
(
	DATEH	DATE NULL,
	ERROR_CODE	VARCHAR2(127 BYTE) NULL,
	ERROR_MESSAGE	VARCHAR2(127 BYTE) NULL,
	ID_CDE	VARCHAR2(15 BYTE) NULL,
