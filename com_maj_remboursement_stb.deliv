<sourceSet name="L1_BZB_FR_FR_REMBOURSEMENT" distinct="true"><field isKey="true" id="_gBbAMDSZEe-8XLGEVLwJsw" alias="L1_PRD_BZB_FR_FR_REMBOURSEMENT" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.ID_CDE<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfADSZEe-8XLGEVLwJsw" alias="L2_X_API_KEY" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">'8Dapc_1hTIGemUdM7erANg=='</field><field isKey="false" id="_3fjfCTSZEe-8XLGEVLwJsw" alias="L3_login" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.EMAIL<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_3fjfCzSZEe-8XLGEVLwJsw" alias="L4_prenom" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_PRENOM<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_3fjfDTSZEe-8XLGEVLwJsw" alias="L5_nom" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_NOM<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_3fjfDzSZEe-8XLGEVLwJsw" alias="L6_civilite" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_CIVILITE<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_3fjfFDSZEe-8XLGEVLwJsw" alias="L7_nbpoints" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.NB_PT_GLOB<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfFjSZEe-8XLGEVLwJsw" alias="L8_expiration" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.DATE_EXPI_FID<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfGDSZEe-8XLGEVLwJsw" alias="L9_codecarte" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.CARTE_FID<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfHDSZEe-8XLGEVLwJsw" alias="L10_modeRemboursement" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">case 
when RET_REGLEMENT_RBT.CODE_RGT in (3,26)
then RET_REGLEMENT_RBT.LIB_RGT
else 'Carte Cadeau'
end<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="false" id="_3fjfHzSZEe-8XLGEVLwJsw" alias="L11_article" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.LIB_COMM<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="true" id="_3fjfIDSZEe-8XLGEVLwJsw" alias="L12_item" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.CODE_EAN<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_3fjfITSZEe-8XLGEVLwJsw" alias="L13_coloris" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.ID_COULEUR<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="false" id="_3fjfIzSZEe-8XLGEVLwJsw" alias="L14_image" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE_URL_PHOTO.VUE_URL<from>ECOMM.ARTICLE_URL_PHOTO  ARTICLE_URL_PHOTO</from></field><field isKey="false" id="_3fjfJzSZEe-8XLGEVLwJsw" alias="L15_prixRemise" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.MONTANT_RBT<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_3fjfKTSZEe-8XLGEVLwJsw" alias="L16_qte" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_3fjfKzSZEe-8XLGEVLwJsw" alias="L17_reference" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.CODE_EAN<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_3fjfLTSZEe-8XLGEVLwJsw" alias="L18_taille" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">TAILLE.LIB_TAILLE<from>ECOMM.TAILLE  TAILLE</from></field><field isKey="false" id="_3fjfLzSZEe-8XLGEVLwJsw" alias="L19_description" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.LIB_PRODUIT<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="false" id="_3fjfMjSZEe-8XLGEVLwJsw" alias="L20_montantTotal" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.MNT_RBT<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfNDSZEe-8XLGEVLwJsw" alias="L21_numero" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">substr(RET_RBT.ID_CDE,1,9)<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_3fjfNjSZEe-8XLGEVLwJsw" alias="L22_date" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.DATH_CDE<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_3fjfODSZEe-8XLGEVLwJsw" alias="L23_motifRemboursement" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">case when RET_RBT.TYPE_RETOUR = 'manquant' 
then RET_RBT.TYPE_RETOUR 
when RET_RBT.TYPE_RETOUR = 'remiseEnStock'
then RET_RBT.TYPE_RETOUR 
else 'retour'
end <from>ECOMM.RET_RBT  RET_RBT</from></field><query><from>(((((((ECOMM.RET_RBT  RET_RBT
								INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
								ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT)
							INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
							ON RET_RBT.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_REGLEMENT_RBT.ID_RBT)
						INNER JOIN ECOMM.CDE  CDE
						ON RET_RBT.ID_CDE = CDE.ID_CDE)
					LEFT OUTER JOIN ECOMM.ARTICLE  ARTICLE
					ON RET_LIGNE_RBT.CODE_EAN = ARTICLE.ID_ARTICLE_INT)
				LEFT OUTER JOIN ECOMM.TAILLE  TAILLE
				ON ARTICLE.ID_GRILLE_TAILLE = TAILLE.ID_GRILLE_TAILLE
and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.ARTICLE_URL_PHOTO  ARTICLE_URL_PHOTO
			ON ARTICLE.ID_REF = ARTICLE_URL_PHOTO.ID_REF
and ARTICLE.ID_COULEUR = ARTICLE_URL_PHOTO.ID_COULEUR
and ARTICLE.ID_SAISON = ARTICLE_URL_PHOTO.ID_SAISON
and ARTICLE_URL_PHOTO.ID_VUE = 'V1')
		LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
		ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
and RET_LIGNE_RBT_2.F_SERVICE = 'O' )
	LEFT OUTER JOIN ECOMM.SERVICES_ECOMM  SERVICES_ECOMM
	ON RET_LIGNE_RBT_2.CODE_EAN = SERVICES_ECOMM.ID_ARTICLE_INT
and SERVICES_ECOMM.ID_MODE_LIVRAISON is not null 
and RET_LIGNE_RBT_2.MONTANT_RBT > 0</from><where> AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$) AND (RET_LIGNE_RBT.MONTANT_RBT > 0 AND RET_LIGNE_RBT.F_SERVICE IS NULL)</where></query></sourceSet>
