(
	CODE	VARCHAR2(15 BYTE) NULL,
	END_DATE_VALID	TIMESTAMP(6) NULL,
	REMAIN_USE_COUNT	NUMBER(22,0) NULL,
	STATUS_CODE	VARCHAR2(1 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="02c7fd460668708aa03528fb12705456" type="Code" actionName="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Insertion of preintegration data - APPEND" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)%
(
	CODE,
	END_DATE_VALID,
	REMAIN_USE_COUNT,
	STATUS_CODE,
	INCREMENTAL_FLAG
)
select		  
			L1_COUPON.L1_CODE AS CODE,
			L1_COUPON.L2_END_DATE_VALID AS END_DATE_VALID,
			L1_COUPON.L3_REMAIN_USE_COUNT AS REMAIN_USE_COUNT,
			L1_COUPON.L4_STATUS_CODE AS STATUS_CODE,
			'I' INCREMENTAL_FLAG
from	ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)%  L1_COUPON
where	(1=1) 
]]><altId value="_jkWgflEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Insertion of preintegration data - APPEND/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Insertion of preintegration data - APPEND/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Insertion of preintegration data - APPEND/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="2c5e20c8d3f6fbeb6b60e082b290da4a" type="Code" actionName="com_maj_remboursement/890 DB Coupon/I1-COUPON-Integration/I1-COUPON-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"COUPON").substring(0,26);}e(rhino)%'
   
);
