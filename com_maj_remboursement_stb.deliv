ON_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% purge]]><altId value="_jkWgMlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="58e997f4bd763ec7de748a9dd42b67c9" type="Code" actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	MNT_RBT_CAL	NUMBER(8,2) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="f3797fe06e93f72a10dc2da833cf7472" type="Code" actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	MNT_RBT_CAL,
	SESSION_ID,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT.MNT_RBT_CAL - W_RBT_PREPA_RGT.MONTANT_AREMBOURSER,
	W_RBT_PREPA_RGT.SESSION_ID,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	ON W_RBT.ID_CDE = W_RBT_PREPA_RGT.ID_CDE
and W_RBT.ID_RBT = W_RBT_PREPA_RGT.ID_RBT
and W_RBT.SESSION_ID = W_RBT_PREPA_RGT.SESSION_ID
where	(1=1)  AND (W_RBT_PREPA_RGT.MODE_REGLEMENT IN (21, 28) AND W_RBT_PREPA_RGT.MONTANT_AREMBOURSER IS NOT NULL) AND (W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$')
minus
select
	ID_CDE,
	ID_RBT,
	MNT_RBT_CAL,
	SESSION_ID,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="02a4ba7abd7ec71030be3b4a5d5cf465" type="Code" actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%'
   
);
end;]]><altId value="_c1jhsGoOEea9fIQJ0nVgng" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><link type="OK" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" mandatory="1" id="7667f7c0663f918baded792acf4dc777"/><link type="OK" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" mandatory="1" id="cebb8471ad436be070ea6c456a594727"/><link type="OK" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-