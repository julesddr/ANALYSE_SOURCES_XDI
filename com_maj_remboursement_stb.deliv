method)" mandatory="1" id="9671a6549d8f4a7bd2e5223a0742f234"/></process><process actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration" isBeginProcess="false"><step id="ceffcaf0f4e4146a07191d7f8cc791f1" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Start" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_jkWgx1EJEeO7Vo9WeM2sCg" origin="compilation"/></step><step id="a3ad0f50db727b318c7c17fca15100f5" type="Code" actionName="com_maj_remboursement/885 ws ImaginoMailClientJules/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Creation of a unique Index on pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[create unique index ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_IDX 
