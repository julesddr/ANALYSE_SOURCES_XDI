b759de6" type="Code" actionName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%
(
	DATEH	DATE NULL,
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	LOG_PAIEMENT	VARCHAR2(100 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="e2d54986ac6259943ff3a3113f09e1b8" type="Code" actionName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of preintegration data - APPEND" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%
(
	DATEH,
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	INCREMENTAL_FLAG
)
select		  
			sysdate AS DATEH,
			'${~/p_id_cde}$' AS ID_CDE,
			${~/p_id_rbt}$ AS ID_RBT,
			'OK-'||L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L10_detailedStatus AS LOG_PAIEMENT,
			'I' INCREMENTAL_FLAG
from	(
select L9_status,
	L10_detailedStatus
from (((((ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0
						LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1
						ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_0.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2
					ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_1.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3
				ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_2.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4
			ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_3.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5
		ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_4.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6  %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6
	ON %e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_5.stb_key=%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6.stb_parentKey
where (1=1)
and not(
	%e(rhino){("L1_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)%_6.stb_key is null))  L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_
where	(1=1)  AND (L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L9_status = 'SUCCESS' AND L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L10_detailedStatus IN ('AUTHORISED', 'CAPTURED', 'WAITING_FOR_PAYMENT'))
]]><altId value="_jkWgflEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of preintegration data - APPEND/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of preintegration data - APPEND/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of preintegration data - APPEND/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="c715221c2e6eb3e6308ce8fb952e17fd" type="Code" actionName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
