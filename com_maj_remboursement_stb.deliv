set


 (  T.DATEH,
		T.LOG_MAIL
             
       ) = 
             (
             select S.DATEH,
				S.LOG_MAIL
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_MAJ_LOG").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
