f329bbaf8f468ad3cf9584" type="Process" actionName="com_maj_remboursement/886 ws ImaginoMailClientBzb" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default"><altId value="_Ia-ocDSbEe-8XLGEVLwJsw" origin="mapping"/><altId value="_Ia-ocDSbEe-8XLGEVLwJsw-flow" origin="flow"/><altId value="_Ia-ocDSbEe-8XLGEVLwJsw-proc" origin="processRef"/><altId value="_g4KtoDUrEe-Uxr7XmfhDLQ" origin="compilation"/></step><step id="cb0f08336b4a4e6b6b6d3a993d5b1e89" type="Process" actionName="com_maj_remboursement/890 DB Coupon" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default"><altId value="_J6Q7QHOmEei1MdTkUZz1Xg" origin="mapping"/><altId value="_J6Q7QHOmEei1MdTkUZz1Xg-flow" origin="flow"/><altId value="_J6Q7QHOmEei1MdTkUZz1Xg-proc" origin="processRef"/><altId value="_CxkWQHPSEei1MdTkUZz1Xg" origin="compilation"/></step><step id="25004a9f49fce58e1704aebd2dc8acf9" type="Code" actionName="com_maj_remboursement/Start" nbCycles="-1" toleratedError="false" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_xqHcBEoiEeifE4ZtNzHACQ" origin="compilation"/></step><step id="eff3344a4b9d080209bc7ad4f78976c4" type="Code" actionName="com_maj_remboursement/Cde_Du_jour" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_RAF" type="String">
select 
case when trunc(dath_cde) = trunc(sysdate) 
then 0 
else 1 end
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>
</sqlToParameters>]]><altId value="_uQHtAHkXEeiwMtziZ7V5yg" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Cde_Du_jour/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Cde_Du_jour/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="da459cb3a53465cae86e3e9e1c3f2ad6" type="Code" actionName="com_maj_remboursement/Mail" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../MAIL" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'e-shopping@Jules.fr' 
when '01601' then 'e-shopping@Jules.fr'
when '02600' then 'contact-clients@bizzbee.fr'
when '03600' then 'serviceclientsbrice@brice.fr' 
when '03651' then 'serviceclientsbrice@brice.fr'
else 'e-shopping@Jules.fr'
end
from dual 
</parameter>
<parameter name="../Authorization" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw==' 
when '01601' then 'MTExMDkzOTQ6cHJvZHBhc3N3b3JkX0dTNVV4VmpGdVBIVDRaMXhQRWlWN21RZUZ6eWhJZGtDZ0RmbXpJQUlYMGc0Rg=='
when '02600' then 'OTI0NTI2NjI6cHJvZHBhc3N3b3JkX3BIdU1JSTI4VHJFanNyOHFMejJNSnZYR0ZhQ3l1VXRVRnQyeldQQThtd2RPSA=='
else 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw=='
end
from dual 
</parameter>
<parameter name="../AuthorizationAlma" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'OTIzMjIxODI6cHJvZHBhc3N3b3JkX2U4cFgyNmM5S25iNTMwNG1ONzJSdkJOUVM5TzNkanB5RGNJSnRvQ1NYNGVHbA==' 
when '02600' then 'NzkwMDg1MjI6cHJvZHBhc3N3b3JkX0Q5V1NlVDFVZVowanpyam9Uak5FTkNhbkhHRUdiS1VzdkFtRVZuVHVmaGNNZA=='
end
from dual 
</parameter>

</sqlToParameters>]]><altId value="_y-AKQHSqEeiJQNbqcdZmww" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Mail/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Mail/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="bdbbfab110e6fa88e699849a5442cb71" type="Code" actionName="com_maj_remboursement/Stop" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_v5uIEHkXEeiwMtziZ7V5yg" origin="compilation"/></step><step id="b35cbe10312b165deff0ba60256ebdce" type="Code" actionName="com_maj_remboursement/Enseigne" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_ENSEIGNE" type="String">
select ens.libmarque
from ECOMM.CDE cde , 
ECOMM.ENSEIGNE ens 
where cde.id_cde = '${~/p_id_cde}$' 
and cde.id_enseigne = ens.id_enseigne
</parameter>
</sqlToParameters>]]><altId value="_6AHoIIphEeiGNdxXqHE_VQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Enseigne/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Enseigne/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="f0df6a5ca95373232f16bbb01ac8d33d" type="Code" actionName="com_maj_remboursement/Type_Rbt" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_TYPE" type="Integer">
select COALESCE(count(1),0)
from ECOMM.RET_LIGNE_RBT 
where id_cde = '${~/p_id_cde}$' 
and id_rbt = ${~/p_id_rbt}$ 
and montant_rbt_force is not null 
</parameter>
</sqlToParameters>]]><altId value="_Vrk90FHTEeifE4ZtNzHACQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Type_Rbt/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Type_Rbt/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="f393d36b009e3371010a3dc3819a2cb5" type="Code" actionName="com_maj_remboursement/Forcé" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_q1osgFHuEei2h5H__NezWQ" origin="compilation"/></step><step id="92d205463e9e96b31573c07414d45b7b" type="Code" actionName="com_maj_remboursement/Calculé" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_yXRR8FHuEei2h5H__NezWQ" origin="compilation"/></step><step id="e0895cf0814d532e0c71fed17852d89c" type="Code" actionName="com_maj_remboursement/Montant_Possible" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_MONTANT_OK" type="String">
select sum(coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0)) - sum(coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0))
from  ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
where W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$'
group by W_RBT_PREPA_RGT.SESSION_ID 
</parameter>
</sqlToParameters>]]><altId value="_SZjFYHROEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Montant_Possible/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Montant_Possible/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/></step><step id="471c1bc89e51a8cd786913c5f27c97a1" type="Code" actionName="com_maj_remboursement/Montant_Force_Correct" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_MNT_OK" type="Integer">
select case when W_RBT.MNT_RBT > to_number(${~/P_MONTANT_OK}$)
then 0
else 1
end
from ETLWORK.W_RBT  W_RBT, ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
where W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$'
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
</parameter>
</sqlToParameters>]]><altId value="_4gEIEHQPEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Montant_Force_Correct/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Montant_Force_Correct/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/></step><step id="84e66ee3dfada20ff2673ce619cab1cb" type="Code" actionName="com_maj_remboursement/SendMontantForceKO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_vyfXIHQTEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/SendMontantForceKO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/SendMontantForceKO/MAIL_TO" type="String" value="${~/MAIL}$"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/SendMontantForceKO/MAIL_SUBJECT" type="String" value="Commande '${~/p_id_cde}$' - Montant remboursemebt forcé trop élevé"/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/SendMontantForceKO/MAIL_TEXT" type="String" value="Bonjour , &#xa;&#xa;La somme des montants forcés dans CBO pour la commande ${~/p_id_cde}$ est supérieure au montant remboursable de la commande.&#xa;&#xa;Veuillez saisir des montants dont la somme doit être inférieure ou égale à : ${~/P_MONTANT_OK}$ €.&#xa;&#xa;Vous pouvez également laisser les montants calculés. &#xa;&#xa;Pensez à valider de nouveau la demande de remboursement dans CBO.&#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/SendMontantForceKO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/><parameter vName="MAIL_PORT" name="com_maj_remboursement/SendMontantForceKO/MAIL_PORT" type="String" value="25"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/SendMontantForceKO/MAIL_USE_SSL" type="String" value="false"/></step><step id="ea9e8db362e2590554723edc232b8659" type="Code" actionName="com_maj_remboursement/RAZ_Montant_Force" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.RET_LIGNE_RBT
set MONTANT_RBT_FORCE = null 
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;
update ECOMM.RET_RBT
set STATUT = 'DEMREMBCAL' 
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;]]><altId value="_IpeFgHQZEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/RAZ_Montant_Force/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_MULTI_QUERYS" name="com_maj_remboursement/RAZ_Montant_Force/SQL_MULTI_QUERYS" type="Boolean" value="true"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/RAZ_Montant_Force/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/RAZ_Montant_Force/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="8c702b9734c0ee1193486c6b3d889837" type="Code" actionName="com_maj_remboursement/Purge_W" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[delete from w_rbt where session_id = '${/CORE_SESSION_ID}$' ; 
delete from w_rbt_prepa_rgt where session_id = '${/CORE_SESSION_ID}$' ; 

commit ; ]]><altId value="_R0MYwHRSEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/Purge_W/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_MULTI_QUERYS" name="com_maj_remboursement/Purge_W/SQL_MULTI_QUERYS" type="Boolean" value="true"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Purge_W/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Purge_W/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/></step><step id="9d0fe4fa888383c5b97c7cfd140b9c64" type="Code" actionName="com_maj_remboursement/Purge2_W" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[delete from w_rbt where session_id = '${/CORE_SESSION_ID}$' ; 
delete from w_rbt_prepa_rgt where session_id = '${/CORE_SESSION_ID}$' ; 

commit ; ]]><altId value="_zHhIsHRUEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/Purge2_W/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_MULTI_QUERYS" name="com_maj_remboursement/Purge2_W/SQL_MULTI_QUERYS" type="Boolean" value="true"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Purge2_W/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Purge2_W/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/></step><step id="4422a86d381435cfa9bbe4c52ea97df4" type="Code" actionName="com_maj_remboursement/MAJ_Montant" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.RET_LIGNE_RBT
set MONTANT_RBT = MONTANT_RBT_FORCE, MONTANT_RBT_FORCE = null
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ 
and MONTANT_RBT_FORCE > 0 ;
update ECOMM.RET_RBT
set MNT_RBT = (select sum(MONTANT_RBT) from ECOMM.RET_LIGNE_RBT 
	where ID_CDE = ${~/p_id_cde}$ and ID_RBT = ${~/p_id_rbt}$ )
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;
]]><altId value="_-EKBwHQaEeiP1OY0c7ac_A" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/MAJ_Montant/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_MULTI_QUERYS" name="com_maj_remboursement/MAJ_Montant/SQL_MULTI_QUERYS" type="Boolean" value="true"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/MAJ_Montant/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/MAJ_Montant/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="045a6c1809f46a28906be0b3ddb5af17" type="Code" actionName="com_maj_remboursement/Recup param" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_PAIEMENT" type="Integer">
select paiement
from ECOMM.RET_PARAM_MAJRBT 
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) 
</parameter>
<parameter name="../P_MAIL" type="Integer">
select MAIL_CLIENT
from ECOMM.RET_PARAM_MAJRBT 
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) 
</parameter>
<parameter name="../P_ENTITE" type="Integer">
select to_number(substr('${~/p_id_cde}$',10,5)) from dual  
</parameter>
<parameter name="../P_PAYZEN" type="Integer">
select count(*)
from  ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$
and code_rgt in (3,26,24,25,33,41)
</parameter>
<parameter name="../P_KDO" type="Integer">
select count(*)
from  ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$
and code_rgt in (21,27,28)
</parameter>
</sqlToParameters>
]]><altId value="_XWXIcF23Eei5LeyMyUrTrw" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Recup param/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Recup param/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="6991267526a0bab9924af459c2cc8bee" type="Code" actionName="com_maj_remboursement/Generer_Paiement ?" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_kYObQF3CEei5LeyMyUrTrw" origin="compilation"/></step><step id="7282c5b55bba3c3a46ce171f50e71737" type="Code" actionName="com_maj_remboursement/Remboursement_CB_Paypal ?" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_N5H1YHCkEeiNlP_LYOP54A" origin="compilation"/></step><step id="68890490f255b8e03b9326e4023eb1bd" type="Code" actionName="com_maj_remboursement/Paiement_trouvé" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_PMTOK" type="Integer">
select 
count(*) 
from ETLWORK.W_RBT_PAYZEN 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
</sqlToParameters>
]]><altId value="_RteGYHDIEeikv7li6YNAXQ" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Paiement_trouvé/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Paiement_trouvé/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="372b3a46692593e74433424df44a6e01" type="Code" actionName="com_maj_remboursement/MailPayzen1KO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_32UH4KtvEeiG3JTWE2CwuA" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/MailPayzen1KO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/MailPayzen1KO/MAIL_TO" type="String" value="${~/mail_info}$"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/MailPayzen1KO/MAIL_SUBJECT" type="String" value="Maj remboursement - Erreur WS Payzen "/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/MailPayzen1KO/MAIL_TEXT" type="String" value="Bonjour, &#xa;&#xa;Erreur dans le retour du WS Payzen (Find) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xa;&#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/MailPayzen1KO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/MailPayzen1KO/MAIL_USE_SSL" type="String" value="false"/><parameter vName="MAIL_PORT" name="com_maj_remboursement/MailPayzen1KO/MAIL_PORT" type="String" value="25"/></step><step id="8f7b1a931b7c6bab1e86fe4973694c47" type="Code" actionName="com_maj_remboursement/SqlOperation" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[select UUID, id_cde, id_rbt, to_number(substr(id_cde,10,5)) as entite
from ETLWORK.W_RBT_PAYZEN 
where ID_CDE = '${~/p_id_cde}$' and ID_RBT = ${~/p_id_rbt}$
]]><altId value="_5UWzsD8eEemdtpAAVzw1lg" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/SqlOperation/SQL_ACTION_TYPE" type="String" value="SELECT"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/SqlOperation/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/SqlOperation/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="7fb5c3ceac45d63768a286bd9a2fdeea" type="Code" actionName="com_maj_remboursement/ExecuteDelivery" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.ExecDeliveryActionCodeI"><altId value="_AFABED8fEemdtpAAVzw1lg" origin="compilation"/><parameter vName="DELIV_NAME" name="com_maj_remboursement/ExecuteDelivery/DELIV_NAME" type="String" value="detail_paiement"/><parameter vName="DELIV_SESSION_NAME" name="com_maj_remboursement/ExecuteDelivery/DELIV_SESSION_NAME" type="String" value="detail_paiement_:{UUID}:"/><parameter vName="p_id_cde" name="com_maj_remboursement/ExecuteDelivery/p_id_cde" type="String" value=":{id_cde}:"/><parameter vName="p_id_rbt" name="com_maj_remboursement/ExecuteDelivery/p_id_rbt" type="Integer" value=":{id_rbt}:"/><parameter vName="uuid" name="com_maj_remboursement/ExecuteDelivery/uuid" type="String" value=":{UUID}:"/><parameter vName="p_entite" name="com_maj_remboursement/ExecuteDelivery/p_entite" type="String" value=":{entite}:"/><parameter vName="Authorization" name="com_maj_remboursement/ExecuteDelivery/Authorization" type="String" value="${~/Authorization}$"/><parameter vName="AuthorizationAlma" name="com_maj_remboursement/ExecuteDelivery/AuthorizationAlma" type="String" value="${~/AuthorizationAlma}$"/></step><step id="21145f6f07bf307fa068daef4537c02a" type="Code" actionName="com_maj_remboursement/DetailTrouvé" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_DETAIL" type="Integer">
select count(*) 
from ETLWORK.W_RBT_PAYZEN DET
where DET.id_cde = '${~/p_id_cde}$'
and DET.id_rbt = ${~/p_id_rbt}$
and DET.type_pmt = 'DEBIT'
and DET.mode_pmt in ('CB','PAYPAL','CARD','ALMA')
</parameter>
</sqlToParameters>
]]><altId value="_jJgoYECuEemNS8-fX7iQiQ" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/DetailTrouvé/SQL_SCHEMA_NAME" type="String" value="ETLWORK"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/DetailTrouvé/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="fe87bcf9d4cf0418875d87effda94523" type="Code" actionName="com_maj_remboursement/RefundPayzen" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_-kYqwHDJEeikv7li6YNAXQ" origin="compilation"/></step><step id="6b8d25d6cfab8c0d826a2142fd1e0269" type="Code" actionName="com_maj_remboursement/MailPayzen2KO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_ck66AECuEemNS8-fX7iQiQ" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/MailPayzen2KO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/MailPayzen2KO/MAIL_TO" type="String" value="${~/mail_info}$"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/MailPayzen2KO/MAIL_SUBJECT" type="String" value="Maj remboursement - Erreur WS Payzen "/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/MailPayzen2KO/MAIL_TEXT" type="String" value="Bonjour, &#xa;&#xa;Erreur dans le retour du WS Payzen (Detail) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xa;&#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/MailPayzen2KO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/><parameter vName="MAIL_PORT" name="com_maj_remboursement/MailPayzen2KO/MAIL_PORT" type="String" value="25"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/MailPayzen2KO/MAIL_USE_SSL" type="String" value="false"/></step><step id="8a05faf32a694aece063677724af29ad" type="Code" actionName="com_maj_remboursement/Remboursement_payzen_effectué" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_PMTBOK" type="Integer">
select 
case when LOG_PAIEMENT like 'OK%'
then 1
else 0 end
from ECOMM.RET_MAJ_LOG 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
</sqlToParameters>
]]><altId value="_t49xIHDbEeiit8uYVX8piQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Remboursement_payzen_effectué/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Remboursement_payzen_effectué/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="23053ecf75089ec9b06f012f3acc759f" type="Code" actionName="com_maj_remboursement/MailPayzen3KO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_hzJO0KtzEeiG3JTWE2CwuA" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/MailPayzen3KO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/MailPayzen3KO/MAIL_TO" type="String" value="${~/mail_info}$"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/MailPayzen3KO/MAIL_SUBJECT" type="String" value="Maj remboursement - Erreur WS Payzen "/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/MailPayzen3KO/MAIL_TEXT" type="String" value="Bonjour, &#xa;&#xa;Erreur dans le retour du WS Payzen (Refund) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xa;&#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/MailPayzen3KO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/><parameter vName="MAIL_PORT" name="com_maj_remboursement/MailPayzen3KO/MAIL_PORT" type="String" value="25"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/MailPayzen3KO/MAIL_USE_SSL" type="String" value="false"/></step><step id="ae5c94611b21298853337287f684e313" type="Code" actionName="com_maj_remboursement/REMBKOB" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.LCDE 
set statut_lcde = 'REMBKOB' , dath_s_rembkob = sysdate, dath_maj = sysdate
where id_cde = '${~/p_id_cde}$' and statut_lcde = 'DEMREMB';
update ECOMM.RET_RBT 
set statut = 'REMBKOB' 
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ ;]]><altId value="_lU1z8HDbEeiit8uYVX8piQ" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/REMBKOB/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_MULTI_QUERYS" name="com_maj_remboursement/REMBKOB/SQL_MULTI_QUERYS" type="Boolean" value="true"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/REMBKOB/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/REMBKOB/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="fd5729d35f00ae0669ea560b4619df0b" type="Code" actionName="com_maj_remboursement/Carte_KDO?" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_eEARMHJoEei1MdTkUZz1Xg" origin="compilation"/></step><step id="c40975e17d85feb9e6c8cebf175fb164" type="Code" actionName="com_maj_remboursement/Donnees_KDO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_MONTANTKDO" type="Integer">
select sum(MONTANT_RGT)
from ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' 
and id_rbt = ${~/p_id_rbt}$ 
and CODE_RGT in (21,27,28)
</parameter>
<parameter name="../P_NUMCLIENT" type="String">
select ID_CLIENT
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>
</sqlToParameters>]]><altId value="_vl3wAHJpEei1MdTkUZz1Xg" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Donnees_KDO/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Donnees_KDO/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="367b747ebf532f17ba8468cff363a605" type="Code" actionName="com_maj_remboursement/Sql To Parameters" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_NOMCLIENT" type="String">
select nvl(NOM||' - '||PRENOM,'-')
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$' 
</parameter>
<parameter name="../P_MAILCLIENT" type="String">
select nvl(EMAIL,'-')
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$'
</parameter>
<parameter name="../P_ADRCLIENT" type="String">
select nvl(COMPLEMENTADRESSE||' - '||LIBELLEVOIE||' - '||CODEPOSTAL||' - '||VILLE||' - '||CODEPAYS,'-')
from STORELAND.ADRESSES_CLIENT 
where CODEADRESSECLIENT = (select CODEADRESSECLIENT
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$')
</parameter>
</sqlToParameters>]]><altId value="_i8VnMHJqEei1MdTkUZz1Xg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Sql To Parameters/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Sql To Parameters/SQL_SCHEMA_NAME" type="String" value="STORELAND"/></step><step id="3d0777e632d50900803af21c982772b9" type="Code" actionName="com_maj_remboursement/SendEmailKDO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_N1atQHJpEei1MdTkUZz1Xg" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/SendEmailKDO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/SendEmailKDO/MAIL_TO" type="String" value="e-shopping@Jules.fr"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/SendEmailKDO/MAIL_SUBJECT" type="String" value="Génération carte KDO suite Remboursement Commande ${~/p_id_cde}$"/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/SendEmailKDO/MAIL_TEXT" type="String" value="Bonjour, &#xa;&#xa;Suite à un retour commande, une carte cadeau est à générer. &#xa;&#xa;Carte cadeau d'un montant de : ${~/P_MONTANTKDO}$ € pour l'enseigne : ${~/P_ENSEIGNE}$&#xa;&#xa;Pour le client : ${~/P_NUMCLIENT}$ - ${~/P_NOMCLIENT}$&#xa;&#xa;Mail : ${~/P_MAILCLIENT}$&#xa;&#xa;Adresse postale : ${~/P_ADRCLIENT}$ &#xa;&#xa;&#xa;Le ticket retour a été créé dans Storeland, pas besoin de prévenir la comptabilité de ce remboursement. &#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_PORT" name="com_maj_remboursement/SendEmailKDO/MAIL_PORT" type="String" value="25"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/SendEmailKDO/MAIL_USE_SSL" type="String" value="false"/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/SendEmailKDO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/></step><step id="cc6943fd27f5480480055c0152c72ef5" type="Code" actionName="com_maj_remboursement/MailStorelandKO" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI"><altId value="_q3XoYKtzEeiG3JTWE2CwuA" origin="compilation"/><parameter vName="MAIL_FROM" name="com_maj_remboursement/MailStorelandKO/MAIL_FROM" type="String" value="stambia@happychicgroup.com"/><parameter vName="MAIL_TO" name="com_maj_remboursement/MailStorelandKO/MAIL_TO" type="String" value="${~/mail_info}$"/><parameter vName="MAIL_SUBJECT" name="com_maj_remboursement/MailStorelandKO/MAIL_SUBJECT" type="String" value="Maj remboursement - Erreur WS Payzen "/><parameter vName="MAIL_TEXT" name="com_maj_remboursement/MailStorelandKO/MAIL_TEXT" type="String" value="Bonjour, &#xa;&#xa;Erreur dans le retour du WS Storeland pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xa;&#xa;&#xa;Cordialement,&#xa;Informatique Commerce "/><parameter vName="MAIL_PORT" name="com_maj_remboursement/MailStorelandKO/MAIL_PORT" type="String" value="25"/><parameter vName="MAIL_USE_SSL" name="com_maj_remboursement/MailStorelandKO/MAIL_USE_SSL" type="String" value="false"/><parameter vName="MAIL_HOSTNAME" name="com_maj_remboursement/MailStorelandKO/MAIL_HOSTNAME" type="String" value="baffin.global.local"/></step><step id="81aeaba0e35f433d96a4932fbf6abe63" type="Code" actionName="com_maj_remboursement/Statut Erreur sur RET_RBT" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.RET_RBT 
set statut = 'DEMREMBERR' 
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ ]]><altId value="_b19esKtzEeiG3JTWE2CwuA" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/Statut Erreur sur RET_RBT/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Statut Erreur sur RET_RBT/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Statut Erreur sur RET_RBT/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="e14b0577c440dd0fa24513901e376734" type="Code" actionName="com_maj_remboursement/Mail_client" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI"><altId value="_sZ3iAF24Eei5LeyMyUrTrw" origin="compilation"/></step><step id="3e044d164fbe51995792fe4854ad3146" type="Code" actionName="com_maj_remboursement/Mail_Renseigne" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../MAIL_CDE" type="Integer">
select case when nvl(EMAIL,'NON RENSEIGNE') = 'NON RENSEIGNE' then 0 
else 1 
end
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>

<parameter name="../ID_ENSEIGNE" type="Integer">
select ID_ENSEIGNE
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>


</sqlToParameters>
]]><altId value="_CyPBkINdEeiWr4QMKGVLkg" origin="compilation"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/Mail_Renseigne/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/Mail_Renseigne/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="b448ded97f6ffa61a2488a045e3755e3" type="Code" actionName="com_maj_remboursement/MAJ LCDE" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.LCDE 
set statut_lcde = 'REMBOK' , dath_s_rembok = sysdate, dath_maj = sysdate
where id_cde||'-'||id_lcde  
in (select id_cde||'-'||id_lcde from ECOMM.RET_LIGNE_RBT 
where id_cde = '${~/p_id_cde}$' 
 and id_rbt = ${~/p_id_rbt}$) ]]><altId value="_LR1WcDA4EemgFJeYtFBU1A" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/MAJ LCDE/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/MAJ LCDE/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/MAJ LCDE/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="c3b33711b2b0f0ebd4baf73de48f8156" type="Code" actionName="com_maj_remboursement/MAJ RET_RBT" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update ECOMM.RET_RBT 
set statut = 'REMBOK' 
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$]]><altId value="_4MIGwF3GEei5LeyMyUrTrw" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/MAJ RET_RBT/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/MAJ RET_RBT/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/MAJ RET_RBT/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="0475f689f47882ffb7306a7925dffff0" type="Code" actionName="com_maj_remboursement/IS_MKP" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters"><![CDATA[<sqlToParameters>
<parameter name="../P_MKP" type="Integer">
select count(1)
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
and id_cde_ext is not null
</parameter>
</sqlToParameters>
]]><altId value="_aGlJkOqDEe66Wv8pfaGQpQ" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/IS_MKP/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/IS_MKP/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><step id="c30c6c5c814cdbd04a64ea24b573c0d8" type="Code" actionName="com_maj_remboursement/INSERT RET_RBT MKP" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[INSERT INTO ECOMM.RET_RBT_MKP
SELECT * from   ECOMM.RET_RBT
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ and statut = 'REMBOK'
]]><altId value="_0DXGkOqBEe66Wv8pfaGQpQ" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/INSERT RET_RBT MKP/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/INSERT RET_RBT MKP/SQL_SCHEMA_NAME" type="String" value="ECOMM"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/INSERT RET_RBT MKP/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/></step><step id="6de47a928fc7ecd59c4af685a624f255" type="Code" actionName="com_maj_remboursement/DELETE  RET_RBT" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[DELETE FROM ECOMM.RET_RBT  
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$  and statut = 'REMBOK'

]]><altId value="_u54ZYOqDEe66Wv8pfaGQpQ" origin="compilation"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/DELETE  RET_RBT/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/DELETE  RET_RBT/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_SCHEMA_NAME" name="com_maj_remboursement/DELETE  RET_RBT/SQL_SCHEMA_NAME" type="String" value="ECOMM"/></step><link type="OK" sourceName="com_maj_remboursement/Start" targetName="com_maj_remboursement/Cde_Du_jour" mandatory="1" id="c4bc378b9e7095b9abda519fc0397aa9"/><link type="OK" sourceName="com_maj_remboursement/Cde_Du_jour" targetName="com_maj_remboursement/Stop" mandatory="1" linkCondition="%e(rhino){${P_RAF}$ == 0}e(rhino)%" id="23e40cae690d9b08ddfdf7c46247c401"/><link type="OK" sourceName="com_maj_remboursement/Cde_Du_jour" targetName="com_maj_remboursement/Mail" mandatory="1" linkCondition="%e(rhino){${P_RAF}$ == 1}e(rhino)%" id="26fd0aaccd16ae40d2b2e481ca0cbd0c"/><link type="OK" sourceName="com_maj_remboursement/Mail" targetName="com_maj_remboursement/Enseigne" mandatory="1" id="36f1048e95d93eb9c919e660bdd83e7d"/><link type="OK" sourceName="com_maj_remboursement/Enseigne" targetName="com_maj_remboursement/Type_Rbt" mandatory="1" id="4f9a7fd0d86f7e50a5bffaef3c669a4d"/><link type="OK" sourceName="com_maj_remboursement/Type_Rbt" targetName="com_maj_remboursement/Forcé" mandatory="1" linkCondition="%e(rhino){${P_TYPE}$ != 0}e(rhino)%" id="3a191616554239c90b497708c866bb54"/><link type="OK" sourceName="com_maj_remboursement/Type_Rbt" targetName="com_maj_remboursement/Calculé" mandatory="1" linkCondition="%e(rhino){${P_TYPE}$ == 0}e(rhino)%" id="a1b47407df6366243e3994cc9e792023"/><link type="OK" sourceName="com_maj_remboursement/Forcé" targetName="com_maj_remboursement/750 DB W_RBT" mandatory="1" id="e234e43e1a53cf37dc7e30d015b9cead"/><link type="OK" sourceName="com_maj_remboursement/Calculé" target