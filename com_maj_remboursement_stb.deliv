		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="a201aa03b1bf87c97c063cf50f3e84ae" type="Code" actionName="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ECOMM.RET_REGLEMENT_RBT T 
set


 (  T.LIB_RGT,
		T.MONTANT_RGT,
		T.NUM_LIGNE
             
       ) = 
             (
             select S.LIB_RGT,
				S.MONTANT_RGT,
				S.NUM_LIGNE
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_REGLEMENT_RBT").substring(0,26);}e(rhino)% S
             where  S.CODE_RGT=T.CODE_RGT
			 And S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(CODE_RGT, ID_CDE, ID_RBT)
	in	(
		select	CODE_RGT, ID_CDE, ID_RBT
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"RET_REGLEMENT_RBT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_ecommerce(_whYKiKKVEeaVPfQirBdutQ)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="784ff63e71f18ef5711baf818fca2d35" type="Code" actionName="com_maj_remboursement/400 DB RET_REGLEMENT_RBT/I1-RET_REGLEMENT_RBT-Integration/I1-RET_REGLEMENT_RBT-Integration/Insertion of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert  into ECOMM.RET_REGLEMENT_RBT
	(	CODE_RGT,
