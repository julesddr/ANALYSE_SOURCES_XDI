select		ECOMM.SEQ_RBT_CDE.NEXTVAL AS L1_ID,
	RET_RBT.ID_CDE AS L2_ID_CDE,
	RET_RBT.ID_RBT AS L3_ID_RBT

from	ECOMM.RET_RBT  RET_RBT
where	(1=1)
 AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)


