on		ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% (ID_CDE, ID_RBT, SESSION_ID)]]><altId value="_jkWgjlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Creation of a unique Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="314909ef39005222f68c1983dc49e82b" type="Code" actionName="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)%
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
		select	ID_CDE,
			ID_RBT,
			SESSION_ID
		from	ETLWORK.W_RBT
		)]]><altId value="_jkWglFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Flag of rows to update/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="030dd77b39a409ceef1b0d7a20c5c329" type="Code" actionName="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[update	ETLWORK.W_RBT T 
set


 (  T.MNT_RBT_CAL
             
       ) = 
             (
             select S.MNT_RBT_CAL
                           
             from   ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.SESSION_ID=T.SESSION_ID
                     )     


where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
		select	ID_CDE, ID_RBT, SESSION_ID
		from	ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT").substring(0,26);}e(rhino)% I
		where	I.INCREMENTAL_FLAG = 'U'
		)
]]><altId value="_jkWgmlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_NAME" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" value="T1"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" value="NOCOMMIT"/><parameter vName="SQL_ACTION_TYPE_STAT" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" value="UPDATE"/></step><step id="4d341131c5423fac0c30fdcfa6ac5c49" type="Code" actionName="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Commit of transaction on target" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[commit]]><altId value="_jkWgqFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" val