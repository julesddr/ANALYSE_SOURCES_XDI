"/><parameter vName="transactionalModeOnWorkTables" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/transactionalModeOnWorkTables" type="Boolean" value="false" input="false" output="false" fault="false"/><parameter vName="purgeTemporaryTables" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/purgeTemporaryTables" type="Boolean" value="true" input="false" output="false" fault="false"/><parameter vName="transactionName" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/transactionName" type="String" value="T1" input="false" output="false" fault="false"/><parameter vName="filterRejectsOnCheckedTable" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/filterRejectsOnCheckedTable" type="Boolean" value="false" input="false" output="false" fault="false"/><parameter vName="scdDefaultEndDate" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/scdDefaultEndDate" type="String" value="NULL" input="false" output="false" fault="false"/><parameter vName="synchronizeDeletionsFromCDC" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/synchronizeDeletionsFromCDC" type="Boolean" value="false" input="false" output="false" fault="false"/><parameter vName="flagDeletedRows" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/flagDeletedRows" type="Boolean" value="false" input="false" output="false" fault="false"/><parameter vName="lockCdcTable" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/lockCdcTable" type="Boolean" value="true" input="false" output="false" fault="false"/></step><link type="OK" sourceName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare" targetName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration" mandatory="1" id="fce548e2f7f9a5ddfac6d18552f547d3"/></process><process actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare" isBeginProcess="false"><step id="59fed37687c6208e48d2976035647417" type="Code" actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-integration table" nbCycles="-1" toleratedError="true" isBeginAction="true" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[drop table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)% purge]]><altId value="_jkWgMlEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="1996b8a85120331c57b85d94008ac470" type="Code" actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[Create table ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	LIB_REGLEMENT	VARCHAR2(30 BYTE) NULL,
	MODE_REGLEMENT	NUMBER(2,0) NULL,
	MONTANT_ORIGINE	NUMBER(10,2) NULL,
	NUM_LIGNE	NUMBER(3,0) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING]]><altId value="_jkWgOFEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="ebcbb7af9955939d875e9d5080c019f5" type="Code" actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" nbCycles="-1" toleratedError="false" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[insert /*+ APPEND */ into ETLWORK.%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%
(
	ID_CDE,
	ID_RBT,
	LIB_REGLEMENT,
	MODE_REGLEMENT,
	MONTANT_ORIGINE,
	NUM_LIGNE,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT.ID_CDE,
	W_RBT.ID_RBT,
	MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG,
	HISTORIQUE_CAISSES.MOTIFRETOUR,
	sum(HISTORIQUE_CAISSES.CANETREALISE),
	min(HISTORIQUE_CAISSES.NUMLIGNE),
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN (STORELAND.MODES_REGLEMENT_MAGASIN  MODES_REGLEMENT_MAGASIN
		INNER JOIN STORELAND.HISTORIQUE_CAISSES  HISTORIQUE_CAISSES
		ON MODES_REGLEMENT_MAGASIN.CODEMODEREGLEMENTMAG = HISTORIQUE_CAISSES.MOTIFRETOUR)
	ON to_number(substr(W_RBT.ID_CDE,10,5)) = HISTORIQUE_CAISSES.CODEMAGASIN
and to_number(substr(W_RBT.ID_CDE,1,9)) = HISTORIQUE_CAISSES.NUMTICKET
and HISTORIQUE_CAISSES.CODECAISSE = 1 
and HISTORIQUE_CAISSES.TYPELIGNE = 9 
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$')
group by W_RBT.ID_CDE, W_RBT.ID_RBT, MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG, HISTORIQUE_CAISSES.MOTIFRETOUR
minus
select
	ID_CDE,
	ID_RBT,
	LIB_REGLEMENT,
	MODE_REGLEMENT,
	MONTANT_ORIGINE,
	NUM_LIGNE,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId value="_jkWgWVEJEeO7Vo9WeM2sCg" origin="compilation"/><parameter vName="SQL_CONNECTION" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" value="oracle_simms(_OjRi0D-9Eee0IacUVr-S7Q)"/><parameter vName="SQL_ACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" value="DDL_DML"/><parameter vName="SQL_TRANSACTION_TYPE" name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" value="AUTOCOMMIT"/></step><step id="9259133665686f5406185a84473a381d" type="Code" actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" nbCycles="-1" toleratedError="true" isBeginAction="false" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'%e(rhino){("I_"+__ctx__.getVariableValue("/CORE_SESSION_TIMESTAMP")+"W_RBT_PREPA_RGT").substring(0,26);}e(rhino)%'
   
);
