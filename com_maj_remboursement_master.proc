<proc:process xmlns:proc="http://www.example.org/proc" id="_qg5hkBIyEfGcctThXQHQEw" metaInf="&lt;httpRestWebServiceProperties extractRequestInfo=&quot;true&quot;>&#xD;&#xA;    &lt;requestHeaderMapper headerName=&quot;Content-type&quot; parameterName=&quot;Http_header&quot; />&#xD;&#xA;    &lt;responseCodeMapper parameterName=&quot;HttpResponseCode&quot; />&#xD;&#xA;&lt;/httpRestWebServiceProperties>">
