    <bindLink id="_qg5hlRIyEfGcctThXQHQEw" bindType="DirectBind" targetId="_qg5hmxIyEfGcctThXQHQEw"/>
    <metaDataLink id="1d706b25-6a68-445e-be3c-cc97df73e2b2" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <metaDataLink id="59162c16-fc77-4643-8a68-ee9479f46d71" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <metaDataLink id="e565edce-d831-4eb9-b283-9a67a0ce38bd" name="STAGE_SALE_ORIGIN" target="resource.md#_IbfPAPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=STAGE_SALE_ORIGIN?"/>
    <parameter id="_qg5hmRIyEfGcctThXQHQEw" name="SQL_ACTION_TYPE" type="String" value="SELECT"/>
    <parameter id="_qg5hmhIyEfGcctThXQHQEw" name="SQL_CONNECTION" type="String"/>
    <code>select ID_CDE,ID_RBT,DAT_DDE_RBT,ORIGIN_PAYMENT from(&#xD;
select distinct RBT.id_cde, RBT.id_rbt, rbt.dat_dde_rbt,nvl(STAGE_SALE_ORIGIN.ORIGIN_PAYMENT,'-') ORIGIN_PAYMENT&#xD;
from %x{$RET_RBT/tech:physicalPath()}x% RBT , %x{$CDE/tech:physicalPath()}x% CDE, %x{$STAGE_SALE_ORIGIN/tech:physicalPath()}x% STAGE_SALE_ORIGIN&#xD;
where &#xD;
CDE.ID_CDE = RBT.ID_CDE &#xD;
and CDE.ID_TICKET=STAGE_SALE_ORIGIN.ORDER_NO(+)&#xD;
and CDE.ID_ENTITE_ECOMM=STAGE_SALE_ORIGIN.STORE_ID(+)&#xD;
and CDE.ID_ENSEIGNE = ${~/Enseigne}$ &#xD;
and RBT.STATUT = 'DEMREMBVAL'&#xD;
and trunc(cde.dath_integ)&lt;>trunc(sysdate)&#xD;
order by rbt.dat_dde_rbt)&#xD;
where ROWNUM &lt; 400&#xD;
and ORIGIN_PAYMENT&lt;>'PURSE' </code>
  </actionCode>
  <actionCode id="_qg5hmxIyEfGcctThXQHQEw" isBeginAction="false" name="ExecuteDelivery" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.ExecDeliveryActionCodeI">
