Id origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="com_maj_remboursement/395 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target" id="ec907cdde45519f6a0f405d10f793d9b" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ETLWORK.W_RBT T 
set


 (  T.MNT_RBT_CAL
             
       ) = 
             (
             select S.MNT_RBT_CAL
                           
             from   ETLWORK.I_W_RBT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.SESSION_ID=T.SESSION_ID
                     )     


where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
