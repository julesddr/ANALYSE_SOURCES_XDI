set


 (  T.LOG_PAIEMENT,
		T.DATEH,
		T.ERROR_CODE,
		T.ERROR_MESSAGE
             
       ) = 
             (
             select S.LOG_PAIEMENT,
				S.DATEH,
				S.ERROR_CODE,
				S.ERROR_MESSAGE
                           
             from   ETLWORK.I_RET_MAJ_LOG S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.I_RET_MAJ_LOG I
		where	I.INCREMENTAL_FLAG = 'U'
		)

]]><altId origin="compilation" value="_jkWgmlEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="UPDATE"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Update of rows in target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="com_maj_remboursement/810 ws RefundPayment/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of rows in target" id="3a9ebba355fec19f55305725d963fe91" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into ECOMM.RET_MAJ_LOG
	(	ID_CDE,
		ID_RBT,
