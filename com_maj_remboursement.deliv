]]><altId origin="compilation" value="8c55021f-2a6e-4cd8-baf5-8ffb4d614646"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of Index on pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of Index on pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" id="f4fc5ab79540aa6e3ff9f2f9c0629df1" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	LIB_REGLEMENT,
	MONTANT_REMBOURSE,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT.ID_CDE,
	W_RBT.ID_RBT,
	HISTORIQUE_CAISSES.MOTIFRETOUR,
	MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG,
	coalesce(sum(HISTORIQUE_CAISSES.CANETREALISE)*-1,0),
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN (STORELAND.MODES_REGLEMENT_MAGASIN  MODES_REGLEMENT_MAGASIN
		INNER JOIN STORELAND.HISTORIQUE_CAISSES  HISTORIQUE_CAISSES
		ON MODES_REGLEMENT_MAGASIN.CODEMODEREGLEMENTMAG = HISTORIQUE_CAISSES.MOTIFRETOUR)
	ON to_number(substr(W_RBT.ID_CDE,10,5)) = HISTORIQUE_CAISSES.CODEMAGASIN
and to_number(substr(W_RBT.ID_CDE,1,9)) = HISTORIQUE_CAISSES.NUMTICKETORIGINE
and HISTORIQUE_CAISSES.CODECAISSE = 2 
and HISTORIQUE_CAISSES.TYPELIGNE = 9 
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$')
group by W_RBT.ID_CDE, W_RBT.ID_RBT, HISTORIQUE_CAISSES.MOTIFRETOUR, MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG, 'I'
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	LIB_REGLEMENT,
	MONTANT_REMBOURSE,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table" id="ff1b26bf88aedaee167611d06fe7e007" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	MODE_REGLEMENT	NUMBER(2,0) NULL,
	LIB_REGLEMENT	VARCHAR2(30 BYTE) NULL,
	MONTANT_REMBOURSE	NUMBER(10,2) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
]]><altId origin="compilation" value="_jkWgOFEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="5a8edccf95ec4479b6c656da768f2a44" mandatory="1" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of Index on pre-integration table" targetName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" type="OK"/><link id="81491f21929fe7b909da87406f611866" mandatory="1" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" targetName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Creation of Index on pre-integration table" type="OK"/><link id="9829371194f1f32e8f2f014ddaa5cf5a" mandatory="1" sourceName="com_maj_remboursement/340 DB Prepa RET_REGLEMENT_RBT(montant remboursé)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Drop of pre-int