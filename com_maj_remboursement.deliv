set


 (  T.LOG_PAIEMENT,
		T.DATEH
             
       ) = 
             (
             select S.LOG_PAIEMENT,
				S.DATEH
                           
             from   ETLWORK.I_RET_MAJ_LOG S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.I_RET_MAJ_LOG I
		where	I.INCREMENTAL_FLAG = 'U'
