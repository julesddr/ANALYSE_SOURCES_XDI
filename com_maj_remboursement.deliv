n/I2-RET_MAJ_LOG_PB-Integration/Commit of transaction on target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Start" id="5921f6bf03c5c2b02f2a6a10de3f4d85" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Drop of pre-integration table" id="d5660ae005d8868ba66fc356393bc128" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_MAJ_LOG purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append" id="f5f5e68a5cee3d0b55815d6189d7418e" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	DATEH,
	ERROR_CODE,
	ERROR_MESSAGE
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_PAIEMENT,
		SRC.DATEH,
		SRC.ERROR_CODE,
		SRC.ERROR_MESSAGE
from (
		select 
			'${~/p_id_cde}$'  AS ID_CDE,
		${~/p_id_rbt}$  AS ID_RBT,
		'KO-'||L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L13_errorMessage AS LOG_PAIEMENT,
		sysdate AS DATEH,
		L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L10_ERROR_CODE AS ERROR_CODE,
		L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L11_ERROR_MESSAGE AS ERROR_MESSAGE
		from	(
select L10_ERROR_CODE,
	L11_ERROR_MESSAGE,
	L12_errorCode,
	L13_errorMessage,
	L14_status
from (((((ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
						LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
						ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
					ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_3  L1_RET_MAJ_LOG_3
				ON L1_RET_MAJ_LOG_2.stb_key=L1_RET_MAJ_LOG_3.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_4  L1_RET_MAJ_LOG_4
			ON L1_RET_MAJ_LOG_3.stb_key=L1_RET_MAJ_LOG_4.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_5  L1_RET_MAJ_LOG_5
		ON L1_RET_MAJ_LOG_4.stb_key=L1_RET_MAJ_LOG_5.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_6  L1_RET_MAJ_LOG_6
	ON L1_RET_MAJ_LOG_5.stb_key=L1_RET_MAJ_LOG_6.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_6.stb_key is null))  L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN
		where	(1=1) AND (L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L14_status <> 'SUCCESS' OR L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L12_errorCode IS NOT NULL)
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><link id="047cb5ac9e089a2862d7c20c1ba8ae6b" mandatory="1" sourceName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Insertion of new rows in target - append" targetName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Commit of transaction on target" type="OK"/><link id="d415c9fe4dbaa725ce43b22894648040" mandatory="1" sourceName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Commit of transaction on target" targetName="com_maj_remboursement/800 ws FindPayment/I2-RET_MAJ_LOG_PB-Integration/I2-RET_MAJ_LOG_PB-Integration/Drop of pre-integration table