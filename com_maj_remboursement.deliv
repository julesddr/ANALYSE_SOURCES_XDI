<sourceSet name="L1_GetOrder" distinct="true"><field isKey="true" id="_c_MphhI4EfGpb7QiJEquyg" alias="L1_GetOrder" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.ID_CDE<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_c_MpiBI4EfGpb7QiJEquyg" alias="L2_Input" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_c_MpiRI4EfGpb7QiJEquyg" alias="L3_content" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="true" id="_c_MpjBI4EfGpb7QiJEquyg" alias="L4_result" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_c_MpjRI4EfGpb7QiJEquyg" alias="L5_orderId" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">to_char(to_number(substr(RET_RBT.ID_CDE,1,9)))<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_c_MpjxI4EfGpb7QiJEquyg" alias="L6_operationType" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">'DEBIT'</field><field isKey="false" id="_c_MpkRI4EfGpb7QiJEquyg" alias="L7_Authorization" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CASE WHEN RET_REGLEMENT_RBT.CODE_RGT is null THEN 'Basic ${~/Authorization}$' ELSE 'Basic ${~/AuthorizationAlma}$' END<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><query><from>ECOMM.RET_RBT  RET_RBT
	LEFT OUTER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
	ON RET_REGLEMENT_RBT.ID_CDE = RET_RBT.ID_CDE
and RET_REGLEMENT_RBT.ID_RBT = RET_RBT.ID_RBT
and RET_REGLEMENT_RBT.CODE_RGT = 41</from><where> AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)</where></query></sourceSet>
