AS

select		ECOMM.SEQ_RBT_CDE.NEXTVAL AS L1_ID,
	RET_RBT.ID_CDE AS L2_ID_CDE,
	RET_RBT.ID_RBT AS L3_ID_RBT

from	ECOMM.RET_RBT  RET_RBT
where	(1=1)
 AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)


]]><altId origin="compilation" value="_rdD5NTRMEeSQ37GXUClEnA"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging" id="58b0a462a6ecdec5dceba0c61ffcff63" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop view WI_WORK.S1_1g9f506o5he26_stage]]><altId origin="compilation" value="_w4gOMDRMEeSQ37GXUClEnA"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="7a86f123161c349b35c189ea43ae513f" mandatory="1" sourceName="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging" targetName="com_maj_remboursement/850 ws StorelandTicketRetour/S1-stage-Staging/Drop table stagging" type="OK"/><link id="9707f34fe7e40bd2d07e6db202550abe" mandatory="1" sourceName="com_maj_remboursement/850 ws S