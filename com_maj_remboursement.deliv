T_RBT(montant à rembourser CB)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="com_maj_remboursement/350 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Integration/Update of rows in target" id="ff76ab930b451ff05b7686e50c32d934" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ETLWORK.W_RBT_PREPA_RGT T 
set


 (  T.MONTANT_AREMBOURSER
             
       ) = 
             (
             select S.MONTANT_AREMBOURSER
                           
             from   ETLWORK.I_W_RBT_PREPA_RGT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.MODE_REGLEMENT=T.MODE_REGLEMENT
                     )     


where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE, ID_RBT, MODE_REGLEMENT
		from	ETLWORK.I_W_RBT_PREPA_RGT I
