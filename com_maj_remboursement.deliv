ment/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Commit of transaction on target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Integration/Update of rows in target" id="e40334ef654c49a96aa7e0ff45bccb63" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ETLWORK.W_RBT_PREPA_RGT T 
set


 (  T.LIB_REGLEMENT,
		T.NUM_LIGNE
             ,T.SESSION_ID
       ) = 
             (
             select S.LIB_REGLEMENT,
				S.NUM_LIGNE
                           ,'${/CORE_SESSION_ID}$'
             from   ETLWORK.I_W_RBT_PREPA_RGT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.MODE_REGLEMENT=T.MODE_REGLEMENT
                     )     


where	(ID_CDE, ID_RBT, MODE_REGLEMENT)
	in	(
		select	ID_CDE, ID_RBT, MODE_REGLEMENT
		from	ETLWORK.I_W_RBT_PREPA_RGT I
		where	I.INCREMENTAL_FLAG = 'U'
		)

