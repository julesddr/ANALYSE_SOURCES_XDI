onName="com_maj_remboursement/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" id="9c3da0f5a51e5527a7be7a360e40f2a2" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[BEGIN 
