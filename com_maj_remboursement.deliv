(
	ID_CDE,
	ID_RBT,
	UUID,
	MONTANT,
	INCREMENTAL_FLAG
)
select		  
			'${~/p_id_cde}$' AS ID_CDE,
			${~/p_id_rbt}$  AS ID_RBT,
			L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L8_UUID AS UUID,
			L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN.L9_MONTANT AS MONTANT,
			'I' INCREMENTAL_FLAG
from	(
select L8_UUID,
	L9_MONTANT
from ((((((ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
							LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
							ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
						LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
						ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_3  L1_RET_MAJ_LOG_3
					ON L1_RET_MAJ_LOG_2.stb_key=L1_RET_MAJ_LOG_3.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_4  L1_RET_MAJ_LOG_4
				ON L1_RET_MAJ_LOG_3.stb_key=L1_RET_MAJ_LOG_4.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_5  L1_RET_MAJ_LOG_5
			ON L1_RET_MAJ_LOG_4.stb_key=L1_RET_MAJ_LOG_5.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_6  L1_RET_MAJ_LOG_6
		ON L1_RET_MAJ_LOG_5.stb_key=L1_RET_MAJ_LOG_6.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_7  L1_RET_MAJ_LOG_7
	ON L1_RET_MAJ_LOG_6.stb_key=L1_RET_MAJ_LOG_7.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_7.stb_key is null))  L1_RET_MAJ_LOG_PB_W_RBT_PAYZEN
where	(1=1) 
]]><altId origin="compilation" value="_jkWgflEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Insertion of preintegration data - APPEND/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Insertion of preintegration data - APPEND/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Insertion of preintegration data - APPEND/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Creation of pre- integration table" id="b0db643c96d31495d35ead83f13bd837" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_W_RBT_PAYZEN
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	VARCHAR2(2 BYTE) NULL,
	UUID	VARCHAR2(50 BYTE) NULL,
	MONTANT	NUMBER(15,0) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
]]><altId origin="compilation" value="_jkWgOFEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/800 ws FindPayment/I3-W_RBT_PAYZEN-Integration/I3-W_RBT_PAYZEN-Prepare/Creation of Index on pre-integration table" id="dc674740fffd2e3008046f9dbf26b2fd" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[create index ETLWORK.I_W_RBT_PAYZEN_IDX
