ing" vName="WRITE_XML_DECLARATION" value="true"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I1-CancelOrRefund-Integration/Call WebServices/XML_VERSION" type="String" vName="XML_VERSION" value="1.0"/></step><step actionName="com_maj_remboursement/810 ws RefundPayment/I1-CancelOrRefund-Integration/SqlToXml" id="a2b8695e8607eeaba316c9f030309b4b" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcToXmlActionCodeI" toleratedError="false" type="Code"><![CDATA[<sqlToXml:descriptor xmlns:sqlToXml="http://www.stambia.com/sqlToXml">
<sourceSet name="L1_CancelOrRefund" distinct="true"><field isKey="true" id="_c_N2mRI4EfGpb7QiJEquyg" alias="L1_CancelOrRefund" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">W_RBT_PAYZEN.ID_CDE<from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN</from></field><field isKey="false" id="_c_N2nBI4EfGpb7QiJEquyg" alias="L2_Authorization" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CASE WHEN RET_REGLEMENT_RBT.CODE_RGT &lt;> 41  THEN 'Basic ${~/Authorization}$' ELSE 'Basic ${~/AuthorizationAlma}$' END<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="true" id="_c_N2ohI4EfGpb7QiJEquyg" alias="L3_result" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_c_N2oxI4EfGpb7QiJEquyg" alias="L4_uuid" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">W_RBT_PAYZEN.UUID<from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN</from></field><field isKey="false" id="_c_N2pRI4EfGpb7QiJEquyg" alias="L5_currency" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">'EUR'</field><field isKey="false" id="_c_N2pxI4EfGpb7QiJEquyg" alias="L6_amount" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_REGLEMENT_RBT.MONTANT_RGT*100<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><query><from>ETLWORK.W_RBT_PAYZEN  W_RBT_PAYZEN
	INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
	ON W_RBT_PAYZEN.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and W_RBT_PAYZEN.ID_RBT = RET_REGLEMENT_RBT.ID_RBT</from><where> AND (RET_REGLEMENT_RBT.CODE_RGT IN (3, 26, 24, 25, 33, 41)) AND (W_RBT_PAYZEN.ID_CDE = '${~/p_id_cde}$' AND W_RBT_PAYZEN.ID_RBT = ${~/p_id_rbt}$ AND W_RBT_PAYZEN.TYPE_PMT = 'DEBIT' AND W_RBT_PAYZEN.MODE_PMT IN ('CB', 'PAYPAL', 'CARD'))</where></query></sourceSet>
