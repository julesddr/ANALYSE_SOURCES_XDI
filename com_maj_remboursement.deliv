B W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration" type="OK"/></process><process actionName="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration" isBeginProcess="false"><step actionName="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append" id="8a273a0f38bfb60f3c38f183b013068d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ETLWORK.W_RBT
( 
	SESSION_ID,
	ID_CDE,
	ID_RBT,
	MNT_RBT
) 
select	  
		'${/CORE_SESSION_ID}$' AS SESSION_ID,
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.MNT_RBT
from (
		select 
			S1_stage.L8_ID_CDE AS ID_CDE,
		S1_stage.L6_ID_RBT AS ID_RBT,
		sum(S1_stage.L7_MNT_RBT) AS MNT_RBT
		from	ETLWORK.S1_1g6sztwnvayj5_stage  S1_stage
		where	(1=1)
group by S1_stage.L8_ID_CDE, S1_stage.L6_ID_RBT
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Drop of pre-integration table" id="b00fbe372ddd1fe375fa66b2e8959933" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_W_RBT purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/750 DB W_RBT/I1-W_RBT-Integration/I1-W_RBT-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/>