   OWNNAME=>'ETLWORK',
   TABNAME=>'I_W_RBT_PREPA_RGT'
   
);
end;]]><altId origin="compilation" value="_c1jhsGoOEea9fIQJ0nVgng"/><parameter name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)/I1-W_RBT_PREPA_RGT-Integration/I1-W_RBT_PREPA_RGT-Prepare/Insertion of pre-integration data - MINUS" id="ebcbb7af9955939d875e9d5080c019f5" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	LIB_REGLEMENT,
	MONTANT_ORIGINE,
	NUM_LIGNE,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT.ID_CDE,
	W_RBT.ID_RBT,
	HISTORIQUE_CAISSES.MOTIFRETOUR,
	MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG,
	sum(HISTORIQUE_CAISSES.CANETREALISE),
	min(HISTORIQUE_CAISSES.NUMLIGNE),
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN (STORELAND.MODES_REGLEMENT_MAGASIN  MODES_REGLEMENT_MAGASIN
		INNER JOIN STORELAND.HISTORIQUE_CAISSES  HISTORIQUE_CAISSES
		ON MODES_REGLEMENT_MAGASIN.CODEMODEREGLEMENTMAG = HISTORIQUE_CAISSES.MOTIFRETOUR)
	ON to_number(substr(W_RBT.ID_CDE,10,5)) = HISTORIQUE_CAISSES.CODEMAGASIN
and to_number(substr(W_RBT.ID_CDE,1,9)) = HISTORIQUE_CAISSES.NUMTICKET
and HISTORIQUE_CAISSES.CODECAISSE = 1 
and HISTORIQUE_CAISSES.TYPELIGNE = 9 
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$')
group by W_RBT.ID_CDE, W_RBT.ID_RBT, HISTORIQUE_CAISSES.MOTIFRETOUR, MODES_REGLEMENT_MAGASIN.LIBMODEREGLEMENTMAG, 'I'
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	LIB_REGLEMENT,
	MONTANT_ORIGINE,
	NUM_LIGNE,
	'I' INCREMENTAL_FLAG	
