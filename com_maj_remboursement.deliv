rameter name="com_maj_remboursement/SendMontantForceKO/MAIL_TO" type="String" vName="MAIL_TO" value="${~/MAIL}$"/><parameter name="com_maj_remboursement/SendMontantForceKO/MAIL_USE_SSL" type="STRING" vName="MAIL_USE_SSL" value="false"/></step><step actionName="com_maj_remboursement/Remboursement_payzen_effectué" id="8a05faf32a694aece063677724af29ad" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_PMTBOK" type="Integer">
select 
case when LOG_PAIEMENT like 'OK%'
then 1
else 0 end
from ECOMM.RET_MAJ_LOG 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
</sqlToParameters>
]]><altId origin="compilation" value="_oU2K8xJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Remboursement_payzen_effectué/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Remboursement_payzen_effectué/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Purge_W" id="8c702b9734c0ee1193486c6b3d889837" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[delete from w_rbt where session_id = '${/CORE_SESSION_ID}$' ; 
