(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.MODE_REGLEMENT,
	case when coalesce(W_RBT.MNT_RBT_CAL,0) < coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
then coalesce(W_RBT.MNT_RBT_CAL,0)
else coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
end ,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	INNER JOIN ETLWORK.W_RBT  W_RBT
	ON W_RBT_PREPA_RGT.ID_CDE = W_RBT.ID_CDE
and W_RBT_PREPA_RGT.ID_RBT = W_RBT.ID_RBT
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$' AND W_RBT.MNT_RBT_CAL > 0) AND (W_RBT_PREPA_RGT.MODE_REGLEMENT = 41)
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Drop of pre-integration table" id="13f8452adc1a890eb93de40c6c6237c2" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_W_RBT_PREPA_RGT purge]]><altId origin="compilation" value="_jkWgMlEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/391 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="c