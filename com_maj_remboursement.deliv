elandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Start" id="6e7704438b30b750dfed4565b5c8aa4d" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="com_maj_remboursement/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target" id="c3a8e0818b087b7403bb2f59fa338c22" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ECOMM.RET_MAJ_LOG T 
set


 (  T.LOG_TICKET,
		T.DATEH
             
       ) = 
             (
             select S.LOG_TICKET,
				S.DATEH
                           
             from   ETLWORK.I_RET_MAJ_LOG S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


