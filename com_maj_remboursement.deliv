<parameter name="../P_MONTANTKDO" type="Integer">
select sum(MONTANT_RGT)
from ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' 
and id_rbt = ${~/p_id_rbt}$ 
and CODE_RGT in (21,27,28)
</parameter>
<parameter name="../P_NUMCLIENT" type="String">
select ID_CLIENT
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LAxJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Donnees_KDO/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Donnees_KDO/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/890 DB Coupon" id="cb0f08336b4a4e6b6b6d3a993d5b1e89" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LphJgEfGpb7QiJEquyg"/><altId origin="flow" value="_J6Q7QHOmEei1MdTkUZz1Xg-flow"/><altId origin="mapping" value="_J6Q7QHOmEei1MdTkUZz1Xg"/><altId origin="processRef" value="_J6Q7QHOmEei1MdTkUZz1Xg-proc"/></step><step actionName="com_maj_remboursement/MailStorelandKO" id="cc6943fd27f5480480055c0152c72ef5" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2LXhJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_FROM" type="String" vName="MAIL_FROM" value="stambia@happychicgroup.com"/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_HOSTNAME" type="STRING" vName="MAIL_HOSTNAME" value="baffin"/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_PORT" type="STRING" vName="MAIL_PORT" value="25"/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_SUBJECT" type="String" vName="MAIL_SUBJECT" value="Maj remboursement - Erreur WS Payzen "/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_TEXT" type="String" vName="MAIL_TEXT" value="Bonjour, &#xA;&#xA;Erreur dans le retour du WS Storeland pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xA;&#xA;&#xA;Cordialement,&#xA;Informatique Commerce "/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_TO" type="String" vName="MAIL_TO" value="${~/mail_info}$"/><parameter name="com_maj_remboursement/MailStorelandKO/MAIL_USE_SSL" type="STRING" vName="MAIL_USE_SSL" value="false"/></step><step actionName="com_maj_remboursement/395 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement 2 )" id="ce3423d6aaf2721de83cd80e2e30c5d4" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LwhJgEfGpb7QiJEquyg"/><altId origin="flow" value="_5UE28HRnEeiP1OY0c7ac_A-flow"/><altId origin="mapping" value="_5UE28HRnEeiP1OY0c7ac_A"/><altId origin="processRef" value="_5UE28HRnEeiP1OY0c7ac_A-proc"/></step><step actionName="com_maj_remboursement/365 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal 2)" id="d19b12b0e13af0bd60827e61860d4810" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LvBJgEfGpb7QiJEquyg"/><altId origin="flow" value="_GpVdUHRnEeiP1OY0c7ac_A-flow"/><altId origin="mapping" value="_GpVdUHRnEeiP1OY0c7ac_A"/><altId origin="processRef" value="_GpVdUHRnEeiP1OY0c7ac_A-proc"/></step><step actionName="com_maj_remboursement/Mail" id="da459cb3a53465cae86e3e9e1c3f2ad6" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../MAIL" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'e-shopping@Jules.fr' 
when '01601' then 'e-shopping@Jules.fr'
when '02600' then 'contact-clients@bizzbee.fr'
when '03600' then 'serviceclientsbrice@brice.fr' 
when '03651' then 'serviceclientsbrice@brice.fr'
else 'e-shopping@Jules.fr'
end
from dual 
</parameter>
<parameter name="../Authorization" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw==' 
when '01601' then 'MTExMDkzOTQ6cHJvZHBhc3N3b3JkX0dTNVV4VmpGdVBIVDRaMXhQRWlWN21RZUZ6eWhJZGtDZ0RmbXpJQUlYMGc0Rg=='
when '02600' then 'OTI0NTI2NjI6cHJvZHBhc3N3b3JkX3BIdU1JSTI4VHJFanNyOHFMejJNSnZYR0ZhQ3l1VXRVRnQyeldQQThtd2RPSA=='
else 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw=='
end
from dual 
</parameter>
<parameter name="../AuthorizationAlma" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'OTIzMjIxODI6cHJvZHBhc3N3b3JkX2U4cFgyNmM5S25iNTMwNG1ONzJSdkJOUVM5TzNkanB5RGNJSnRvQ1NYNGVHbA==' 
when '02600' then 'NzkwMDg1MjI6cHJvZHBhc3N3b3JkX0Q5V1NlVDFVZVowanpyam9Uak5FTkNhbkhHRUdiS1VzdkFtRVZuVHVmaGNNZA=='
end
from dual 
</parameter>

</sqlToParameters>]]><altId origin="compilation" value="_oU2LOBJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Mail/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Mail/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)" id="db08332c254b1e37405f4816e258fe26" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LshJgEfGpb7QiJEquyg"/><altId origin="flow" value="_-0oWmTDpEeiylpRw1KCMvQ-flow"/><altId origin="mapping" value="_-0oWmTDpEeiylpRw1KCMvQ"/><altId origin="processRef" value="_-0oWmTDpEeiylpRw1KCMvQ-proc"/></step><step actionName="com_maj_remboursement/Montant_Possible" id="e0895cf0814d532e0c71fed17852d89c" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_MONTANT_OK" type="String">
select sum(coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0)) - sum(coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0))
from  ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
where W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$'
group by W_RBT_PREPA_RGT.SESSION_ID 
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LKRJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Montant_Possible/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/Montant_Possible/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ETLWORK"/></step><step actionName="com_maj_remboursement/Mail_client" id="e14b0577c440dd0fa24513901e376734" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2K2BJgEfGpb7QiJEquyg"/></step><step actionName="com_maj_remboursement/870 DB RET_RBT(Fid)" id="e34d68bbdba3aa1088b61a610cc4ce50" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LohJgEfGpb7QiJEquyg"/><altId origin="flow" value="_rz-f8BJnEfGpb7QiJEquyg-flow"/><altId origin="mapping" value="_rz-f8BJnEfGpb7QiJEquyg"/><altId origin="processRef" value="_rz-f8BJnEfGpb7QiJEquyg-proc"/></step><step actionName="com_maj_remboursement/RAZ_Montant_Force" id="ea9e8db362e2590554723edc232b8659" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.RET_LIGNE_RBT
set MONTANT_RBT_FORCE = null 
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;
update ECOMM.RET_RBT
set STATUT = 'DEMREMBCAL' 
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;]]><altId origin="compilation" value="_oU2LGxJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/RAZ_Montant_Force/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/RAZ_Montant_Force/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/RAZ_Montant_Force/SQL_MULTI_QUERYS" type="Boolean" vName="SQL_MULTI_QUERYS" value="true"/><parameter name="com_maj_remboursement/RAZ_Montant_Force/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Cde_Du_jour" id="eff3344a4b9d080209bc7ad4f78976c4" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_RAF" type="String">
select 
case when trunc(dath_cde) = trunc(sysdate) 
then 0 
else 1 end
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LPBJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Cde_Du_jour/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Cde_Du_jour/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Type_Rbt" id="f0df6a5ca95373232f16bbb01ac8d33d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_TYPE" type="Integer">
select COALESCE(count(1),0)
from ECOMM.RET_LIGNE_RBT 
where id_cde = '${~/p_id_cde}$' 
and id_rbt = ${~/p_id_rbt}$ 
and montant_rbt_force is not null 
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU1jyhJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Type_Rbt/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Type_Rbt/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Forcé" id="f393d36b009e3371010a3dc3819a2cb5" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2K0BJgEfGpb7QiJEquyg"/></step><step actionName="com_maj_remboursement/Carte_KDO?" id="fd5729d35f00ae0669ea560b4619df0b" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2K-BJgEfGpb7QiJEquyg"/></step><step actionName="com_maj_remboursement/RefundPayzen" id="fe87bcf9d4cf0418875d87effda94523" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2K6xJgEfGpb7QiJEquyg"/></step><link id="010d3e0caf0f1d5d2d547da3332214d0" linkCondition="%e(rhino){${P_PMTBOK}$ == 1}e(rhino)%" mandatory="0" sourceName="com_maj_remboursement/Remboursement_payzen_effectué" targetName="com_maj_remboursement/Carte_KDO?" type="OK"/><link id="01b974a681ee3d5bdf009d4a90f456f2" linkCondition="%e(rhino){${P_PAYZEN}$ == 0}e(rhino)%" mandatory="0" sourceName="com_maj_remboursement/Remboursement_CB_Paypal ?" targetName="com_maj_remboursement/Carte_KDO?" type="OK"/><link id="04a703a82a91777d3e3ed6633b48db7e" linkCondition="%e(rhino){${P_PMTOK}$ != 0}e(rhino)%" mandatory="1" sourceName="com_maj_remboursement/Paiement_trouvé" targetName="com_maj_remboursement/SqlOperation" type="OK"/><link id="0a4c31d49f4c488a8a