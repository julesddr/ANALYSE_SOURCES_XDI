YN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS" id="ab1deb42a874282c58b6b2cae08df7d0" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.MODE_REGLEMENT,
	case when coalesce(W_RBT.MNT_RBT_CAL,0) < coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
then coalesce(W_RBT.MNT_RBT_CAL,0)
else coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
end ,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	INNER JOIN ETLWORK.W_RBT  W_RBT
	ON W_RBT_PREPA_RGT.ID_CDE = W_RBT.ID_CDE
and W_RBT_PREPA_RGT.ID_RBT = W_RBT.ID_RBT
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
where	(1=1)  AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$' AND W_RBT.MNT_RBT_CAL > 0) AND (W_RBT_PREPA_RGT.MODE_REGLEMENT = 49)
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT_PREPA_RGT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/390 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Virement )/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of pre- integration table" id="eadb5e1e9d50da8b4ef8a93be19633c7" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	MODE_REGLEMENT	NUMBER(2,0) NULL,
	MONTANT_AREMBOURSER	NUMBER(10,2) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
