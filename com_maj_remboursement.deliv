" toleratedError="true" type="Code"><![CDATA[create index ETLWORK.I_W_RBT_PREPA_RGT_IDX
on		ETLWORK.I_W_RBT_PREPA_RGT (ID_CDE, ID_RBT, MODE_REGLEMENT)

]]><altId origin="compilation" value="8c55021f-2a6e-4cd8-baf5-8ffb4d614646"/><parameter name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of Index on pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of Index on pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Creation of Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/370 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Kdo)/I1-W_RBT_PREPA_RGT_2-Integration/I1-W_RBT_PREPA_RGT_2-Prepare/Insertion of pre-integration data - MINUS" id="c033a0b32cdec3338dabe81000c7fefd" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT_PREPA_RGT
(
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.MODE_REGLEMENT,
	case when coalesce(W_RBT.MNT_RBT_CAL,0) < coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
then coalesce(W_RBT.MNT_RBT_CAL,0)
else coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0) - coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0)
end ,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	INNER JOIN ETLWORK.W_RBT  W_RBT
	ON W_RBT_PREPA_RGT.ID_CDE = W_RBT.ID_CDE
and W_RBT_PREPA_RGT.ID_RBT = W_RBT.ID_RBT
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
where	(1=1)  AND (W_RBT_PREPA_RGT.MODE_REGLEMENT = 27) AND (W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$' AND W_RBT.MNT_RBT_CAL > 0)
minus
select
	ID_CDE,
	ID_RBT,
	MODE_REGLEMENT,
	MONTANT_AREMBOURSER,
