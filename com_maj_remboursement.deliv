><connection name="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)" type="RDBMS"><parameter name="JDBC.BIND.MANAGE_GET_DATE_AS_TIMESTAMP" type="Boolean" value="true"/><parameter name="JDBC.CONNECTION_POOL_ENABLED" type="String" value="false"/><parameter name="JDBC.DRIVER" type="String" value="oracle.jdbc.OracleDriver"/><parameter name="JDBC.MODULE" type="String" value="Oracle"/><parameter name="JDBC.PASSWORD" type="String" value="463AF908A0C710ED3ACAF3CD075321F448BA3107C45C5AF0B268701E4CBEC278"/><parameter name="JDBC.URL" type="String" value="jdbc:oracle:thin:@maia:1521:simms"/><parameter name="JDBC.USER" type="String" value="etlwork"/><parameter name="TECH.DATE_MASK" type="String" value="DATE"/><parameter name="TECH.DATE_TYPE" type="String" value="DATE"/><parameter name="TECH.NUMERIC_MASK" type="String" value="NUMBER([size],[precision])"/><parameter name="TECH.NUMERIC_MAX_SIZE" type="String" value="38"/><parameter name="TECH.NUMERIC_TYPE" type="String" value="NUMBER"/><parameter name="TECH.OBJECT_END_DELIMITER" type="String" value="&#34;"/><parameter name="TECH.OBJECT_START_DELIMITER" type="String" value="&#34;"/><parameter name="TECH.VARCHAR_MASK" type="String" value="VARCHAR2([size] CHAR)"/><parameter name="TECH.VARCHAR_MAX_SIZE" type="String" value="4000"/><parameter name="TECH.VARCHAR_TYPE" type="String" value="VARCHAR2"/><transaction name="T1"/></connection><parameter name="com_maj_remboursement/mail_info" type="String" vName="mail_info" value="Informatique_Support_Front@jules.com"/><parameter input="true" name="com_maj_remboursement/p_id_cde" type="String" vName="p_id_cde" value=""/><parameter input="true" name="com_maj_remboursement/p_id_rbt" type="Integer" vName="p_id_rbt" value="1"/><altId origin="compilation" value="_oU1jwBJgEfGpb7QiJEquyg"/><process actionName="com_maj_remboursement" isBeginProcess="true"><step actionName="com_maj_remboursement/Recup param" id="045a6c1809f46a28906be0b3ddb5af17" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_PAIEMENT" type="Integer">
select paiement
from ECOMM.RET_PARAM_MAJRBT 
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) 
</parameter>
<parameter name="../P_MAIL" type="Integer">
select MAIL_CLIENT
from ECOMM.RET_PARAM_MAJRBT 
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) 
</parameter>
<parameter name="../P_ENTITE" type="Integer">
select to_number(substr('${~/p_id_cde}$',10,5)) from dual  
</parameter>
<parameter name="../P_PAYZEN" type="Integer">
select count(*)
from  ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$
and code_rgt in (3,26,24,25,33,41)
</parameter>
<parameter name="../P_KDO" type="Integer">
select count(*)
from  ECOMM.RET_REGLEMENT_RBT 
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$
and code_rgt in (21,27,28)
</parameter>
</sqlToParameters>
]]><altId origin="compilation" value="_oU2K1BJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Recup param/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Recup param/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/IS_MKP" id="0475f689f47882ffb7306a7925dffff0" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_MKP" type="Integer">
select count(1)
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
and id_cde_ext is not null
</parameter>
</sqlToParameters>
]]><altId origin="compilation" value="_oU2LjhJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/IS_MKP/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/IS_MKP/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/360 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Paypal)" id="0f88c4fefa04cb6ed62ec529e0d076ea" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LsBJgEfGpb7QiJEquyg"/><altId origin="flow" value="_LxCYEDDpEeiylpRw1KCMvQ-flow"/><altId origin="mapping" value="_LxCYEDDpEeiylpRw1KCMvQ"/><altId origin="processRef" value="_LxCYEDDpEeiylpRw1KCMvQ-proc"/></step><step actionName="com_maj_remboursement/810 ws RefundPayment" id="1db008a9cc0da2a555f2058532fb5df9" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LnBJgEfGpb7QiJEquyg"/><altId origin="flow" value="_gTN54BJkEfGpb7QiJEquyg-flow"/><altId origin="mapping" value="_gTN54BJkEfGpb7QiJEquyg"/><altId origin="processRef" value="_gTN54BJkEfGpb7QiJEquyg-proc"/></step><step actionName="com_maj_remboursement/350 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB)" id="204b0edd52c5693f61c7371f350cff3d" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LrhJgEfGpb7QiJEquyg"/><altId origin="flow" value="_ANrdUy3uEeizKekQ_YH6NA-flow"/><altId origin="mapping" value="_ANrdUy3uEeizKekQ_YH6NA"/><altId origin="processRef" value="_ANrdUy3uEeizKekQ_YH6NA-proc"/></step><step actionName="com_maj_remboursement/355 DB Prepa RET_REGLEMENT_RBT(montant à rembourser CB 2)" id="20566368ba4402e77b0b507ff20b3d88" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LuhJgEfGpb7QiJEquyg"/><altId origin="flow" value="_QN12QHRjEeiP1OY0c7ac_A-flow"/><altId origin="mapping" value="_QN12QHRjEeiP1OY0c7ac_A"/><altId origin="processRef" value="_QN12QHRjEeiP1OY0c7ac_A-proc"/></step><step actionName="com_maj_remboursement/DetailTrouvé" id="21145f6f07bf307fa068daef4537c02a" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_DETAIL" type="Integer">
select count(*) 
from ETLWORK.W_RBT_PAYZEN DET
where DET.id_cde = '${~/p_id_cde}$'
and DET.id_rbt = ${~/p_id_rbt}$
and DET.type_pmt = 'DEBIT'
and DET.mode_pmt in ('CB','PAYPAL','CARD','ALMA')
</parameter>
</sqlToParameters>
]]><altId origin="compilation" value="_oU2LgxJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/DetailTrouvé/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/DetailTrouvé/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ETLWORK"/></step><step actionName="com_maj_remboursement/Start" id="25004a9f49fce58e1704aebd2dc8acf9" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU1jyBJgEfGpb7QiJEquyg"/></step><step actionName="com_maj_remboursement/Sql To Parameters" id="367b747ebf532f17ba8468cff363a605" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_NOMCLIENT" type="String">
select nvl(NOM||' - '||PRENOM,'-')
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$' 
</parameter>
<parameter name="../P_MAILCLIENT" type="String">
select nvl(EMAIL,'-')
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$'
</parameter>
<parameter name="../P_ADRCLIENT" type="String">
select nvl(COMPLEMENTADRESSE||' - '||LIBELLEVOIE||' - '||CODEPOSTAL||' - '||VILLE||' - '||CODEPAYS,'-')
from STORELAND.ADRESSES_CLIENT 
where CODEADRESSECLIENT = (select CODEADRESSECLIENT
from STORELAND.CLIENTS 
where CODECLIENT = '${~/P_NUMCLIENT}$')
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LCBJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Sql To Parameters/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/Sql To Parameters/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="STORELAND"/></step><step actionName="com_maj_remboursement/MailPayzen1KO" id="372b3a46692593e74433424df44a6e01" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2LTBJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_FROM" type="String" vName="MAIL_FROM" value="stambia@happychicgroup.com"/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_HOSTNAME" type="STRING" vName="MAIL_HOSTNAME" value="baffin"/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_PORT" type="STRING" vName="MAIL_PORT" value="25"/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_SUBJECT" type="String" vName="MAIL_SUBJECT" value="Maj remboursement - Erreur WS Payzen "/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_TEXT" type="String" vName="MAIL_TEXT" value="Bonjour, &#xA;&#xA;Erreur dans le retour du WS Payzen (Find) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xA;&#xA;&#xA;Cordialement,&#xA;Informatique Commerce "/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_TO" type="String" vName="MAIL_TO" value="${~/mail_info}$"/><parameter name="com_maj_remboursement/MailPayzen1KO/MAIL_USE_SSL" type="STRING" vName="MAIL_USE_SSL" value="false"/></step><step actionName="com_maj_remboursement/330 DB Prepa RET_REGLEMENT_RBT(montant origine)" id="37a42a729d689c9e1fcb6f19b4e0d491" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LqhJgEfGpb7QiJEquyg"/><altId origin="flow" value="_BEBr8C3tEeizKekQ_YH6NA-flow"/><altId origin="mapping" value="_BEBr8C3tEeizKekQ_YH6NA"/><altId origin="processRef" value="_BEBr8C3tEeizKekQ_YH6NA-proc"/></step><step actionName="com_maj_remboursement/SendEmailKDO" id="3d0777e632d50900803af21c982772b9" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.SendMailActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_oU2K-xJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_FROM" type="String" vName="MAIL_FROM" value="stambia@happychicgroup.com"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_HOSTNAME" type="STRING" vName="MAIL_HOSTNAME" value="baffin"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_PORT" type="STRING" vName="MAIL_PORT" value="25"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_SUBJECT" type="String" vName="MAIL_SUBJECT" value="Génération carte KDO suite Remboursement Commande ${~/p_id_cde}$"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_TEXT" type="String" vName="MAIL_TEXT" value="Bonjour, &#xA;&#xA;Suite à un retour commande, une carte cadeau est à générer. &#xA;&#xA;Carte cadeau d'un montant de : ${~/P_MONTANTKDO}$ € pour l'enseigne : ${~/P_ENSEIGNE}$&#xA;&#xA;Pour le client : ${~/P_NUMCLIENT}$ - ${~/P_NOMCLIENT}$&#xA;&#xA;Mail : ${~/P_MAILCLIENT}$&#xA;&#xA;Adresse postale : ${~/P_ADRCLIENT}$ &#xA;&#xA;&#xA;Le ticket retour a été créé dans Storeland, pas besoin de prévenir la comptabilité de ce remboursement. &#xA;&#xA;Cordialement,&#xA;Informatique Commerce "/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_TO" type="String" vName="MAIL_TO" value="e-shopping@Jules.fr"/><parameter name="com_maj_remboursement/SendEmailKDO/MAIL_USE_SSL" type="STRING" vName="MAIL_USE_SSL" value="false"/></step><step actionName="com_maj_remboursement/Mail_Renseigne" id="3e044d164fbe51995792fe4854ad3146" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../MAIL_CDE" type="Integer">
select case when nvl(EMAIL,'NON RENSEIGNE') = 'NON RENSEIGNE' then 0 
else 1 
end
from ECOMM.CDE 
where id_cde = '${~/p_id_cde}$' 
</parameter>
</sqlToParameters>
]]><altId origin="compilation" value="_oU2LQhJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Mail_Renseigne/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Mail_Renseigne/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/380 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado)" id="3e52e4307de7b3141f040001697433b9" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LtBJgEfGpb7QiJEquyg"/><altId origin="flow" value="_Enr6UDDqEeiylpRw1KCMvQ-flow"/><altId origin="mapping" value="_Enr6UDDqEeiylpRw1KCMvQ"/><altId origin="processRef" value="_Enr6UDDqEeiylpRw1KCMvQ-proc"/></step><step actionName="com_maj_remboursement/MAJ_Montant" id="4422a86d381435cfa9bbe4c52ea97df4" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.RET_LIGNE_RBT
set MONTANT_RBT = MONTANT_RBT_FORCE, MONTANT_RBT_FORCE = null
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ 
and MONTANT_RBT_FORCE > 0 ;
update ECOMM.RET_RBT
set MNT_RBT = (select sum(MONTANT_RBT) from ECOMM.RET_LIGNE_RBT 
	where ID_CDE = ${~/p_id_cde}$ and ID_RBT = ${~/p_id_rbt}$ )
where ID_CDE = '${~/p_id_cde}$' 
and ID_RBT = ${~/p_id_rbt}$ ;
]]><altId origin="compilation" value="_oU2LIhJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/MAJ_Montant/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/MAJ_Montant/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/MAJ_Montant/SQL_MULTI_QUERYS" type="Boolean" vName="SQL_MULTI_QUERYS" value="true"/><parameter name="com_maj_remboursement/MAJ_Montant/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Montant_Force_Correct" id="471c1bc89e51a8cd786913c5f27c97a1" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_MNT_OK" type="Integer">
select case when W_RBT.MNT_RBT > to_number(${~/P_MONTANT_OK}$)
then 0
else 1
end
from ETLWORK.W_RBT  W_RBT, ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
where W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$'
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LDRJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Montant_Force_Correct/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/Montant_Force_Correct/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ETLWORK"/></step><step actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )" id="492fbcc6851e8a61f933da40fd07f1a5" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LxhJgEfGpb7QiJEquyg"/><altId origin="flow" value="_W_jHdBC9EfGfYb_ksmCh-w-flow"/><altId origin="mapping" value="_W_jHdBC9EfGfYb_ksmCh-w"/><altId origin="processRef" value="_W_jHdBC9EfGfYb_ksmCh-w-proc"/></step><step actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)" id="6562eb74a389b3ea9690a2a411050d1f" isBeginAction="false" nbCycles="-1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_oU2LwBJgEfGpb7QiJEquyg"/><altId origin="flow" value="_t6fvwnRnEeiP1OY0c7ac_A-flow"/><altId origin="mapping" value="_t6fvwnRnEeiP1OY0c7ac_A"/><altId origin="processRef" value="_t6fvwnRnEeiP1OY0c7ac_A-proc"/></step><step actionName="com_maj_remboursement/Paiement_trouvé" id="68890490f255b8e03b9326e4023eb1bd" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_PMTOK" type="Integer">
select 
count(*) 
from ETLWORK.W_RBT_PAYZEN 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
