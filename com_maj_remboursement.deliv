]]><altId origin="compilation" value="_jkWgOFEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table" id="258a4c838db5571e4f00bafc97bbc625" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_RBT purge]]><altId origin="compilation" value="_jkWgMlEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" id="3bb0a156944530c4098eae05a2806521" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_RET_RBT
(
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	INCREMENTAL_FLAG
)
select   	  
	RET_LIGNE_RBT.ID_CDE,
	RET_LIGNE_RBT.ID_RBT,
	case when max(LCDE.DATH_E_EXPE) is null 
then 'manquant'
when max(LCDE.DATH_E_RETIRE) is null 
then 'remiseEnStock'
else 'retour'
end,
	'I' INCREMENTAL_FLAG
from	ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	INNER JOIN ECOMM.LCDE  LCDE
	ON RET_LIGNE_RBT.ID_CDE = LCDE.ID_CDE
and RET_LIGNE_RBT.ID_LCDE = LCDE.ID_LCDE
where	(1=1)  AND (RET_LIGNE_RBT.F_SERVICE IS NULL AND RET_LIGNE_RBT.MOTIF_RETOUR IS NULL) AND (RET_LIGNE_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_LIGNE_RBT.ID_RBT = ${~/p_id_rbt}$)
group by RET_LIGNE_RBT.ID_CDE, RET_LIGNE_RBT.ID_RBT, 'I'
minus
select
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	'I' INCREMENTAL_FLAG	
from	ECOMM.RET_RBT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" id="b5266390eb3dbf7a7198b68dc57adea9" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[BEGIN 
DBMS_STATS.GATHER_TABLE_STATS(
   OWNNAME=>'ETLWORK',
   TABNAME=>'I_RET_RBT'
   
);
end;]]><altId origin="compilation" value="_c1jhsGoOEea9fIQJ0nVgng"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of Index on pre-integration table" id="d3c8d583bbf42cf056694e66b611f87c" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[create index ETLWORK.I_RET_RBT_IDX
