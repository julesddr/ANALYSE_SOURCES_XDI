gy="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_W_RBT purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Start" id="3c78e150632ae2b5615b367737205c81" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target" id="ac9feb8a5f1abe9c3c9b94bf4cda553d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ETLWORK.W_RBT T 
set


 (  T.MNT_RBT_CAL
             
       ) = 
             (
             select S.MNT_RBT_CAL
                           
             from   ETLWORK.I_W_RBT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.SESSION_ID=T.SESSION_ID
                     )     


where	(ID_CDE, ID_RBT, SESSION_ID)
	in	(
		select	ID_CDE, ID_RBT, SESSION_ID
		from	ETLWORK.I_W_RBT I
		where	I.INCREMENTAL_FLAG = 'U'
		)

