 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Drop of pre-integration table" id="23be57cfabfb7ddd292af01388a61c88" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_RBT purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target" id="84f40e80bb8305eb4333d1647a114588" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into ECOMM.RET_RBT
	(	ID_CDE,
		ID_RBT,
		TYPE_RETOUR
		
	)
select	  ID_CDE,
		ID_RBT,
		TYPE_RETOUR
		
from	ETLWORK.I_RET_RBT INT
where	INT.INCREMENTAL_FLAG = 'I'


]]><altId origin="compilation" value="_jkWgoVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Insertion of rows in target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target" id="94fdf01ad66e21067027fd7ed0385f53" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ECOMM.RET_RBT T 
set


 (  T.TYPE_RETOUR
             
       ) = 
             (
             select S.TYPE_RETOUR
                           
             from   ETLWORK.I_RET_RBT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.I_RET_RBT I
		where	I.INCREMENTAL_FLAG = 'U'
		)

]]><altId origin="compilation" value="_jkWgmlEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="UPDATE"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="com_maj_remboursement/860 DB RET_RBT(Motif mail)2/I1-RET_RBT-Integration/I1-RET_RBT-Integration/Flag of rows to update" id="af269e6a20dba27de637dcb63b5a54c6" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	ETLWORK.I_RET_RBT
set	INCREMENTAL_FLAG = 'U'
where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE,
			ID_RBT
		from	ECOMM.RET_RBT
