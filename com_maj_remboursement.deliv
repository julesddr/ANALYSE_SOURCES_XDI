RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" id="58e997f4bd763ec7de748a9dd42b67c9" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_W_RBT
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	SESSION_ID	VARCHAR2(40 BYTE) NULL,
	MNT_RBT_CAL	NUMBER(8,2) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
]]><altId origin="compilation" value="_jkWgOFEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" id="f3797fe06e93f72a10dc2da833cf7472" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT
(
	ID_CDE,
	ID_RBT,
	SESSION_ID,
	MNT_RBT_CAL,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.SESSION_ID,
	W_RBT.MNT_RBT_CAL - W_RBT_PREPA_RGT.MONTANT_AREMBOURSER,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	ON W_RBT.ID_CDE = W_RBT_PREPA_RGT.ID_CDE
and W_RBT.ID_RBT = W_RBT_PREPA_RGT.ID_RBT
and W_RBT.SESSION_ID = W_RBT_PREPA_RGT.SESSION_ID
where	(1=1)  AND (W_RBT_PREPA_RGT.MODE_REGLEMENT IN (21, 28) AND W_RBT_PREPA_RGT.MONTANT_AREMBOURSER IS NOT NULL) AND (W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$')
minus
select
	ID_CDE,
	ID_RBT,
	SESSION_ID,
	MNT_RBT_CAL,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="7667f7c0663f918baded792acf4dc777" mandatory="1" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of pre- integration table" type="OK"/><link id="88fb6452b75f8093c8c8b4b128501040" mandatory="1" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of Index on pre-integration table" targetName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" type="OK"/><link id="cebb8471ad436be070ea6c456a594727" mandatory="1" sourceName="com_maj_remboursement/385 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Carte Illicado 2)/I1-W_RBT_2-Integration/I