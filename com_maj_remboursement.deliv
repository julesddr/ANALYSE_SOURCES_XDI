nt"/><parameter name="com_maj_remboursement/ExecuteDelivery/DELIV_SESSION_NAME" type="String" vName="DELIV_SESSION_NAME" value="detail_paiement_:{UUID}:"/><parameter name="com_maj_remboursement/ExecuteDelivery/p_entite" type="String" vName="p_entite" value=":{entite}:"/><parameter name="com_maj_remboursement/ExecuteDelivery/p_id_cde" type="String" vName="p_id_cde" value=":{id_cde}:"/><parameter name="com_maj_remboursement/ExecuteDelivery/p_id_rbt" type="Integer" vName="p_id_rbt" value=":{id_rbt}:"/><parameter name="com_maj_remboursement/ExecuteDelivery/uuid" type="String" vName="uuid" value=":{UUID}:"/></step><step actionName="com_maj_remboursement/Statut Erreur sur RET_RBT" id="81aeaba0e35f433d96a4932fbf6abe63" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.RET_RBT 
