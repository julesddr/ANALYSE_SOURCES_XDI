set


 (  T.NB_PT_GLOB,
		T.CARTE_FID,
		T.DATE_EXPI_FID
             
       ) = 
             (
             select S.NB_PT_GLOB,
				S.CARTE_FID,
				S.DATE_EXPI_FID
                           
             from   ETLWORK.I_RET_RBT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.I_RET_RBT I
		where	I.INCREMENTAL_FLAG = 'U'
		)

