set statut_lcde = 'REMBKOB' , dath_s_rembkob = sysdate, dath_maj = sysdate
where id_cde = '${~/p_id_cde}$' and statut_lcde = 'DEMREMB';
update ECOMM.RET_RBT 
set statut = 'REMBKOB' 
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ ;]]><altId origin="compilation" value="_oU2K7RJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/REMBKOB/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/REMBKOB/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/REMBKOB/SQL_MULTI_QUERYS" type="Boolean" vName="SQL_MULTI_QUERYS" value="true"/><parameter name="com_maj_remboursement/REMBKOB/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/Enseigne" id="b35cbe10312b165deff0ba60256ebdce" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
<parameter name="../P_ENSEIGNE" type="String">
select ens.libmarque
from ECOMM.CDE cde , 
ECOMM.ENSEIGNE ens 
where cde.id_cde = '${~/p_id_cde}$' 
and cde.id_enseigne = ens.id_enseigne
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_oU2LRxJgEfGpb7QiJEquyg"/><parameter name="com_maj_remboursement/Enseigne/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/Enseigne/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="com_maj_remboursement/MAJ LCDE" id="b448ded97f6ffa61a2488a045e3755e3" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.LCDE 
