(
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	DATEH,
	INCREMENTAL_FLAG
)
select   	  
	'${~/p_id_cde}$',
	${~/p_id_rbt}$,
	'OK-'||L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L10_detailedStatus,
	sysdate,
	'I' INCREMENTAL_FLAG
from	(
select L10_detailedStatus,
	L11_status
from (((((ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
						LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
						ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
					ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_3  L1_RET_MAJ_LOG_3
				ON L1_RET_MAJ_LOG_2.stb_key=L1_RET_MAJ_LOG_3.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_4  L1_RET_MAJ_LOG_4
			ON L1_RET_MAJ_LOG_3.stb_key=L1_RET_MAJ_LOG_4.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_5  L1_RET_MAJ_LOG_5
		ON L1_RET_MAJ_LOG_4.stb_key=L1_RET_MAJ_LOG_5.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_6  L1_RET_MAJ_LOG_6
	ON L1_RET_MAJ_LOG_5.stb_key=L1_RET_MAJ_LOG_6.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_6.stb_key is null))  L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_
where	(1=1)  AND (L1_RET_MAJ_LOG_KO_RET_MAJ_LOG_.L11_status = 'SUCCESS')
minus
select
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	DATEH,
	'I' INCREMENTAL_FLAG	
from	ECOMM.RET_MAJ_LOG

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="41a36a775f377dd185de106c6e694671" mandatory="1" sourceName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of pre-integration data - MINUS" targetName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of Index on pre-integration table" type="OK"/><link id="67065f3805a86dfdaf87e5fe99011607" mandatory="1" sourceName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table" targetName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Insertion of pre-integration data - MINUS" type="OK"/><link id="697a361f555f6eed39dc1ba023f4b61a" mandatory="1" sourceName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Drop of pre-integration table" targetName="com_maj_remboursement/810 ws RefundPayment/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Prepare/Creation of pre- integration table" type="OK"/><link id="e22711700ce8d9c66b264f9c726587ee" mandatory="1" sourceName="com_maj_rembourse