 nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert into ETLWORK.L1_1g6sztwnvayj5
(L1_ID_LCDE, L2_MONTANT_RBT, L3_MONTANT_RBT_FORCE, L4_ID_CDE, L5_ID_RBT)
values
(:{L1_ID_LCDE}:, :{L2_MONTANT_RBT}:, :{L3_MONTANT_RBT_FORCE}:, :{L4_ID_CDE}:, :{L5_ID_RBT}:)]]><altId origin="compilation" value="_0wMsY2iQEeiKycjOxudrjg"/><parameter name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Load of data (TRG)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="INSERT"/><parameter name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Load of data (TRG)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Load of data (TRG)/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Select on source table (SRC)" id="9cd632842037f20d9c604fcc96205fd1" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[select		
			RET_LIGNE_RBT.ID_LCDE  L1_ID_LCDE,
			RET_LIGNE_RBT.MONTANT_RBT  L2_MONTANT_RBT,
			RET_LIGNE_RBT.MONTANT_RBT_FORCE  L3_MONTANT_RBT_FORCE,
			RET_RBT.ID_CDE  L4_ID_CDE,
			RET_RBT.ID_RBT  L5_ID_RBT
			
from	ECOMM.RET_RBT  RET_RBT
	INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT
where	(1=1) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)]]><altId origin="compilation" value="_0wMFUmiQEeiKycjOxudrjg"/><parameter name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Select on source table (SRC)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="SELECT"/><parameter name="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Select on source table (SRC)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/></step><link bindType="DirectBind" id="e759914d7f75971733d9b457727319bc" mandatory="1" sourceName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Select on source table (SRC)" targetName="com_maj_remboursement/750 DB W_RBT/L1-stage-Load/For simple table/Load of data (TRG)" type="OK"/></process><process actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Cleanup" isBeginProcess="false"><step actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Cleanup/Drop table staging" id="14001f341937ffa3309808bce1a1c729" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Drop table ETLWORK.S1_1g6sztwnvayj5_stage purge]]><altId origin="compilation" value="_8zSzYdu8EeWIdu0rdnx7VQ"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Cleanup/Drop table staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Cleanup/Drop table staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Cleanup/Drop table staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step></process><process actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging" isBeginProcess="false"><step actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Creation of staging" id="1a1b9bbaad1664faf99267fe34a05165" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.S1_1g6sztwnvayj5_stage
NOLOGGING
AS




select	  
	L1_stage.L5_ID_RBT AS L6_ID_RBT,
	sum(coalesce(L1_stage.L3_MONTANT_RBT_FORCE,L1_stage.L2_MONTANT_RBT)) AS L7_MNT_RBT,
	L1_stage.L4_ID_CDE AS L8_ID_CDE,
	L1_stage.L1_ID_LCDE AS L9_ID_LCDE

from	ETLWORK.L1_1g6sztwnvayj5  L1_stage
where	(1=1)
group by L1_stage.L5_ID_RBT, L1_stage.L4_ID_CDE, L1_stage.L1_ID_LCDE



]]><altId origin="compilation" value="_8zSzSdu8EeWIdu0rdnx7VQ"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging" id="c3d8bff8e085851fe4bd7e47c0dd80a9" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop view ETLWORK.S1_1g6sztwnvayj5_stage]]><altId origin="compilation" value="_8zSzVdu8EeWIdu0rdnx7VQ"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging" id="d045f218bd80a344adf875aa31038e0e" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop table ETLWORK.S1_1g6sztwnvayj5_stage purge]]><altId origin="compilation" value="_8zSzT9u8EeWIdu0rdnx7VQ"/><parameter name="com_maj_remboursement/750 DB W_RBT/S1-stage-Staging/Drop table stagging/S