Update of rows in target" type="OK"/><link id="c1e1201dcb16ba93d40740a8ca6d6f42" mandatory="1" sourceName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Update of rows in target" targetName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Integration/Commit of transaction on target" type="OK"/></process><process actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare" isBeginProcess="false"><step actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS" id="0fdadeede3f8d37ea1c1783bd26c2f3d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_W_RBT
(
	ID_CDE,
	ID_RBT,
	SESSION_ID,
	MNT_RBT_CAL,
	INCREMENTAL_FLAG
)
select   	  
	W_RBT_PREPA_RGT.ID_CDE,
	W_RBT_PREPA_RGT.ID_RBT,
	W_RBT_PREPA_RGT.SESSION_ID,
	W_RBT.MNT_RBT_CAL - W_RBT_PREPA_RGT.MONTANT_AREMBOURSER,
	'I' INCREMENTAL_FLAG
from	ETLWORK.W_RBT  W_RBT
	INNER JOIN ETLWORK.W_RBT_PREPA_RGT  W_RBT_PREPA_RGT
	ON W_RBT.ID_CDE = W_RBT_PREPA_RGT.ID_CDE
and W_RBT.ID_RBT = W_RBT_PREPA_RGT.ID_RBT
and W_RBT.SESSION_ID = W_RBT_PREPA_RGT.SESSION_ID
where	(1=1)  AND (W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$') AND (W_RBT_PREPA_RGT.MODE_REGLEMENT = 41 AND W_RBT_PREPA_RGT.MONTANT_AREMBOURSER IS NOT NULL)
minus
select
	ID_CDE,
	ID_RBT,
	SESSION_ID,
	MNT_RBT_CAL,
	'I' INCREMENTAL_FLAG	
from	ETLWORK.W_RBT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_storeland(_1hrwYN6QEe217NRB37hsnQ)"/><parameter name="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="com_maj_remboursement/396 DB Prepa RET_REGLEMENT_RBT(montant à rembourser Alma 2 )/I1-W_RBT_2-Integration/I1-W_RBT_2-Prepare/Creation of Index on pre-integration table" id="3c174bb61944bc89b214897c8af7173f" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[create index ETLWORK.I_W_RBT_IDX
