AS




select	  DISTINCT 
	CDE.FAC_PRENOM AS L91_prenom,
	ARTICLE.ID_COULEUR AS L92_coloris,
	substr(RET_RBT.ID_CDE,1,9) AS L93_numero,
	case when RET_RBT.TYPE_RETOUR = 'manquant' 
then RET_RBT.TYPE_RETOUR 
when RET_RBT.TYPE_RETOUR = 'remiseEnStock'
then RET_RBT.TYPE_RETOUR 
else 'retour'
end  AS L94_motifRemboursement,
	ARTICLE.LIB_PRODUIT AS L95_description,
	RET_LIGNE_RBT.CODE_EAN AS L96_reference,
