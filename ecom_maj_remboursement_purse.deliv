set


 (  T.LOG_TICKET,
		T.DATEH
             
       ) = 
             (
             select S.LOG_TICKET,
				S.DATEH
                           
             from   ETLWORK.I_RET_MAJ_LOG S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
                     )     


where	(ID_CDE, ID_RBT)
	in	(
		select	ID_CDE, ID_RBT
		from	ETLWORK.I_RET_MAJ_LOG I
		where	I.INCREMENTAL_FLAG = 'U'
		)

]]><altId origin="compilation" value="_jkWgmlEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="UPDATE"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Start" id="35107694ccf0cb321c605656f82674c0" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Integration/Drop of pre-integration table" id="caa345d051e76727a2037e2ed51d9b84" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code