then RET_REGLEMENT_RBT.LIB_RGT
else 'Carte Cadeau'
end AS L99_modeRemboursement,
	RET_RBT.CARTE_FID AS L100_codecarte,
	CDE.FAC_NOM AS L101_nom,
	RET_RBT.DATE_EXPI_FID AS L102_expiration,
