PE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I5-RET_MAJ_LOG_ANO-Integration/I5-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append" id="b9ac62bca019e4f5bc8152de1f9b32ad" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		${~/p_id_rbt}$ AS ID_RBT,
		L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L138_LOG_MAIL AS LOG_MAIL
		from	(
select L138_LOG_MAIL,
	L139_status
from (ETLWORK.L3_RET_MAJ_LOG_0  L3_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L3_RET_MAJ_LOG_1  L3_RET_MAJ_LOG_1
		ON L3_RET_MAJ_LOG_0.stb_key=L3_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L3_RET_MAJ_LOG_2  L3_RET_MAJ_LOG_2
	ON L3_RET_MAJ_LOG_1.stb_key=L3_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L3_RET_MAJ_LOG_2.stb_key is null))  L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO
		where	(1=1) AND (L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L139_status <> 'OK')
		
	) SRC
