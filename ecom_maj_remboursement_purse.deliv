ANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" id="b24040eac03bb44fcec554f83124e375" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_RET_RBT
(
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	INCREMENTAL_FLAG
)
select   	  
	RET_LIGNE_RBT.ID_CDE,
	RET_LIGNE_RBT.ID_RBT,
	case when max(LCDE.DATH_E_EXPE) is null 
then 'manquant'
when max(LCDE.DATH_E_RETIRE) is null 
then 'remiseEnStock'
else 'retour'
end,
	'I' INCREMENTAL_FLAG
from	ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	INNER JOIN ECOMM.LCDE  LCDE
	ON RET_LIGNE_RBT.ID_CDE = LCDE.ID_CDE
and RET_LIGNE_RBT.ID_LCDE = LCDE.ID_LCDE
where	(1=1)  AND (RET_LIGNE_RBT.F_SERVICE IS NULL AND RET_LIGNE_RBT.MOTIF_RETOUR IS NULL) AND (RET_LIGNE_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_LIGNE_RBT.ID_RBT = ${~/p_id_rbt}$)
group by RET_LIGNE_RBT.ID_CDE, RET_LIGNE_RBT.ID_RBT, 'I'
minus
select
	ID_CDE,
	ID_RBT,
	TYPE_RETOUR,
	'I' INCREMENTAL_FLAG	
from	ECOMM.RET_RBT

]]><altId origin="compilation" value="_jkWgWVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="519542515163298611fd40fde7d9751d" mandatory="1" sourceName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" targetName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of Index on pre-integration table" type="OK"/><link id="5bca83293522ac9bf8510d1b7564f5b1" mandatory="1" sourceName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of Index on pre-integration table" targetName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" type="OK"/><link id="71b07e6bcd85ccf37a30e4b324a3bd7b" mandatory="1" sourceName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Creation of pre- integration table" targetName="ecom_maj_remboursement_purse/860 DB RET_RBT(Motif mail)/I1-RET_RBT-Integration/I1-RET_RBT-Prepare/Insertion of pre-integration data - MINUS" type="OK"/><link id="fbfcd203cb7b8d54be420d4b095eb223" ma