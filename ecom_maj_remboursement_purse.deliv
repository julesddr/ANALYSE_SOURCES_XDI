<parameter name="../P_PMTBOK" type="Integer">
select 
case when LOG_PAIEMENT like 'OK%'
then 1
else 0 end
from ECOMM.RET_MAJ_LOG 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
<parameter name="../P_PMTBKO" type="Integer">
select 
case when LOG_PAIEMENT like 'KO%'
then 1
else 0 end
from ECOMM.RET_MAJ_LOG 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
<parameter name="../P_STATUS" type="String">
select 
NVL(ERROR_CODE,'-')
from ECOMM.RET_MAJ_LOG 
where ID_CDE = '${~/p_id_cde}$'
and ID_RBT = ${~/p_id_rbt}$
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="a07382f7-cd81-471f-88e1-134d6ec0214a"/><parameter name="ecom_maj_remboursement_purse/Remboursement_purse_effectué/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/Remboursement_purse_effectué/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="ecom_maj_remboursement_purse/Cde_Du_jour" id="45d99e59137e300a4be2f3946bd230d8" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.sqlToParameters" toleratedError="false" type="Code"><![CDATA[<sqlToParameters>
