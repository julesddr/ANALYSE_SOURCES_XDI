		ON L1_1g9klfhlwte0i_2.stb_key=L1_1g9klfhlwte0i_3.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_1g9klfhlwte0i_4  L1_1g9klfhlwte0i_4
	ON L1_1g9klfhlwte0i_3.stb_key=L1_1g9klfhlwte0i_4.stb_parentKey
where (1=1)
and not(
	L1_1g9klfhlwte0i_3.stb_key is null and
	L1_1g9klfhlwte0i_4.stb_key is null))  L1_stage_refund_reponse
where	(1=1)



