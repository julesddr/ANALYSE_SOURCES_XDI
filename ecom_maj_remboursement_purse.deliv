ame="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target" id="cd15d504f91e58385573bad08db284af" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update	  ECOMM.RET_REGLEMENT_RBT T 
set


 (  T.MONTANT_RGT
             
       ) = 
             (
             select S.MONTANT_RGT
                           
             from   ETLWORK.I_RET_REGLEMENT_RBT S
             where  S.ID_CDE=T.ID_CDE
			 And S.ID_RBT=T.ID_RBT
			 And S.CODE_RGT=T.CODE_RGT
                     )     


where	(ID_CDE, ID_RBT, CODE_RGT)
	in	(
		select	ID_CDE, ID_RBT, CODE_RGT
		from	ETLWORK.I_RET_REGLEMENT_RBT I
		where	I.INCREMENTAL_FLAG = 'U'
		)

]]><altId origin="compilation" value="_jkWgmlEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="UPDATE"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Update of rows in target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Drop of pre-integration table" id="e2ada5e5853ae175d5a0398dde2ca078" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_REGLEMENT_RBT purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name=