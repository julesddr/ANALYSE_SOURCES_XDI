NOLOGGING
AS




select		
	ECOMM.SEQ_RBT_CDE.NEXTVAL AS L1_ID,
	RET_RBT.ID_CDE AS L2_ID_CDE,
	RET_RBT.ID_RBT AS L3_ID_RBT
	
from	ECOMM.RET_RBT  RET_RBT
where	(1=1) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)



]]><altId origin="compilation" value="_rdD5NTRMEeSQ37GXUClEnA"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging" id="3dd9bd4379ea5372c49c0a86b3709009" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop view WI_WORK.S1_1g9f506o5he26_stage]]><altId origin="compilation" value="_w4gOMDRMEeSQ37GXUClEnA"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/S1-stage-Staging/Drop table stagging" id="e19db7baa6a2d7a3f4b0a4fa765b3094" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop tabl