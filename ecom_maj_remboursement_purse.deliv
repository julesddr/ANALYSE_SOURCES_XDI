(
	ID_CDE,
	ID_RBT,
	LOG_TICKET,
	DATEH,
	INCREMENTAL_FLAG
)
select * from
(select  	  
			'${~/p_id_cde}$' AS ID_CDE,
	${~/p_id_rbt}$ AS ID_RBT,
	case when L1_RET_MAJ_LOG.L56_faultcode is not null 
then L1_RET_MAJ_LOG.L54_code||'-'||L1_RET_MAJ_LOG.L55_description
else 'OK' 
end      AS LOG_TICKET,
	sysdate AS DATEH,
			'I' INCREMENTAL_FLAG
from	(
select L54_code,
	L55_description,
	L56_faultcode
from (((((ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
						LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
						ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
					LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
					ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey)
				LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_3  L1_RET_MAJ_LOG_3
				ON L1_RET_MAJ_LOG_2.stb_key=L1_RET_MAJ_LOG_3.stb_parentKey)
			LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_4  L1_RET_MAJ_LOG_4
			ON L1_RET_MAJ_LOG_3.stb_key=L1_RET_MAJ_LOG_4.stb_parentKey)
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_5  L1_RET_MAJ_LOG_5
		ON L1_RET_MAJ_LOG_4.stb_key=L1_RET_MAJ_LOG_5.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_6  L1_RET_MAJ_LOG_6
	ON L1_RET_MAJ_LOG_4.stb_key=L1_RET_MAJ_LOG_6.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_5.stb_key is null and
	L1_RET_MAJ_LOG_6.stb_key is null))  L1_RET_MAJ_LOG
where	(1=1) 
) SRC
WHERE not exists (select   'X' from ECOMM.RET_MAJ_LOG TRG
					Where (1=1)
					
					And (TRG.ID_CDE=SRC.ID_CDE or ( TRG.ID_CDE IS NULL AND SRC.ID_CDE IS NULL))
					And(TRG.ID_RBT=SRC.ID_RBT or ( TRG.ID_RBT IS NULL AND SRC.ID_RBT IS NULL))
					And(TRG.LOG_TICKET=SRC.LOG_TICKET or ( TRG.LOG_TICKET IS NULL AND SRC.LOG_TICKET IS NULL))
					And(TRG.DATEH=SRC.DATEH or ( TRG.DATEH IS NULL AND SRC.DATEH IS NULL))
					
					)]]><altId origin="compilation" value="_jkWgEFEJEeO7Vo9WeM2sCg_x"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Insertion of pre-integration data - NOT EXISTS/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Insertion of pre-integration data - NOT EXISTS/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Insertion of pre-integration data - NOT EXISTS/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Creation of Index on pre-integration table" id="56e5532aaef1c1d72da819ecb1c395d8" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[create index ETLWORK.I_RET_MAJ_LOG_IDX
on		ETLWORK.I_RET_MAJ_LOG (ID_CDE, ID_RBT)

]]><altId origin="compilation" value="8c55021f-2a6e-4cd8-baf5-8ffb4d614646"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Creation of Index on pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Creation of Index on pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Creation of Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/850 ws StorelandTicketRetour/I1-RET_MAJ_LOG-Integration/I1-RET_MAJ_LOG-Prepare/Creation of pre- integration table" id="d91e4fbf376ac182ccc3225da65a7c7d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_RET_MAJ_LOG
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	LOG_TICKET	VARCHAR2(100 BYTE) NULL,
	DATEH	DATE NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
