se" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[commit]]><altId origin="compilation" value="_jkWgqFEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Commit of transaction on target/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Commit of transaction on target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append" id="c47551060cc33b545ec38f31b7d837af" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		 ${~/p_id_rbt}$ AS ID_RBT,
		L1_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L25_LOG_MAIL AS LOG_MAIL
		from	(
select L25_LOG_MAIL,
	L26_status
from (ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
		ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
	ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_2.stb_key is null))  L1_RET_MAJ_LOG_RET_MAJ_LOG_ANO
		where	(1=1) AND (L1_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L26_status <> 'OK')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><link id="19001a413c149e0d85eee4b2670c8f49" mandatory="1" sourceName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Start" targetName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append" type="OK"/><link id="311e04df0690c90df5dadd362ecd7c0e" mandatory="1" sourceName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I3-RET_MAJ_LOG_ANO-Integration/I3-RET_MAJ_LOG_ANO-Integration/Insertion of new rows in target - append" targetName="eco