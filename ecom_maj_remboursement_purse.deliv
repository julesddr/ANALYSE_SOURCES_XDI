and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
			ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
