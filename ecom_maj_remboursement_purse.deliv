   OWNNAME=>'ETLWORK',
   TABNAME=>'I_RET_REGLEMENT_RBT'
   
);
end;]]><altId origin="compilation" value="_c1jhsGoOEea9fIQJ0nVgng"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of pre- integration table" id="83cdffab665cc252f709d4efa6919547" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.I_RET_REGLEMENT_RBT
(
	ID_CDE	VARCHAR2(15 BYTE) NULL,
	ID_RBT	NUMBER(2,0) NULL,
	CODE_RGT	NUMBER(2,0) NULL,
	MONTANT_RGT	NUMBER(12,2) NULL,
	
	
	INCREMENTAL_FLAG	CHAR(1)
)
NOLOGGING
]]><altId origin="compilation" value="_jkWgOFEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of pre- integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of pre- integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of pre- integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Insertion of preintegration data - APPEND" id="edc5fcab713f83f0034f62a18b6251df" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert /*+ APPEND */ into ETLWORK.I_RET_REGLEMENT_RBT
(
	ID_CDE,
	ID_RBT,
	CODE_RGT,
	MONTANT_RGT,
	INCREMENTAL_FLAG
)
select		  DISTINCT
			S2_stage_refund_response_rank.L45_id_cde AS ID_CDE,
			S2_stage_refund_response_rank.L46_id_rbt AS ID_RBT,
			MODES_REGL_ECOMM_PAYS.CODEMODEREGLEMENTMAG AS CODE_RGT,
			sum(S2_stage_refund_response_rank.L42_partner_amount) AS MONTANT_RGT,
			'I' INCREMENTAL_FLAG
from	ETLWORK.S2_1g9klfhlwte0i_stage_refund_  S2_stage_refund_response_rank
	INNER JOIN ECOMM.MODES_REGL_ECOMM_PAYS  MODES_REGL_ECOMM_PAYS
	ON S2_stage_refund_response_rank.L41_partner||S2_stage_refund_response_rank.L48_method = MODES_REGL_ECOMM_PAYS.CODEPAYZEN
where	(1=1)  AND (S2_stage_refund_response_rank.L49_merchant_reference = '${~/p_id_cde}$' || '-' || '${~/p_id_rbt}$') AND (MODES_REGL_ECOMM_PAYS.CODEPAYS = '${~/p_pays}$')
group by S2_stage_refund_response_rank.L45_id_cde, S2_stage_refund_response_rank.L46_id_rbt, MODES_REGL_ECOMM_PAYS.CODEMODEREGLEMENTMAG, 'I'
