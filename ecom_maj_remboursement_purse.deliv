ameter name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml/STREAM_HOOK_01" type="String" vName="STREAM_HOOK_01" value="${../streamHook01}$"/><parameter name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml/SUPER_ROOT_NAME" type="String" vName="SUPER_ROOT_NAME" value="root"/><parameter name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml/WRITE_KEY_VALUES" type="String" vName="WRITE_KEY_VALUES" value="true"/><parameter name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml/WRITE_XML_DESCRIPTOR" type="Boolean" vName="WRITE_XML_DESCRIPTOR" value="false"/><parameter name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml/XML_OUTPUT_FACTORY" type="String" vName="XML_OUTPUT_FACTORY" value="com.sun.xml.internal.stream.XMLOutputFactoryImpl"/></step></process><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S1-QTE_RET_SKU-Cleanup" isBeginProcess="false"/><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S1-QTE_RET_SKU-Staging" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S1-QTE_RET_SKU-Staging/Register Sub Query" id="639a4cad08b1991db86f0d6c89079ae6" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><![CDATA[
select		LCDE.ID_ARTICLE_INT AS L1_sku,
	count(RET_LIGNE_RBT.CODE_EAN)  AS L2_quantity,
	LCDE.ID_CDE AS L3_ID_CDE
from	ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	INNER JOIN ECOMM.LCDE  LCDE
	ON RET_LIGNE_RBT.ID_LCDE = LCDE.ID_LCDE
and RET_LIGNE_RBT.CODE_EAN = LCDE.ID_ARTICLE_INT
and LCDE.ID_CDE = RET_LIGNE_RBT.ID_CDE
AND LCDE.F_SERVICE IS null
where	(1=1)
 AND (RET_LIGNE_RBT.ID_RBT = ${~/p_id_rbt}$) AND (LCDE.ID_CDE = ${~/p_id_cde}$)
group by LCDE.ID_ARTICLE_INT, LCDE.ID_CDE

]]><altId origin="compilation" value="_3H_nQDNEEeSH5LKy1U4ptg"/></step></process><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Cleanup" isBeginProcess="false"/><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Staging" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Staging/Register Sub Query" id="76694e365e980ee11307705cd86d6e01" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><![CDATA[
select		DISTINCT STAGE_SALES.BASKETID AS L4_basketId,
	CDE.ID_ENTITE_ECOMM AS L5_storeId,
	CDE.ID_CDE || '_' || TO_CHAR(SYSTIMESTAMP, 'YYYYMMDDHH24MISSFF3') AS L6_receipt_id,
	CDE.ID_CDE AS L7_ID_CDE
from	ECOMM.STAGE_SALES  STAGE_SALES
	INNER JOIN ECOMM.CDE  CDE
	ON STAGE_SALES.ORDER_NO = CDE.ID_TICKET
and STAGE_SALES.STORE_ID = CDE.ID_ENTITE_ECOMM
where	(1=1)
 AND (CDE.ID_CDE = ${~/p_id_cde}$) AND (STAGE_SALES.BASKETID IS NOT NULL)

]]><altId origin="compilation" value="_3H_nQDNEEeSH5LKy1U4ptg"/></step></process><process actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup" id="01aa114fd6753b21e190bcca776551d9" isBeginAction="false" nbCycles="1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_GfJjADIsEe-uVJ1syFJE3w-proc2_L1"/><altId origin="processRef" value="_XlyXUF1zEeqeGKtdIHSD5Q"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/cleanTemporaryObjects" output="false" type="Boolean" vName="cleanTemporaryObjects" value="true"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/createLoadIndexes" output="false" type="Boolean" vName="createLoadIndexes" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/emptyElementAsNull" output="false" type="Boolean" vName="emptyElementAsNull" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/extractBase64BinaryToFile" output="false" type="Boolean" vName="extractBase64BinaryToFile" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/filterEmptyRecords" output="false" type="Boolean" vName="filterEmptyRecords" value="true"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/L1-RET_MAJ_LOG_ANO_BE_FR_RET_MAJ_-Cleanup/inFileName" output="false" type="String" vName="inFileName" value="${/CORE_TEMPORARY_FOLDER}$/mailPurse.xml"/><paramete