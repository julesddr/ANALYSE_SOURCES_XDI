					ON RET_LIGNE_RBT.CODE_EAN = ARTICLE.ID_ARTICLE_INT)
				LEFT OUTER JOIN ECOMM.TAILLE  TAILLE
				ON ARTICLE.ID_GRILLE_TAILLE = TAILLE.ID_GRILLE_TAILLE
and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
			ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
and RET_LIGNE_RBT_2.F_SERVICE = 'O' )
		LEFT OUTER JOIN ECOMM.SERVICES_ECOMM  SERVICES_ECOMM
		ON RET_LIGNE_RBT_2.CODE_EAN = SERVICES_ECOMM.ID_ARTICLE_INT
and SERVICES_ECOMM.ID_MODE_LIVRAISON is not null 
and RET_LIGNE_RBT_2.MONTANT_RBT > 0)
	LEFT OUTER JOIN ECOMM.D_PRD_URL_PHOTO_VUE_UNIQUE  D_PRD_URL_PHOTO_VUE_UNIQUE
	ON ARTICLE.ID_REF = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_REFERENCE
and ARTICLE.ID_COULEUR = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_COULEUR
and ARTICLE.ID_SAISON = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_SAISON
where	(1=1) AND (RET_LIGNE_RBT.MONTANT_RBT > 0 AND RET_LIGNE_RBT.F_SERVICE IS NULL) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$) AND (CDE.ID_ENTITE_ECOMM = 1601 AND CDE.ID_LANGUE_CDE <> 'FRE')



]]><altId origin="compilation" value="_8zSzSdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="294963cea717d72ccf99902f8bb9026a" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Drop table stagging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Creation of staging" type="OK"/><link id="aa1a0e57e9c319dc3ee72106cab17c02" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Creation of staging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Analyze" type="OK"/><link id="f2498cfca9cb0b9a4d8a7414828cc6dc" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Drop view staging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S3-stage_jules_be_nl-Staging/Drop table stagging" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I2-RET_MAJ_LOG-Integration" id="12bf6a8319efb868f3a22716d08f1ba0" isBeginAction="false" nbCycles="1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_Ieg24DSWEe--NK0XcsiGFw-proc_I2"/>