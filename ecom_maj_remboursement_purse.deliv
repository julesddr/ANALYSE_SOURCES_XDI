p table staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step></process><process actionName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging" id="183e6a9fa21c799dd64e380d9e227496" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop table ETLWORK.S1_1g9qi8sgt71pe_stage purge]]><altId origin="compilation" value="_8zSzT9u8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging" id="19e00e5c277c03db2a593164f10af3e2" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.S1_1g9qi8sgt71pe_stage
NOLOGGING
AS




select	  
	L1_stage.L10_total_captured AS L14_TOTAL_CAPTURED,
	L1_stage.L9_total_authorized AS L15_TOTAL_AUTHORIZED,
	L1_stage.L11_available_to_capture AS L16_AVAILABLE_TO_CAPTURE,
	'${~/p_id_cde}$'  AS L17_ID_CDE,
	L1_stage.L8_authorize_pending AS L18_AUTHORIZE_PENDING,
	L1_stage.L12_total_refunded AS L19_TOTAL_REFUNDED,
	${~/p_id_rbt}$  AS L20_ID_RBT,
	SYSDATE AS L21_DATH_MAJ,
	L1_stage.L13_available_to_refund AS L22_AVAILABLE_TO_REFUND
	
from	(
select L8_authorize_pending,
	L9_total_authorized,
	L10_total_captured,
	L11_available_to_capture,
	L12_total_refunded,
	L13_available_to_refund
from (ETLWORK.L1_1g9qi8sgt71pe_0  L1_1g9qi8sgt71pe_0
		LEFT OUTER JOIN ETLWORK.L1_1g9qi8sgt71pe_1  L1_1g9qi8sgt71pe_1
		ON L1_1g9qi8sgt71pe_0.stb_key=L1_1g9qi8sgt71pe_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_1g9qi8sgt71pe_2  L1_1g9qi8sgt71pe_2
	ON L1_1g9qi8sgt71pe_1.stb_key=L1_1g9qi8sgt71pe_2.stb_parentKey
where (1=1)
and not(
	L1_1g9qi8sgt71pe_2.stb_key is null))  L1_stage
where	(1=1)



]]><altId origin="compilation" value="_8zSzSdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop view staging" id="82d8dcd3d34cea035cc73ecec3b70acd" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop view ETLWORK.S1_1g9qi8sgt71pe_stage]]><altId origin="compilation" value="_8zSzVdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop view staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Analyze" id="bb216ea7a580cb11e7cfea57c6ac2ffe" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_XbZ0oGqnEeaHq-wCayLdYQ"/></step><link id="05cc00174232fd943059589d42b85028" mandatory="1" sourceName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop view staging" targetName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging" type="OK"/><link id="3cdac1d1d4e4753f36fc624479cdc80f" mandatory="1" sourceName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging" targetName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Analyze" type="OK"/><link id="9333e3409907bd36be0e846ca1d4d2bb" mandatory="1" sourceName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Drop table stagging" targetName="ecom_maj_remboursement_purse/120 get payment purse/S1-stage-Staging/Creation of staging" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Cleanup" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Cleanup/Drop table staging" id="540325605b4dbc88191554691ef84add" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Drop table ETLWORK.stage_get_payment purge]]><altId origin="compilation" value="_8zSzYdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Cleanup/Drop table staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Cleanup/Drop table staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Cleanup/Drop table staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step></process><process actionName="ecom_maj_remb