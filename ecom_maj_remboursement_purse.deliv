lowEmptyValue&#34;:&#34;false&#34;,&#34;location&#34;:&#34;path&#34;,&#34;required&#34;:&#34;true&#34;}},&#34;requestbody&#34;:{&#34;required&#34;:&#34;false&#34;,&#34;content&#34;:{&#34;mediaType&#34;:&#34;JSON&#34;,&#34;id&#34;:&#34;_9xDWZW1cEfCavo4NkvuF9Q&#34;,&#34;contentType&#34;:&#34;application/json&#34;,&#34;root&#34;:{&#34;products&#34;:[]}},},&#34;responses&#34;:[{&#34;code&#34;:&#34;200&#34;,&#34;headers&#34;:{&#34;date&#34;:{},&#34;server&#34;:{},&#34;Alt-Svc&#34;:{},&#34;x-cloud-trace-context&#34;:{},&#34;content-type&#34;:{},&#34;alt-svc&#34;:{},&#34;Content-Length&#34;:{},&#34;via&#34;:{}},&#34;cookies&#34;:{}},{&#34;code&#34;:&#34;400&#34;,&#34;content&#34;:{&#34;mediaType&#34;:&#34;JSON&#34;,&#34;id&#34;:&#34;_77jSRXKmEfCSgtKXbKAhGQ&#34;,&#34;contentType&#34;:&#34;application/json&#34;,&#34;root&#34;:{}},&#34;headers&#34;:{&#34;date&#34;:{},&#34;server&#34;:{},&#34;Alt-Svc&#34;:{},&#34;x-cloud-trace-context&#34;:{},&#34;content-type&#34;:{},&#34;alt-svc&#34;:{},&#34;Content-Length&#34;:{},&#34;via&#34;:{}},&#34;cookies&#34;:{}}]}&#xA;metadata.json.content.2=&#xA;metadata.json.content.proxy=&#xA;metadata.json.root.enableHostnameVerification=true&#xA;metadata.json.root.enableCertificateVerification=true&#xA;metadata.json.content.keyStore=&#xA;metadata.json.content.trustStore=&#xA;&#xA;metadata.json.root.baseUrl=https://api-prd.b-z-b.com/&#xA;metadata.json.root.resource=v1/carts/{basketId}/refund&#xA;metadata.json.root.outputFileFolder=&#xA;metadata.json.root.logReqRes=console&#xA;metadata.json.root.timeout=&#xA;metadata.json.root.connectionTimeout=&#xA;metadata.json.root.delayBetweenInvocations=&#xA;metadata.json.root.functionalErrorAcceptanceNumber=-1&#xA;metadata.json.root.functionalErrorRetryNumber=&#xA;metadata.json.root.functionalErrorRetryDelay=&#xA;metadata.json.root.technicalErrorAcceptanceNumber=&#xA;metadata.json.root.technicalErrorRetryNumber=&#xA;metadata.json.root.technicalErrorRetryDelay=&#xA;"/></step></process><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/I1-POST-Integration/INT/SqlToXml" id="4b09e01e78735a44251ac25423821ffb" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcToXmlActionCodeI" toleratedError="false" type="Code"><![CDATA[<sqlToXml:descriptor xmlns:sqlToXml="http://www.stambia.com/sqlToXml" xmlns:md="http://www.stambia.com/md" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

<data targetNamespace="">
	<sourceSet name="L1_POST" distinct="true" integrationSelectHint=""><field isKey="true" id="_TulksG1dEfCavo4NkvuF9Q" alias="L8_basketId" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S2_stage.L4_basketId</field><field isKey="true" id="_9xDWaW1cEfCavo4NkvuF9Q" alias="L9_receipt_id" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S2_stage.L6_receipt_id</field><field isKey="true" id="_9xDWa21cEfCavo4NkvuF9Q" alias="L10_store_id" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S2_stage.L5_storeId</field><field isKey="true" id="_9xDWbm1cEfCavo4NkvuF9Q" alias="L11_item" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_QTE_RET_SKU.L1_sku</field><field isKey="true" id="_9xDWb21cEfCavo4NkvuF9Q" alias="L12_sku" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_QTE_RET_SKU.L1_sku</field><field isKey="true" id="_9xDWcW1cEfCavo4NkvuF9Q" alias="L13_quantity" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">S1_QTE_RET_SKU.L2_quantity</field><query><from>(
select		DISTINCT STAGE_SALES.BASKETID AS L4_basketId,
	CDE.ID_ENTITE_ECOMM AS L5_storeId,
	CDE.ID_CDE || '_' || TO_CHAR(SYSTIMESTAMP, 'YYYYMMDDHH24MISSFF3') AS L6_receipt_id,
	CDE.ID_CDE AS L7_ID_CDE
from	ECOMM.STAGE_SALES  STAGE_SALES
	INNER JOIN ECOMM.CDE  CDE
	ON STAGE_SALES.ORDER_NO = CDE.ID_TICKET
and STAGE_SALES.STORE_ID = CDE.ID_ENTITE_ECOMM
where	(1=1)
 AND (CDE.ID_CDE = ${~/p_id_cde}$) AND (STAGE_SALES.BASKETID IS NOT NULL))  S2_stage
	INNER JOIN (
select		LCDE.ID_ARTICLE_INT AS L1_sku,
	count(RET_LIGNE_RBT.CODE_EAN)  AS L2_quantity,
	LCDE.ID_CDE AS L3_ID_CDE
from	ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
	INNER JOIN ECOMM.LCDE  LCDE
	ON RET_LIGNE_RBT.ID_LCDE = LCDE.ID_LCDE
and RET_LIGNE_RBT.CODE_EAN = LCDE.ID_ARTICLE_INT
and LCDE.ID_CDE = RET_LIGNE_RBT.ID_CDE
AND LCDE.F_SERVICE IS null
where	(1=1)
 AND (RET_LIGNE_RBT.ID_RBT = ${~/p_id_rbt}$) AND (LCDE.ID_CDE = ${~/p_id_cde}$)
group by LCDE.ID_ARTICLE_INT, LCDE.ID_CDE)  S1_QTE_RET_SKU
	ON S2_stage.L7_ID_CDE = S1_QTE_RET_SKU.L3_ID_CDE</from><where/></query></sourceSet><element defType="com.stambia.json.object" method="POST" id="_9xCvgG1cEfCavo4NkvuF9Q" name="e"><element defType="com.stambia.json.object" id="_9xCvgm1cEfCavo4NkvuF9Q" name="parameters"><element default="AIzaSyDE0-4O-fSGCTZz46X1lzadtSR_cfvAaI8" allowEmptyValue="true" location="header" defType="com.stambia.json.value" deprecated="false" name="X-Api-Key" id="_9xDWYG1cEfCavo4NkvuF9Q" required="false" type="string"/><element defType="com.stambia.json.value" deprecated="false" allowEmptyValue="false" name="basketId" location="path" id="_TulksG1dEfCavo4NkvuF9Q" required="true" type="string"/></element><element defType="com.stambia.json.object" id="_9xDWZG1cEfCavo4NkvuF9Q" required="false" name="requestbody"><element defType="com.stambia.json.object" mediaType="JSON" id="_9xDWZW1cEfCavo4NkvuF9Q" contentType="application/json" type="string" name="_9xDWZW1cEfCavo4NkvuF9Q"><element defType="com.stambia.json.object" name="root" id="_9xDWaG1cEfCavo4NkvuF9Q"><element defType="com.stambia.json.value" name="receipt_id" id="_9xDWaW1cEfCavo4NkvuF9Q" position="2" type="string"/><element defType="com.stambia.json.value" name="store_id" id="_9xDWa21cEfCavo4NkvuF9Q" position="1" type="decimal"/><element defType="com.stambia.json.array" name="products" id="_9xDWbW1cEfCavo4NkvuF9Q" position="3"><element defType="com.stambia.json.value" name="e" id="_9xDWbm1cEfCavo4NkvuF9Q" position="1"><element defType="com.stambia.json.value" name="sku" id="_9xDWb21cEfCavo4NkvuF9Q" position="1" type="string"/><element defType="com.stambia.json.value" name="quantity" id="_9xDWcW1cEfCavo4NkvuF9Q" position="2" type="decimal"/></element></element></element></element></element><element defType="com.stambia.json.array" id="_9xDWc21cEfCavo4NkvuF9Q" name="responses"><element defType="com.stambia.json.object" code="200" id="_9xDWkG1cEfCavo4NkvuF9Q" name="A200"><element defType="com.stambia.json.object" id="_9xDWkm1cEfCavo4NkvuF9Q" 