0 get payment purse/S2-stage_get_payment-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Staging/Analyze" id="b49ee496961962773879b6a1f99a6cfe" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_XbZ0oGqnEeaHq-wCayLdYQ"/></step><step actionName="ecom_maj_remboursement_purse/120 get payment purse/S2-stage_get_payment-Staging/Creation of staging" id="f9fe9a3c6417fc8ba06585ff4a8868a5" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.stage_get_payment
NOLOGGING
AS




select	  
	'${~/P_ACCESS_TOKEN}$' AS L1_Authorization,
	RET_REGLEMENT_RBT.ID_CDE AS L2_POST,
	sum(RET_REGLEMENT_RBT.MONTANT_RGT) AS L3_amount,
	STAGE_SALE_ORIGIN.F3_PAYMENT_ID AS L4_Payment_id
	
from	ECOMM.STAGE_SALE_ORIGIN  STAGE_SALE_ORIGIN
	INNER JOIN (ECOMM.CDE  CDE
		INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
		ON CDE.ID_CDE = RET_REGLEMENT_RBT.ID_CDE)
	ON STAGE_SALE_ORIGIN.STORE_ID = CDE.ID_ENTITE_ECOMM
and STAGE_SALE_ORIGIN.ORDER_NO = CDE.ID_TICKET
where	(1=1) AND (CDE.ID_CDE = '${~/p_id_cde}$') AND (RET_REGLEMENT_RBT.ID_CDE = '${~/p_id_cde}$' AND RET_REGLEMENT_RBT.ID_RBT = ${~/p_id_rbt}$)
