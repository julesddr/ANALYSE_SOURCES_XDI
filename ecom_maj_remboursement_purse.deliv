 value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Drop of pre-integration table" id="1070b2b05fa7a945e8f2eb075695eb8e" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_MAJ_LOG purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append" id="d6c964a2aa37739b5246b221e0c70dbf" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		${~/p_id_rbt}$ AS ID_RBT,
		L1_RET_MAJ_LOG_ANO_BE_FR_RET_M.L140_LOG_MAIL AS LOG_MAIL
		from	(
select L140_LOG_MAIL,
	L142_status
from (ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
		ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
	ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_2.stb_key is null))  L1_RET_MAJ_LOG_ANO_BE_FR_RET_M
		where	(1=1) AND (L1_RET_MAJ_LOG_ANO_BE_FR_RET_M.L142_status <> 'OK')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/Start" id="e1640c0e83a22d970a7bc99670964877" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><link id="19016cb96d08d441a2ba791b89e230c8" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I6-RET_MAJ_LOG_ANO_BE_FR-Integration/I6-RET_MAJ