</field><field isKey="false" id="_DJzcEzSWEe--NK0XcsiGFw" alias="L3_login" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.EMAIL<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_DJzcFTSWEe--NK0XcsiGFw" alias="L4_prenom" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_PRENOM<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_DJzcFzSWEe--NK0XcsiGFw" alias="L5_nom" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_NOM<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_DJzcGTSWEe--NK0XcsiGFw" alias="L6_civilite" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.FAC_CIVILITE<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_DJzcHjSWEe--NK0XcsiGFw" alias="L7_nbpoints" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.NB_PT_GLOB<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_DJzcIDSWEe--NK0XcsiGFw" alias="L8_expiration" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.DATE_EXPI_FID<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_DJzcIjSWEe--NK0XcsiGFw" alias="L9_codecarte" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.CARTE_FID<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_DJzcJjSWEe--NK0XcsiGFw" alias="L10_modeRemboursement" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">case 
when RET_REGLEMENT_RBT.CODE_RGT in (3,26)
then RET_REGLEMENT_RBT.LIB_RGT
else 'Carte Cadeau'
end<from>ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT</from></field><field isKey="false" id="_DJzcKTSWEe--NK0XcsiGFw" alias="L11_article" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.LIB_COMM<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="true" id="_DJzcKjSWEe--NK0XcsiGFw" alias="L12_item" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.CODE_EAN<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_DJzcKzSWEe--NK0XcsiGFw" alias="L13_coloris" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.ID_COULEUR<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="false" id="_DJzcLTSWEe--NK0XcsiGFw" alias="L14_image" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">D_PRD_URL_PHOTO_VUE_UNIQUE.URL_EXTERNE_FULL<from>ECOMM.D_PRD_URL_PHOTO_VUE_UNIQUE  D_PRD_URL_PHOTO_VUE_UNIQUE</from></field><field isKey="false" id="_DJzcMTSWEe--NK0XcsiGFw" alias="L15_prixRemise" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.MONTANT_RBT<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_DJzcMzSWEe--NK0XcsiGFw" alias="L16_qte" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">1</field><field isKey="false" id="_DJzcNTSWEe--NK0XcsiGFw" alias="L17_reference" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_LIGNE_RBT.CODE_EAN<from>ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT</from></field><field isKey="false" id="_DJzcNzSWEe--NK0XcsiGFw" alias="L18_taille" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">TAILLE.LIB_TAILLE<from>ECOMM.TAILLE  TAILLE</from></field><field isKey="false" id="_DJzcOTSWEe--NK0XcsiGFw" alias="L19_description" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">ARTICLE.LIB_COMM<from>ECOMM.ARTICLE  ARTICLE</from></field><field isKey="false" id="_DJzcPDSWEe--NK0XcsiGFw" alias="L20_montantTotal" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">RET_RBT.MNT_RBT<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_DJzcPjSWEe--NK0XcsiGFw" alias="L21_numero" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">substr(RET_RBT.ID_CDE,1,9)<from>ECOMM.RET_RBT  RET_RBT</from></field><field isKey="false" id="_DJzcQDSWEe--NK0XcsiGFw" alias="L22_date" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">CDE.DATH_CDE<from>ECOMM.CDE  CDE</from></field><field isKey="false" id="_DJzcQjSWEe--NK0XcsiGFw" alias="L23_motifRemboursement" aliasWord="" isAggregate="false" location="SRC" forceIsNillable="" sortOrder="">case when RET_RBT.TYPE_RETOUR = 'manquant' 
then RET_RBT.TYPE_RETOUR 
when RET_RBT.TYPE_RETOUR = 'remiseEnStock'
then RET_RBT.TYPE_RETOUR 
else 'retour'
end <from>ECOMM.RET_RBT  RET_RBT</from></field><query><from>(((((((ECOMM.RET_RBT  RET_RBT
								INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
								ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT)
							INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
							ON RET_RBT.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_REGLEMENT_RBT.ID_RBT)
						INNER JOIN ECOMM.CDE  CDE
						ON RET_RBT.ID_CDE = CDE.ID_CDE)
					LEFT OUTER JOIN ECOMM.ARTICLE  ARTICLE
					ON RET_LIGNE_RBT.CODE_EAN = ARTICLE.ID_ARTICLE_INT)
				LEFT OUTER JOIN ECOMM.TAILLE  TAILLE
				ON ARTICLE.ID_GRILLE_TAILLE = TAILLE.ID_GRILLE_TAILLE
and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
			ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
and RET_LIGNE_RBT_2.F_SERVICE = 'O' )
		LEFT OUTER JOIN ECOMM.SERVICES_ECOMM  SERVICES_ECOMM
		ON RET_LIGNE_RBT_2.CODE_EAN = SERVICES_ECOMM.ID_ARTICLE_INT
and SERVICES_ECOMM.ID_MODE_LIVRAISON is not null 
and RET_LIGNE_RBT_2.MONTANT_RBT > 0)
	LEFT OUTER JOIN ECOMM.D_PRD_URL_PHOTO_VUE_UNIQUE  D_PRD_URL_PHOTO_VUE_UNIQUE
	ON ARTICLE.ID_REF = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_REFERENCE
and ARTICLE.ID_COULEUR = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_COULEUR
and ARTICLE.ID_SAISON = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_SAISON</from><where> AND (RET_LIGNE_RBT.MONTANT_RBT > 0 AND RET_LIGNE_RBT.F_SERVICE IS NULL) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$)</where></query></sourceSet><element defType="com.stambia.json.object" method="POST" id="_zuSwQTSVEe--NK0XcsiGFw" name="e"><element defType="com.stambia.json.object" id="_DJzcDDSWEe--NK0XcsiGFw" required="false" name="requestbody"><element defType="com.stambia.json.object" mediaType="JSON" id="_DJzcDTSWEe--NK0XcsiGFw" contentType="application/json" type="string" name="_DJzcDTSWEe--NK0XcsiGFw"><element defType="com.stambia.json.object" name="root" id="_DJzcEDSWEe--NK0XcsiGFw"><element defType="com.stambia.json.value" name="ctx" id="_DJzcETSWEe--NK0XcsiGFw" position="1"><element defType="com.stambia.json.value" name="client" id="_DJzcEjSWEe--NK0XcsiGFw" position="1"><element defType="com.stambia.json.value" name="login" id="_DJzcEzSWEe--NK0XcsiGFw" position="1" type="string"/><element defType="com.stambia.json.value" name="prenom" id="_DJzcFTSWEe--NK0XcsiGFw" position="2" type="string"/><element defType="com.stambia.json.value" name="nom" id="_DJzcFzSWEe--NK0XcsiGFw" position="3" type="string"/><element defType="com.stambia.json.value" name="civilite" id="_DJzcGTSWEe--NK0XcsiGFw" position="4" type="string"/><element defType="com.stambia.json.value" name="codeclient" id="_DJzcGzSWEe--NK0XcsiGFw" position="5" type="string"/></element><element defType="com.stambia.json.value" name="fidelite" id="_DJzcHTSWEe--NK0XcsiGFw" position="2"><element defType="com.stambia.json.value" name="nbpoints" id="_DJzcHjSWEe--NK0XcsiGFw" position="1" type="decimal"/><element defType="com.stambia.json.value" name="expiration" id="_DJzcIDSWEe--NK0XcsiGFw" position="2" type="string"/><element defType="com.stambia.json.value" name="codecarte" id="_DJzcIjSWEe--NK0XcsiGFw" position="3" type="string"/></element><element defType="com.stambia.json.value" name="commande" id="_DJzcJDSWEe--NK0XcsiGFw" position="3"><element defType="com.stambia.json.value" name="modeRemboursement" id="_DJzcJTSWEe--NK0XcsiGFw" position="1"><element defType="com.stambia.json.value" name="modeRemboursement" id="_DJzcJjSWEe--NK0XcsiGFw" position="1" type="string"/></element><element defType="com.stambia.json.value" name="articles" id="_DJzcKDSWEe--NK0XcsiGFw" position="2"><element defType="com.stambia.json.array" name="article" id="_DJzcKTSWEe--NK0XcsiGFw" position="1"><element defType="com.stambia.json.value" name="e" id="_DJzcKjSWEe--NK0XcsiGFw" position="1"><element defType="com.stambia.json.value" name="coloris" id="_DJzcKzSWEe--NK0XcsiGFw" position="1" type="string"/><element defType="com.stambia.json.value" name="image" id="_DJzcLTSWEe--NK0XcsiGFw" position="2" type="string"/><element defType="com.stambia.json.value" name="prixLigne" id="_DJzcLzSWEe--NK0XcsiGFw" position="3" type="decimal"/><element defType="com.stambia.json.value" name="prixRemise" id="_DJzcMTSWEe--NK0XcsiGFw" position="4" type="decimal"/><element defType="com.stambia.json.value" name="qte" id="_DJzcMzSWEe--NK0XcsiGFw" position="5" type="decimal"/><element defType="com.stambia.json.value" name="reference" id="_DJzcNTSWEe--NK0XcsiGFw" position="6" type="string"/><element defType="com.stambia.json.value" name="taille" id="_DJzcNzSWEe--NK0XcsiGFw" position="7" type="string"/><element defType="com.stambia.json.value" name="description" id="_DJzcOTSWEe--NK0XcsiGFw" position="8" type="string"/></element></element></element><element defType="com.stambia.json.value" name="total" id="_DJzcOzSWEe--NK0XcsiGFw" position="3"><element defType="com.stambia.json.value" name="montantTotal" id="_DJzcPDSWEe--NK0XcsiGFw" position="1" type="decimal"/></element><element defType="com.stambia.json.value" name="numero" id="_DJzcPjSWEe--NK0XcsiGFw" position="4" type="string"/><element defType="com.stambia.json.value" name="date" id="_DJzcQDSWEe--NK0XcsiGFw" position="5" type="string"/><element defType="com.stambia.json.v