ame="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append" id="a7fb0008b66e1a1c939749d45db1ff8e" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL,
	DATEH
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL,
		SRC.DATEH
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		${~/p_id_rbt}$ AS ID_RBT,
		L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L137_LOG_MAIL AS LOG_MAIL,
		sysdate AS DATEH
		from	(
select L137_LOG_MAIL,
	L139_status
from (ETLWORK.L3_RET_MAJ_LOG_0  L3_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L3_RET_MAJ_LOG_1  L3_RET_MAJ_LOG_1
		ON L3_RET_MAJ_LOG_0.stb_key=L3_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L3_RET_MAJ_LOG_2  L3_RET_MAJ_LOG_2
	ON L3_RET_MAJ_LOG_1.stb_key=L3_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L3_RET_MAJ_LOG_2.stb_key is null))  L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO
		where	(1=1) AND (L3_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L139_status = 'OK')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Start" id="d9dd9fb4fe2c33fb2855ce8292da8fd4" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><link id="1233d086b3bb14e1be7413543de31328" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RET_MAJ_LOG-Integration/I4-RET_MAJ_LOG-Integration/Insertion of new rows in target - append" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I4-RE