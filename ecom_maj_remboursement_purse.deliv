maginoMailClientBzb/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Drop of pre-integration table" id="35669b5de1493543ed6355dbcf883fa0" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_MAJ_LOG purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/950 ws ImaginoMailClientBzb/I2-RET_MAJ_LOG-Integration/I2-RET_MAJ_LOG-Integration/Insertion of new rows in target - append" id="a5faef01a21e5210bbab18579aec4f48" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL,
	DATEH
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL,
		SRC.DATEH
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		 ${~/p_id_rbt}$ AS ID_RBT,
		L1_RET_MAJ_LOG_RET_MAJ_LOG_ANO.L24_LOG_MAIL AS LOG_MAIL,
		sysdate AS DATEH
		from	(
select L24_LOG_MAIL,
	L26_status
from (ETLWORK.L1_RET_MAJ_LOG_0  L1_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_1  L1_RET_MAJ_LOG_1
		ON L1_RET_MAJ_LOG_0.stb_key=L1_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L1_RET_MAJ_LOG_2  L1_RET_MAJ_LOG_2
	ON L1_RET_MAJ_LOG_1.stb_key=L1_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L1_RET_MAJ_LOG_2.stb_key is null))  L1_RET_MAJ_LOG_RET_MAJ_LOG_ANO
