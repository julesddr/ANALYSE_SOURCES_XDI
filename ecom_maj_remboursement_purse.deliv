ation/I3-RET_MAJ_LOG_OK-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Integration/Commit of transaction on target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Integration/Start" id="453f564107b2ad5b6a9b6a28b8944555" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I3-RET_MAJ_LOG_OK-Integration/I3-RET_MAJ_LOG_OK-Integration/Insertion of new rows in target - append" id="dfdd153b1d800f44fcacd414dbcd175f" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	LOG_TICKET,
	DATEH
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_PAIEMENT,
		SRC.LOG_TICKET,
		SRC.DATEH
from (
		select 
			S2_stage_refund_response_rank.L45_id_cde AS ID_CDE,
		S2_stage_refund_response_rank.L46_id_rbt AS ID_RBT,
		'OK-'|| S2_stage_refund_response_rank.L44_partner_status_description AS LOG_PAIEMENT,
		S2_stage_refund_response_rank.L42_partner_amount AS LOG_TICKET,
		SYSDATE AS DATEH
		from	ETLWORK.S2_1g9klfhlwte0i_stage_refund_  S2_stage_refund_response_rank
	INNER JOIN ECOMM.MODES_REGL_ECOMM_PAYS  MODES_REGL_ECOMM_PAYS
	ON S2_stage_refund_response_rank.L41_partner||S2_stage_refund_response_rank.L48_method = MODES_REGL_ECOMM_PAYS.CODEPAYZEN
		where	(1=1) AND (S2_stage_refund_response_rank.L49_merchant_reference = '${~/p_id_cde}$' || '-' || '${~/p_id_rbt}$') AND (MODES_REGL_ECOMM_PAYS.CODEPAYS = '${~/p_pays}$') AND (S2_stage_refund_response_rank.L47_refund_status = 'SUCCESS' OR (S2_stage_refund_response_rank.L47_refund_status = 'PENDING' AND S2_stage_refund_response_rank.L43_partner_status = 'AUTHORISED'))
		
	) SRC
