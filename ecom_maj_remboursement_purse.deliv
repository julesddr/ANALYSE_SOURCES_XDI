_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Commit of transaction on target/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Commit of transaction on target/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Commit of transaction on target/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="COMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Start" id="7b8193145ca429dd9824cb9d45825e6e" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Drop of pre-integration table" id="89a10474d198d1b3b8fbe722f6722f9d" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_MAJ_LOG purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Drop of pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Drop of pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Drop of pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append" id="d8417394afc602c1c45df536594b4f29" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_PAIEMENT,
	LOG_TICKET,
	DATEH,
	ERROR_CODE,
	ERROR_MESSAGE
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_PAIEMENT,
		SRC.LOG_TICKET,
		SRC.DATEH,
		SRC.ERROR_CODE,
		SRC.ERROR_MESSAGE
from (
		select 
			S2_stage_refund_response_rank.L45_id_cde AS ID_CDE,
		S2_stage_refund_response_rank.L46_id_rbt AS ID_RBT,
		'KO-'|| S2_stage_refund_response_rank.L44_partner_status_description AS LOG_PAIEMENT,
		S2_stage_refund_response_rank.L39_amount AS LOG_TICKET,
		SYSDATE AS DATEH,
		S2_stage_refund_response_rank.L40_status AS ERROR_CODE,
		S2_stage_refund_response_rank.L44_partner_status_description AS ERROR_MESSAGE
		from	ETLWORK.S2_1g9klfhlwte0i_stage_refund_  S2_stage_refund_response_rank
	INNER JOIN ECOMM.MODES_REGL_ECOMM_PAYS  MODES_REGL_ECOMM_PAYS
	ON S2_stage_refund_response_rank.L41_partner||S2_stage_refund_response_rank.L48_method = MODES_REGL_ECOMM_PAYS.CODEPAYZEN
		where	(1=1) AND (S2_stage_refund_response_rank.L49_merchant_reference = '${~/p_id_cde}$' || '-' || '${~/p_id_rbt}$') AND (MODES_REGL_ECOMM_PAYS.CODEPAYS = '${~/p_pays}$') AND (S2_stage_refund_response_rank.L47_refund_status = 'FAILURE' OR (S2_stage_refund_response_rank.L47_refund_status = 'PENDING' AND S2_stage_refund_response_rank.L43_partner_status <> 'AUTHORISED') OR S2_stage_refund_response_rank.L47_refund_status = 'CONFLICT')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><link id="02d95b9755f2ca812866b5662efb97e9" mandatory="1" sourceName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Commit of transaction on target" targetName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Drop of pre-integration table" type="OK"/><link id="57093da7dc06c33b4e657d2365eb30ce" mandatory="1" sourceName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Start" targetName="ecom_maj_remboursement_purse/150 refund purse/I2-RET_MAJ_LOG_KO-Integration/I2-RET_MAJ_LOG_KO-Integration/Insertion of new rows