ment_purse/150 refund purse/S2-stage_refund_response_rank-Staging/Analyze" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Cleanup" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Cleanup/Drop table staging" id="e6cd002dc8699d6a11051480ee6337d5" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Drop table ETLWORK.stage_reglement_rbt_agr purge]]><altId origin="compilation" value="_8zSzYdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Cleanup/Drop table staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Cleanup/Drop table staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Cleanup/Drop table staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step></process><process actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Creation of staging" id="0da8632223935bbb688eea4e55a4360b" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Create table ETLWORK.stage_reglement_rbt_agr
NOLOGGING
AS




select	  
	'${~/P_ACCESS_TOKEN}$' AS L1_Authorization,
	RET_REGLEMENT_RBT.ID_CDE AS L2_POST,
	sum(RET_REGLEMENT_RBT.MONTANT_RGT) AS L3_amount,
	STAGE_SALE_ORIGIN.F3_PAYMENT_ID AS L4_Payment_id
	
from	ECOMM.STAGE_SALE_ORIGIN  STAGE_SALE_ORIGIN
	INNER JOIN (ECOMM.CDE  CDE
		INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
		ON CDE.ID_CDE = RET_REGLEMENT_RBT.ID_CDE)
	ON STAGE_SALE_ORIGIN.STORE_ID = CDE.ID_ENTITE_ECOMM
and STAGE_SALE_ORIGIN.ORDER_NO = CDE.ID_TICKET
where	(1=1) AND (RET_REGLEMENT_RBT.ID_CDE = '${~/p_id_cde}$' AND RET_REGLEMENT_RBT.ID_RBT = ${~/p_id_rbt}$) AND (CDE.ID_CDE = '${~/p_id_cde}$')
group by '${~/P_ACCESS_TOKEN}$', RET_REGLEMENT_RBT.ID_CDE, STAGE_SALE_ORIGIN.F3_PAYMENT_ID



]]><altId origin="compilation" value="_8zSzSdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Drop view staging" id="4dc5dd8e064b43552127a2d67b049aa0" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[Drop view ETLWORK.stage_reglement_rbt_agr]]><altId origin="compilation" value="_8zSzVdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Drop view staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Drop view staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Drop view staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/S3-stage_reglement_rbt_agr-Staging/Analyze" id="72355d4058ca26eab7afc01431b2f168" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError