e="transactionalModeOnWorkTables" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/truncateTargetTable" output="false" type="Boolean" vName="truncateTargetTable" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/unlockCdcTable" output="false" type="Boolean" vName="unlockCdcTable" value="true"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/useDistinct" output="false" type="Boolean" vName="useDistinct" value="false"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/uselessUpdateDetectionMethod" output="false" type="String" vName="uselessUpdateDetectionMethod" value="minus"/></step><link id="4143a83d8c157a3e3cffd57f7d0dc609" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Prepare" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append" id="4905146e64e70bbd1318246050c0768b" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[insert  into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		${~/p_id_rbt}$ AS ID_RBT,
		L2_RET_MAJ_LOG_ANO_BE_NL_RET_M.L143_LOG_MAIL AS LOG_MAIL
		from	(
select L143_LOG_MAIL,
	L145_status
from (ETLWORK.L2_RET_MAJ_LOG_0  L2_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L2_RET_MAJ_LOG_1  L2_RET_MAJ_LOG_1
		ON L2_RET_MAJ_LOG_0.stb_key=L2_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L2_RET_MAJ_LOG_2  L2_RET_MAJ_LOG_2
	ON L2_RET_MAJ_LOG_1.stb_key=L2_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L2_RET_MAJ_LOG_2.stb_key is null))  L2_RET_MAJ_LOG_ANO_BE_NL_RET_M
		where	(1=1) AND (L2_RET_MAJ_LOG_ANO_BE_NL_RET_M.L145_status <> 'OK')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/I7-RET_MAJ_LOG_ANO_BE_NL-Integration/Drop of pre-integration table" id="5660c1e2dbcb8de925595ba51744ae8a" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[drop table ETLWORK.I_RET_MAJ_LOG purge]]><altId origin="compilation" value="_jkWgu1EJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I7-RET_MAJ_LOG_ANO_BE_NL-Integrati