<parameter name="../MAIL" type="String">
select case substr('${~/p_id_cde}$',10,5) 
when '00600' then 'e-shopping@Jules.fr' 
when '01601' then 'e-shopping@Jules.fr'
when '02600' then 'contact-clients@bizzbee.fr'
when '03600' then 'serviceclientsbrice@brice.fr' 
when '03651' then 'serviceclientsbrice@brice.fr'
else 'e-shopping@Jules.fr'
end
from dual 
</parameter>
</sqlToParameters>]]><altId origin="compilation" value="_y-AKQHSqEeiJQNbqcdZmww"/><parameter name="ecom_maj_remboursement_purse/Mail/SQL_CONNECTION" type="STRING" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/Mail/SQL_SCHEMA_NAME" type="STRING" vName="SQL_SCHEMA_NAME" value="ECOMM"/></step><step actionName="ecom_maj_remboursement_purse/MAJ LCDE BZB" id="630a2ded7aed36895aeb73a70c6d1242" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.LCDE 
