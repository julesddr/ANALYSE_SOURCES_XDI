 into	ECOMM.RET_MAJ_LOG
( 
	
	ID_CDE,
	ID_RBT,
	LOG_MAIL
) 
select	  
		
		SRC.ID_CDE,
		SRC.ID_RBT,
		SRC.LOG_MAIL
from (
		select 
			${~/p_id_cde}$ AS ID_CDE,
		${~/p_id_rbt}$ AS ID_RBT,
		L2_RET_MAJ_LOG_ANO_BE_NL_RET_M.L144_LOG_MAIL AS LOG_MAIL
		from	(
select L144_LOG_MAIL,
	L145_status
from (ETLWORK.L2_RET_MAJ_LOG_0  L2_RET_MAJ_LOG_0
		LEFT OUTER JOIN ETLWORK.L2_RET_MAJ_LOG_1  L2_RET_MAJ_LOG_1
		ON L2_RET_MAJ_LOG_0.stb_key=L2_RET_MAJ_LOG_1.stb_parentKey)
	LEFT OUTER JOIN ETLWORK.L2_RET_MAJ_LOG_2  L2_RET_MAJ_LOG_2
	ON L2_RET_MAJ_LOG_1.stb_key=L2_RET_MAJ_LOG_2.stb_parentKey
where (1=1)
and not(
	L2_RET_MAJ_LOG_2.stb_key is null))  L2_RET_MAJ_LOG_ANO_BE_NL_RET_M
		where	(1=1) AND (L2_RET_MAJ_LOG_ANO_BE_NL_RET_M.L145_status = 'OK')
		
	) SRC
]]><altId origin="compilation" value="_jkWgzVEJEeO7Vo9WeM2sCg"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Insertion of new rows in target - append/SQL_ACTION_TYPE_STAT" type="String" vName="SQL_ACTION_TYPE_STAT" value="INSERT"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Insertion of new rows in target - append/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_NAME" type="String" vName="SQL_TRANSACTION_NAME" value="T1"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Insertion of new rows in target - append/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="NOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Start" id="4c41d3e92658e1d4c87b391ec93d0edb" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.EmptyActionCodeI" toleratedError="false" type="Code"><altId origin="compilation" value="_jkWgx1EJEeO7Vo9WeM2sCg"/></step><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/I9-RET_MAJ_LOG_BE_NL-Integration/I9-RET_MAJ_LOG_BE_NL-Integration/Commit of transaction on target" id="5686501f92807b78c3135409f6ac33ae" isBeginAct