where	(1=1) AND (RET_COUPON_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_COUPON_RBT.ID_RBT = ${~/p_id_rbt}$)]]><altId origin="compilation" value="_0wMFUmiQEeiKycjOxudrjg"/><parameter name="ecom_maj_remboursement_purse/890 DB Coupon/L1-COUPON-Load/For simple table/Select on source table (SRC)/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="SELECT"/><parameter name="ecom_maj_remboursement_purse/890 DB Coupon/L1-COUPON-Load/For simple table/Select on source table (SRC)/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/></step><link bindType="DirectBind" id="4cabdba5c8f46392a56bf2e6b789c0ba" mandatory="1" sourceName="ecom_maj_remboursement_purse/890 DB Coupon/L1-COUPON-Load/For simple table/Select on source table (SRC)" targetName="ecom_maj_remboursement_purse/890 DB Coupon/L1-COUPON-Load/For simple table/Load of data (TRG)" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Cleanup" id="365e97406eec23dfdb71ee03515b677e" isBeginAction="false" nbCycles="1" restartPoint="default" toleratedError="false" type="Process"><altId origin="compilation" value="_ZDVoYINBEfCAFcYVV-VnVg-proc4_S2"/><altId origin="processRef" value="_YizOwK7sEeqGH6AaH3PDiA"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Cleanup/lockCdcTable" output="false" type="Boolean" vName="lockCdcTable" value="true"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Cleanup/unlockCdcTable" output="false" type="Boolean" vName="unlockCdcTable" value="true"/><parameter fault="false" input="false" name="ecom_maj_remboursement_purse/891_Maxxing_maj_avantage_fidelite_BZB/S2-stage-Cleanup/useDistinct" output="false" type="Boolean" vName="useDistin