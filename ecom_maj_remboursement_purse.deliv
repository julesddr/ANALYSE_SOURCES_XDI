]]><altId origin="compilation" value="8c55021f-2a6e-4cd8-baf5-8ffb4d614646"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of Index on pre-integration table/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of Index on pre-integration table/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Creation of Index on pre-integration table/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><step actionName="ecom_maj_remboursement_purse/150 refund purse/I4-RET_REGLEMENT_RBT_2-Integration/I4-RET_REGLEMENT_RBT_2-Prepare/Analyze of pre-integration table (DBMS_STATS.GATHER_TABLE_STATS method)" id="3be7821eb288a89535f5b4f351c27f99" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="true" type="Code"><![CDATA[BEGIN 
