AS




select	  DISTINCT 
	case when RET_RBT.TYPE_RETOUR = 'manquant' 
then RET_RBT.TYPE_RETOUR 
when RET_RBT.TYPE_RETOUR = 'remiseEnStock'
then RET_RBT.TYPE_RETOUR 
else 'retour'
end  AS L1_motifRemboursement,
	ARTICLE.LIB_PRODUIT AS L2_description,
	RET_RBT.MNT_RBT AS L3_montantTotal,
	ARTICLE.ID_COULEUR AS L4_coloris,
	RET_LIGNE_RBT.CODE_EAN AS L5_reference,
	RET_RBT.DATE_EXPI_FID AS L6_expiration,
	D_PRD_URL_PHOTO_VUE_UNIQUE.URL_EXTERNE_FULL AS L7_image,
	TAILLE.LIB_TAILLE AS L8_taille,
	CDE.EMAIL AS L9_login,
	RET_RBT.NB_PT_GLOB AS L10_nbpoints,
	CDE.FAC_CIVILITE AS L11_civilite,
	substr(RET_RBT.ID_CDE,1,9) AS L12_numero,
	case 
when RET_REGLEMENT_RBT.CODE_RGT in (3,26)
then RET_REGLEMENT_RBT.LIB_RGT
else 'Carte Cadeau'
end AS L13_modeRemboursement,
	'${~/P_X_API_KEY_IMAGINO}$' AS L14_X_API_KEY,
	RET_RBT.CARTE_FID AS L15_codecarte,
	RET_LIGNE_RBT.MONTANT_RBT AS L16_prixRemise,
	1 AS L17_qte,
	RET_RBT.ID_CDE AS L18_POST,
	ARTICLE.LIB_COMM AS L19_article,
	CDE.FAC_PRENOM AS L20_prenom,
	CDE.DATH_CDE AS L21_date,
	CDE.FAC_NOM AS L22_nom
	
from	(((((((ECOMM.RET_RBT  RET_RBT
								INNER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT
								ON RET_RBT.ID_CDE = RET_LIGNE_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT.ID_RBT)
							INNER JOIN ECOMM.RET_REGLEMENT_RBT  RET_REGLEMENT_RBT
							ON RET_RBT.ID_CDE = RET_REGLEMENT_RBT.ID_CDE
and RET_RBT.ID_RBT = RET_REGLEMENT_RBT.ID_RBT)
						INNER JOIN ECOMM.CDE  CDE
						ON RET_RBT.ID_CDE = CDE.ID_CDE)
					LEFT OUTER JOIN ECOMM.ARTICLE  ARTICLE
					ON RET_LIGNE_RBT.CODE_EAN = ARTICLE.ID_ARTICLE_INT)
				LEFT OUTER JOIN ECOMM.TAILLE  TAILLE
				ON ARTICLE.ID_GRILLE_TAILLE = TAILLE.ID_GRILLE_TAILLE
and ARTICLE.ID_TAILLE = TAILLE.ID_TAILLE)
			LEFT OUTER JOIN ECOMM.RET_LIGNE_RBT  RET_LIGNE_RBT_2
			ON RET_RBT.ID_CDE = RET_LIGNE_RBT_2.ID_CDE
and RET_RBT.ID_RBT = RET_LIGNE_RBT_2.ID_RBT
and RET_LIGNE_RBT_2.F_SERVICE = 'O' )
		LEFT OUTER JOIN ECOMM.SERVICES_ECOMM  SERVICES_ECOMM
		ON RET_LIGNE_RBT_2.CODE_EAN = SERVICES_ECOMM.ID_ARTICLE_INT
and SERVICES_ECOMM.ID_MODE_LIVRAISON is not null 
and RET_LIGNE_RBT_2.MONTANT_RBT > 0)
	LEFT OUTER JOIN ECOMM.D_PRD_URL_PHOTO_VUE_UNIQUE  D_PRD_URL_PHOTO_VUE_UNIQUE
	ON ARTICLE.ID_REF = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_REFERENCE
and ARTICLE.ID_COULEUR = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_COULEUR
and ARTICLE.ID_SAISON = D_PRD_URL_PHOTO_VUE_UNIQUE.ID_SAISON
where	(1=1) AND (RET_LIGNE_RBT.MONTANT_RBT > 0 AND RET_LIGNE_RBT.F_SERVICE IS NULL) AND (RET_RBT.ID_CDE = ${~/p_id_cde}$ AND RET_RBT.ID_RBT = ${~/p_id_rbt}$) AND (CDE.ID_ENTITE_ECOMM = 600)



]]><altId origin="compilation" value="_8zSzSdu8EeWIdu0rdnx7VQ"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Creation of staging/SQL_ACTION_TYPE" type="String" vName="SQL_ACTION_TYPE" value="DDL_DML"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Creation of staging/SQL_CONNECTION" type="String" vName="SQL_CONNECTION" value="ora_ecomm_art_ref(_jMVp0Nk3Ee2_W6r6SMVqFA)"/><parameter name="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Creation of staging/SQL_TRANSACTION_TYPE" type="String" vName="SQL_TRANSACTION_TYPE" value="AUTOCOMMIT"/></step><link id="1fd88cc840edbed4f108fa4f11841b4d" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Drop table stagging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Creation of staging" type="OK"/><link id="443147fa0ebdffef5bafafde1770d4c3" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Creation of staging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Analyze" type="OK"/><link id="f66f3bf64752fd263114d9e8c94d1f11" mandatory="1" sourceName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Drop view staging" targetName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S1-stage_jules-Staging/Drop table stagging" type="OK"/></process><process actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S2-stage_jules_be_fr-Cleanup" isBeginProcess="false"><step actionName="ecom_maj_remboursement_purse/900 ws ImaginoMailClient/S2-stage_jules_be_fr-Cleanup/Drop table staging" id="e648f5b25f4e6e974e616fd940fdb362" isBeginAction="true" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[Drop table ETLWO