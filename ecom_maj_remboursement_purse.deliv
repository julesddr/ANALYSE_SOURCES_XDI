ameter name="ecom_maj_remboursement_purse/MailRemboursementKO/MAIL_USE_SSL" type="STRING" vName="MAIL_USE_SSL" value="false"/></step><step actionName="ecom_maj_remboursement_purse/Remboursement0" id="1235d0209932468b743c84e56627cdb9" isBeginAction="false" nbCycles="-1" restartPoint="default" technology="com.indy.engine.actionCodes.JdbcActionCodeI" toleratedError="false" type="Code"><![CDATA[update ECOMM.LCDE 
