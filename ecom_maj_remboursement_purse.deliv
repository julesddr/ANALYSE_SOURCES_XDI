	L1_stage_refund_reponse.L19_partner_status AS L29_partner_status,
	L1_stage_refund_reponse.L20_partner_status_description AS L30_partner_status_description,
	L1_stage_refund_reponse.L21_status AS L31_refund_status,
	 '${~/p_id_cde}$'  AS L32_id_cde,
	${~/p_id_rbt}$  AS L33_id_rbt,
	L1_stage_refund_reponse.L17_method AS L34_method,
	L1_stage_refund_reponse.L14_merchant_reference AS L35_merchant_reference
	
from	(
select L10_id,
	L11_created_at,
	L12_updated_at,
	L13_amount,
	L14_merchant_reference,
	L15_status,
	L16_partner,
	L17_method,
	L18_amount,
	L19_partner_status,
	L20_partner_status_description,
	L21_status
from (((ETLWORK.L1_1g9klfhlwte0i_0  L1_1g9klfhlwte0i_0
				LEFT OUTER JOIN ETLWORK.L1_1g9klfhlwte0i_1  L1_1g9klfhlwte0i_1
