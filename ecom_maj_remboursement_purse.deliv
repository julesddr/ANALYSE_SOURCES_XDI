nCodeI" toleratedError="false" type="Code"><![CDATA[update	  ECOMM.RET_RBT T 
set


 (  T.NB_PT_GLOB,
		T.CARTE_FID,
		T.DATE_EXPI_FID
             
       ) = 
             (
             select S.NB_PT_GLOB,
				S.CARTE_FID,
