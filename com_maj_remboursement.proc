    <parameter id="_oU2LUhJgEfGpb7QiJEquyg" name="MAIL_TEXT" type="String" value="Bonjour, &#xD;&#xA;&#xD;&#xA;Erreur dans le retour du WS Payzen (Find) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;Cordialement,&#xD;&#xA;Informatique Commerce "/>
