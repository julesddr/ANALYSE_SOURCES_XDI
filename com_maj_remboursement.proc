    <metaDataLink id="_oU2K6RJgEfGpb7QiJEquyg" name="W_RBT_PAYZEN" target="resource.md#_IVXP4BIzEfGcctThXQHQEw?fileId=_JKWSgPwJEe6-gJSJ1VYtiA$type=md$name=W_RBT_PAYZEN?"/>
    <parameter id="_oU2K6hJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_PMTOK&quot; type=&quot;Integer&quot;>&#xD;
select &#xD;
count(*) &#xD;
from %x{$W_RBT_PAYZEN/tech:physicalPath()}x% &#xD;
where ID_CDE = '${~/p_id_cde}$'&#xD;
and ID_RBT = ${~/p_id_rbt}$&#xD;
