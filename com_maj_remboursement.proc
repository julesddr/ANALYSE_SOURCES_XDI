    <parameter id="_oU2LMRJgEfGpb7QiJEquyg" name="SQL_MULTI_QUERYS" type="Boolean" value="true"/>
    <code>delete from w_rbt where session_id = '${/CORE_SESSION_ID}$' ; &#xD;
delete from w_rbt_prepa_rgt where session_id = '${/CORE_SESSION_ID}$' ; &#xD;
&#xD;
commit ; </code>
  </actionCode>
