  <actionCode id="_oU2LfBJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="MailPayzen2KO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.SendMailActionCodeI">
    <metaDataLink id="_oU2LfRJgEfGpb7QiJEquyg" name="SMTP" target="resource.md#_yFg9cnSCEe2wENHQ1zUjoA?fileId=_xvXuUHSCEe2wENHQ1zUjoA$type=md$name=SMTP?"/>
    <parameter id="_oU2LfhJgEfGpb7QiJEquyg" name="MAIL_FROM" type="String" value="stambia@happychicgroup.com"/>
    <parameter id="_oU2LfxJgEfGpb7QiJEquyg" name="MAIL_HOSTNAME" type="String"/>
    <parameter id="_oU2LgBJgEfGpb7QiJEquyg" name="MAIL_TO" type="String" value="${~/mail_info}$"/>
    <parameter id="_oU2LgRJgEfGpb7QiJEquyg" name="MAIL_SUBJECT" type="String" value="Maj remboursement - Erreur WS Payzen "/>
    <parameter id="_oU2LghJgEfGpb7QiJEquyg" name="MAIL_TEXT" type="String" value="Bonjour, &#xD;&#xA;&#xD;&#xA;Erreur dans le retour du WS Payzen (Detail) pour la commande : ${~/p_id_cde}$  et le remboursement : ${~/p_id_rbt}$&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;Cordialement,&#xD;&#xA;Informatique Commerce "/>
  </actionCode>
  <actionCode id="_oU2LgxJgEfGpb7QiJEquyg" isBeginAction="false" name="DetailTrouvé" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LhBJgEfGpb7QiJEquyg" executionCondition="${P_DETAIL}$ == 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K6xJgEfGpb7QiJEquyg"/>
    <link id="_oU2LhRJgEfGpb7QiJEquyg" executionCondition="${P_DETAIL}$ != 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LfBJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LhhJgEfGpb7QiJEquyg" name="W_RBT_PAYZEN" target="resource.md#_IVXP4BIzEfGcctThXQHQEw?fileId=_JKWSgPwJEe6-gJSJ1VYtiA$type=md$name=W_RBT_PAYZEN?"/>
    <parameter id="_oU2LhxJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_DETAIL&quot; type=&quot;Integer&quot;>&#xD;
select count(*) &#xD;
from %x{$W_RBT_PAYZEN/tech:physicalPath()}x% DET&#xD;
where DET.id_cde = '${~/p_id_cde}$'&#xD;
and DET.id_rbt = ${~/p_id_rbt}$&#xD;
and DET.type_pmt = 'DEBIT'&#xD;
and DET.mode_pmt in ('CB','PAYPAL','CARD','ALMA')&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters>&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LiBJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="INSERT RET_RBT MKP" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
