  <actionCode id="_oU2LUxJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Statut Erreur sur RET_RBT" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <metaDataLink id="1fb63b0a-b3a5-4722-8eed-6778351262bd" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <parameter id="_oU2LVRJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2LVhJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>update %x{$RET_RBT/tech:physicalPath()}x% &#xD;
