  <actionCode id="_oU1jyhJgEfGpb7QiJEquyg" isBeginAction="false" name="Type_Rbt" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU1jyxJgEfGpb7QiJEquyg" executionCondition="${P_TYPE}$ != 0" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K0BJgEfGpb7QiJEquyg"/>
    <link id="_oU1jzBJgEfGpb7QiJEquyg" executionCondition="${P_TYPE}$ == 0" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K0hJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU1jzRJgEfGpb7QiJEquyg" name="RET_LIGNE_RBT" target="resource.md#_CU4dIPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_LIGNE_RBT?"/>
    <parameter id="_oU1jzhJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_TYPE&quot; type=&quot;Integer&quot;>&#xD;
select COALESCE(count(1),0)&#xD;
from %x{$RET_LIGNE_RBT/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
and id_rbt = ${~/p_id_rbt}$ &#xD;
and montant_rbt_force is not null &#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
