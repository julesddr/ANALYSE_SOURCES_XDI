    <metaDataLink id="_oU2LixJgEfGpb7QiJEquyg" name="RET_RBT_MKP" target="resource.md#_DaLRQPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT_MKP?"/>
    <parameter id="_oU2LjBJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2LjRJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>INSERT INTO %x{$RET_RBT_MKP/tech:physicalPath()}x%&#xD;
SELECT * from   %x{$RET_RBT/tech:physicalPath()}x%&#xD;
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ and statut = 'REMBOK'&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LjhJgEfGpb7QiJEquyg" isBeginAction="false" name="IS_MKP" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LjxJgEfGpb7QiJEquyg" executionCondition="${P_MKP}$ == 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LiBJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LkBJgEfGpb7QiJEquyg" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <parameter id="_oU2LkRJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_MKP&quot; type=&quot;Integer&quot;>&#xD;
select count(1)&#xD;
from %x{$CDE/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
and id_cde_ext is not null&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters>&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LkhJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="DELETE  RET_RBT" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
