  </actionCode>
  <actionCode id="_oU2LXhJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="MailStorelandKO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.SendMailActionCodeI">
    <link id="_oU2LXxJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2LUxJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LYBJgEfGpb7QiJEquyg" name="SMTP" target="resource.md#_yFg9cnSCEe2wENHQ1zUjoA?fileId=_xvXuUHSCEe2wENHQ1zUjoA$type=md$name=SMTP?"/>
    <parameter id="_oU2LYRJgEfGpb7QiJEquyg" name="MAIL_FROM" type="String" value="stambia@happychicgroup.com"/>
    <parameter id="_oU2LYhJgEfGpb7QiJEquyg" name="MAIL_HOSTNAME" type="String"/>
    <parameter id="_oU2LYxJgEfGpb7QiJEquyg" name="MAIL_TO" type="String" value="${~/mail_info}$"/>
