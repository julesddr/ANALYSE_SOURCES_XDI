  <actionCode id="_oU2K7RJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="REMBKOB" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <metaDataLink id="_oU2K7hJgEfGpb7QiJEquyg" name="LCDE" target="resource.md#_4uA50Q6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=LCDE?"/>
    <metaDataLink id="_oU2K7xJgEfGpb7QiJEquyg" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <parameter id="_oU2K8BJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2K8RJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <parameter id="_oU2K8hJgEfGpb7QiJEquyg" name="SQL_MULTI_QUERYS" type="Boolean" value="true"/>
    <code>update %x{$LCDE/tech:physicalPath()}x% &#xD;
set statut_lcde = 'REMBKOB' , dath_s_rembkob = sysdate, dath_maj = sysdate&#xD;
where id_cde = '${~/p_id_cde}$' and statut_lcde = 'DEMREMB';&#xD;
update %x{$RET_RBT/tech:physicalPath()}x% &#xD;
set statut = 'REMBKOB' &#xD;
where id_cde = '${~/p_id_cde}$' and id_rbt =  ${~/p_id_rbt}$ ;</code>
  </actionCode>
  <actionCode id="_oU2K8xJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Remboursement_payzen_effectué" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2K9BJgEfGpb7QiJEquyg" executionCondition="${P_PMTBOK}$ == 0" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2K7RJgEfGpb7QiJEquyg"/>
    <link id="_oU2K9RJgEfGpb7QiJEquyg" executionCondition="${P_PMTBOK}$ == 1" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2K-BJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2K9hJgEfGpb7QiJEquyg" name="RET_MAJ_LOG" target="resource.md#_DpuJIPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_MAJ_LOG?"/>
    <parameter id="_oU2K9xJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_PMTBOK&quot; type=&quot;Integer&quot;>&#xD;
select &#xD;
case when LOG_PAIEMENT like 'OK%'&#xD;
then 1&#xD;
else 0 end&#xD;
from %x{$RET_MAJ_LOG/tech:physicalPath()}x% &#xD;
where ID_CDE = '${~/p_id_cde}$'&#xD;
and ID_RBT = ${~/p_id_rbt}$&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters>&#xD;
</code>
  </actionCode>
