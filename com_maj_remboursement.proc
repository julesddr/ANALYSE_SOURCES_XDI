  <actionCode id="_oU2LZhJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="MAJ LCDE" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <link id="_oU2LZxJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K3hJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LaBJgEfGpb7QiJEquyg" name="LCDE" target="resource.md#_4uA50Q6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=LCDE?"/>
    <metaDataLink id="_oU2LaRJgEfGpb7QiJEquyg" name="RET_LIGNE_RBT" target="resource.md#_CU4dIPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_LIGNE_RBT?"/>
    <metaDataLink id="_oU2LahJgEfGpb7QiJEquyg" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <parameter id="_oU2LaxJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2LbBJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>update %x{$LCDE/tech:physicalPath()}x% &#xD;
set statut_lcde = 'REMBOK' , dath_s_rembok = sysdate, dath_maj = sysdate&#xD;
where id_cde||'-'||id_lcde  &#xD;
in (select id_cde||'-'||id_lcde from %x{$RET_LIGNE_RBT/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
 and id_rbt = ${~/p_id_rbt}$) </code>
  </actionCode>
  <actionCode id="_oU2LbRJgEfGpb7QiJEquyg" isBeginAction="false" name="SqlOperation" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <bindLink id="_oU2LbhJgEfGpb7QiJEquyg" bindType="DirectBind" targetId="_oU2LchJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LbxJgEfGpb7QiJEquyg" name="W_RBT_PAYZEN" target="resource.md#_IVXP4BIzEfGcctThXQHQEw?fileId=_JKWSgPwJEe6-gJSJ1VYtiA$type=md$name=W_RBT_PAYZEN?"/>
    <parameter id="_oU2LcBJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="SELECT"/>
    <parameter id="_oU2LcRJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>select UUID, id_cde, id_rbt, to_number(substr(id_cde,10,5)) as entite&#xD;
from %x{$W_RBT_PAYZEN/tech:physicalPath()}x% &#xD;
where ID_CDE = '${~/p_id_cde}$' and ID_RBT = ${~/p_id_rbt}$&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LchJgEfGpb7QiJEquyg" isBeginAction="false" name="ExecuteDelivery" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.ExecDeliveryActionCodeI">
