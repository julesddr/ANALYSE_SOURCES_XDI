  <actionCode id="_oU2K-xJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="SendEmailKDO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.SendMailActionCodeI">
    <link id="_oU2K_BJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2LlhJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2K_RJgEfGpb7QiJEquyg" name="SMTP" target="resource.md#_yFg9cnSCEe2wENHQ1zUjoA?fileId=_xvXuUHSCEe2wENHQ1zUjoA$type=md$name=SMTP?"/>
    <parameter id="_oU2K_hJgEfGpb7QiJEquyg" name="MAIL_FROM" type="String" value="stambia@happychicgroup.com"/>
    <parameter id="_oU2K_xJgEfGpb7QiJEquyg" name="MAIL_HOSTNAME" type="String"/>
    <parameter id="_oU2LABJgEfGpb7QiJEquyg" name="MAIL_TO" type="String" value="e-shopping@Jules.fr"/>
    <parameter id="_oU2LARJgEfGpb7QiJEquyg" name="MAIL_SUBJECT" type="String" value="Génération carte KDO suite Remboursement Commande ${~/p_id_cde}$"/>
    <parameter id="_oU2LAhJgEfGpb7QiJEquyg" name="MAIL_TEXT" type="String" value="Bonjour, &#xD;&#xA;&#xD;&#xA;Suite à un retour commande, une carte cadeau est à générer. &#xD;&#xA;&#xD;&#xA;Carte cadeau d'un montant de : ${~/P_MONTANTKDO}$ € pour l'enseigne : ${~/P_ENSEIGNE}$&#xD;&#xA;&#xD;&#xA;Pour le client : ${~/P_NUMCLIENT}$ - ${~/P_NOMCLIENT}$&#xD;&#xA;&#xD;&#xA;Mail : ${~/P_MAILCLIENT}$&#xD;&#xA;&#xD;&#xA;Adresse postale : ${~/P_ADRCLIENT}$ &#xD;&#xA;&#xD;&#xA;&#xD;&#xA;Le ticket retour a été créé dans Storeland, pas besoin de prévenir la comptabilité de ce remboursement. &#xD;&#xA;&#xD;&#xA;Cordialement,&#xD;&#xA;Informatique Commerce "/>
  </actionCode>
  <actionCode id="_oU2LAxJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Donnees_KDO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LBBJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LCBJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LBRJgEfGpb7QiJEquyg" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <metaDataLink id="_oU2LBhJgEfGpb7QiJEquyg" name="RET_REGLEMENT_RBT" target="resource.md#_D4zuAPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_REGLEMENT_RBT?"/>
    <parameter id="_oU2LBxJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_MONTANTKDO&quot; type=&quot;Integer&quot;>&#xD;
select sum(MONTANT_RGT)&#xD;
from %x{$RET_REGLEMENT_RBT/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
and id_rbt = ${~/p_id_rbt}$ &#xD;
and CODE_RGT in (21,27,28)&#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_NUMCLIENT&quot; type=&quot;String&quot;>&#xD;
select ID_CLIENT&#xD;
from %x{$CDE/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LCBJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Sql To Parameters" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LCRJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K-xJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LChJgEfGpb7QiJEquyg" name="ADRESSES_CLIENT" target="resource.md#_TH4rAQ56Ee6JfbycoN1ybw?fileId=_qEADsOREEe2fFdVtOVmeEg$type=md$name=ADRESSES_CLIENT?"/>
    <metaDataLink id="_oU2LCxJgEfGpb7QiJEquyg" name="CLIENTS" target="resource.md#_5SjPsAuPEe6QKKTV4UFFxw?fileId=_qEADsOREEe2fFdVtOVmeEg$type=md$name=CLIENTS?"/>
    <parameter id="_oU2LDBJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_NOMCLIENT&quot; type=&quot;String&quot;>&#xD;
select nvl(NOM||' - '||PRENOM,'-')&#xD;
from %x{$CLIENTS/tech:physicalPath()}x% &#xD;
where CODECLIENT = '${~/P_NUMCLIENT}$' &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_MAILCLIENT&quot; type=&quot;String&quot;>&#xD;
select nvl(EMAIL,'-')&#xD;
from %x{$CLIENTS/tech:physicalPath()}x% &#xD;
where CODECLIENT = '${~/P_NUMCLIENT}$'&#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_ADRCLIENT&quot; type=&quot;String&quot;>&#xD;
select nvl(COMPLEMENTADRESSE||' - '||LIBELLEVOIE||' - '||CODEPOSTAL||' - '||VILLE||' - '||CODEPAYS,'-')&#xD;
from %x{$ADRESSES_CLIENT/tech:physicalPath()}x% &#xD;
where CODEADRESSECLIENT = (select CODEADRESSECLIENT&#xD;
from %x{$CLIENTS/tech:physicalPath()}x% &#xD;
where CODECLIENT = '${~/P_NUMCLIENT}$')&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LDRJgEfGpb7QiJEquyg" isBeginAction="false" name="Montant_Force_Correct" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LDhJgEfGpb7QiJEquyg" executionCondition="${P_MNT_OK}$ == 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LrhJgEfGpb7QiJEquyg"/>
    <link id="_oU2LDxJgEfGpb7QiJEquyg" executionCondition="${P_MNT_OK}$ == 0" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LExJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LEBJgEfGpb7QiJEquyg" name="W_RBT" target="resource.md#_7szGgBIqEfGcctThXQHQEw?fileId=_TIPX4A6cEe6JfbycoN1ybw$type=md$name=W_RBT?"/>
    <metaDataLink id="_oU2LERJgEfGpb7QiJEquyg" name="W_RBT_PREPA_RGT" target="resource.md#_9V0SwBIqEfGcctThXQHQEw?fileId=_TIPX4A6cEe6JfbycoN1ybw$type=md$name=W_RBT_PREPA_RGT?"/>
    <parameter id="_oU2LEhJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_MNT_OK&quot; type=&quot;Integer&quot;>&#xD;
select case when W_RBT.MNT_RBT > to_number(${~/P_MONTANT_OK}$)&#xD;
then 0&#xD;
else 1&#xD;
end&#xD;
from %x{$W_RBT/tech:physicalPath()}x%  W_RBT, %x{$W_RBT_PREPA_RGT/tech:physicalPath()}x%  W_RBT_PREPA_RGT&#xD;
where W_RBT.SESSION_ID = '${/CORE_SESSION_ID}$'&#xD;
and W_RBT_PREPA_RGT.SESSION_ID = W_RBT.SESSION_ID&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LExJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="SendMontantForceKO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.SendMailActionCodeI">
    <link id="_oU2LFBJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LGxJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LFRJgEfGpb7QiJEquyg" name="SMTP" target="resource.md#_yFg9cnSCEe2wENHQ1zUjoA?fileId=_xvXuUHSCEe2wENHQ1zUjoA$type=md$name=SMTP?"/>
    <parameter id="_oU2LFhJgEfGpb7QiJEquyg" name="MAIL_FROM" type="String" value="stambia@happychicgroup.com"/>
    <parameter id="_oU2LFxJgEfGpb7QiJEquyg" name="MAIL_HOSTNAME" type="String"/>
    <parameter id="_oU2LGBJgEfGpb7QiJEquyg" name="MAIL_TO" type="String" value="${~/MAIL}$"/>
    <parameter id="_oU2LGRJgEfGpb7QiJEquyg" name="MAIL_SUBJECT" type="String" value="Commande '${~/p_id_cde}$' - Montant remboursemebt forcé trop élevé"/>
    <parameter id="_oU2LGhJgEfGpb7QiJEquyg" name="MAIL_TEXT" type="String" value="Bonjour , &#xD;&#xA;&#xD;&#xA;La somme des montants forcés dans CBO pour la commande ${~/p_id_cde}$ est supérieure au montant remboursable de la commande.&#xD;&#xA;&#xD;&#xA;Veuillez saisir des montants dont la somme doit être inférieure ou égale à : ${~/P_MONTANT_OK}$ €.&#xD;&#xA;&#xD;&#xA;Vous pouvez également laisser les montants calculés. &#xD;&#xA;&#xD;&#xA;Pensez à valider de nouveau la demande de remboursement dans CBO.&#xD;&#xA;&#xD;&#xA;Cordialement,&#xD;&#xA;Informatique Commerce "/>
  </actionCode>
  <actionCode id="_oU2LGxJgEfGpb7QiJEquyg" isBeginAction="false" name="RAZ_Montant_Force" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <link id="_oU2LHBJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LLRJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LHRJgEfGpb7QiJEquyg" name="RET_LIGNE_RBT" target="resource.md#_CU4dIPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_LIGNE_RBT?"/>
    <metaDataLink id="_oU2LHhJgEfGpb7QiJEquyg" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <parameter id="_oU2LHxJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2LIBJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <parameter id="_oU2LIRJgEfGpb7QiJEquyg" name="SQL_MULTI_QUERYS" type="Boolean" value="true"/>
    <code>update %x{$RET_LIGNE_RBT/tech:physicalPath()}x%&#xD;
set MONTANT_RBT_FORCE = null &#xD;
where ID_CDE = '${~/p_id_cde}$' &#xD;
and ID_RBT = ${~/p_id_rbt}$ ;&#xD;
update %x{$RET_RBT/tech:physicalPath()}x%&#xD;
set STATUT = 'DEMREMBCAL' &#xD;
where ID_CDE = '${~/p_id_cde}$' &#xD;
and ID_RBT = ${~/p_id_rbt}$ ;</code>
  </actionCode>
  <actionCode id="_oU2LIhJgEfGpb7QiJEquyg" isBeginAction="false" name="MAJ_Montant" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
    <link id="_oU2LIxJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2K1BJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LJBJgEfGpb7QiJEquyg" name="RET_RBT" target="resource.md#_E3gx8PslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_RBT?"/>
    <metaDataLink id="_oU2LJRJgEfGpb7QiJEquyg" name="RET_LIGNE_RBT" target="resource.md#_CU4dIPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_LIGNE_RBT?"/>
    <parameter id="_oU2LJhJgEfGpb7QiJEquyg" name="SQL_ACTION_TYPE" type="String" value="DDL_DML"/>
    <parameter id="_oU2LJxJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <parameter id="_oU2LKBJgEfGpb7QiJEquyg" name="SQL_MULTI_QUERYS" type="Boolean" value="true"/>
    <code>update %x{$RET_LIGNE_RBT/tech:physicalPath()}x%&#xD;
set MONTANT_RBT = MONTANT_RBT_FORCE, MONTANT_RBT_FORCE = null&#xD;
where ID_CDE = '${~/p_id_cde}$' &#xD;
and ID_RBT = ${~/p_id_rbt}$ &#xD;
and MONTANT_RBT_FORCE > 0 ;&#xD;
update %x{$RET_RBT/tech:physicalPath()}x%&#xD;
set MNT_RBT = (select sum(MONTANT_RBT) from %x{$RET_LIGNE_RBT/tech:physicalPath()}x% &#xD;
	where ID_CDE = ${~/p_id_cde}$ and ID_RBT = ${~/p_id_rbt}$ )&#xD;
where ID_CDE = '${~/p_id_cde}$' &#xD;
and ID_RBT = ${~/p_id_rbt}$ ;&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LKRJgEfGpb7QiJEquyg" isBeginAction="false" name="Montant_Possible" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LKhJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LDRJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LKxJgEfGpb7QiJEquyg" name="W_RBT_PREPA_RGT" target="resource.md#_9V0SwBIqEfGcctThXQHQEw?fileId=_TIPX4A6cEe6JfbycoN1ybw$type=md$name=W_RBT_PREPA_RGT?"/>
    <parameter id="_oU2LLBJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_MONTANT_OK&quot; type=&quot;String&quot;>&#xD;
select sum(coalesce(W_RBT_PREPA_RGT.MONTANT_ORIGINE,0)) - sum(coalesce(W_RBT_PREPA_RGT.MONTANT_REMBOURSE,0))&#xD;
from  %x{$W_RBT_PREPA_RGT/tech:physicalPath()}x%  W_RBT_PREPA_RGT&#xD;
where W_RBT_PREPA_RGT.SESSION_ID = '${/CORE_SESSION_ID}$'&#xD;
group by W_RBT_PREPA_RGT.SESSION_ID &#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LLRJgEfGpb7QiJEquyg" isBeginAction="false" name="Purge_W" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.JdbcActionCodeI">
