  <actionCode id="_oU2K1BJgEfGpb7QiJEquyg" isBeginAction="false" name="Recup param" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2K1RJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2K2xJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2K1hJgEfGpb7QiJEquyg" name="RET_PARAM_MAJRBT" target="resource.md#_EIHVUPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_PARAM_MAJRBT?"/>
    <metaDataLink id="_oU2K1xJgEfGpb7QiJEquyg" name="RET_REGLEMENT_RBT" target="resource.md#_D4zuAPslEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=RET_REGLEMENT_RBT?"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_PAIEMENT&quot; type=&quot;Integer&quot;>&#xD;
select paiement&#xD;
from %x{$RET_PARAM_MAJRBT/tech:physicalPath()}x% &#xD;
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_MAIL&quot; type=&quot;Integer&quot;>&#xD;
select MAIL_CLIENT&#xD;
from %x{$RET_PARAM_MAJRBT/tech:physicalPath()}x% &#xD;
where id_entite = to_number(substr('${~/p_id_cde}$',10,5)) &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_ENTITE&quot; type=&quot;Integer&quot;>&#xD;
select to_number(substr('${~/p_id_cde}$',10,5)) from dual  &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_PAYZEN&quot; type=&quot;Integer&quot;>&#xD;
select count(*)&#xD;
from  %x{$RET_REGLEMENT_RBT/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$&#xD;
and code_rgt in (3,26,24,25,33,41)&#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../P_KDO&quot; type=&quot;Integer&quot;>&#xD;
select count(*)&#xD;
from  %x{$RET_REGLEMENT_RBT/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' and id_rbt = ${~/p_id_rbt}$&#xD;
and code_rgt in (21,27,28)&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters>&#xD;
</code>
  </actionCode>
