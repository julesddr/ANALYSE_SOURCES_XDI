  <actionCode id="_oU2K5hJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Paiement_trouvé" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
