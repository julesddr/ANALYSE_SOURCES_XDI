  <actionCode id="_oU2LOBJgEfGpb7QiJEquyg" isBeginAction="false" name="Mail" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LORJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LRxJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LOhJgEfGpb7QiJEquyg" name="ECOMM" target="resource.md#_IJFpcNk4Ee2_W6r6SMVqFA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=ECOMM?"/>
    <parameter id="_oU2LOxJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../MAIL&quot; type=&quot;String&quot;>&#xD;
select case substr('${~/p_id_cde}$',10,5) &#xD;
when '00600' then 'e-shopping@Jules.fr' &#xD;
when '01601' then 'e-shopping@Jules.fr'&#xD;
when '02600' then 'contact-clients@bizzbee.fr'&#xD;
when '03600' then 'serviceclientsbrice@brice.fr' &#xD;
when '03651' then 'serviceclientsbrice@brice.fr'&#xD;
else 'e-shopping@Jules.fr'&#xD;
end&#xD;
from dual &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../Authorization&quot; type=&quot;String&quot;>&#xD;
select case substr('${~/p_id_cde}$',10,5) &#xD;
when '00600' then 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw==' &#xD;
when '01601' then 'MTExMDkzOTQ6cHJvZHBhc3N3b3JkX0dTNVV4VmpGdVBIVDRaMXhQRWlWN21RZUZ6eWhJZGtDZ0RmbXpJQUlYMGc0Rg=='&#xD;
when '02600' then 'OTI0NTI2NjI6cHJvZHBhc3N3b3JkX3BIdU1JSTI4VHJFanNyOHFMejJNSnZYR0ZhQ3l1VXRVRnQyeldQQThtd2RPSA=='&#xD;
else 'NDgzNjY0MTU6cHJvZHBhc3N3b3JkX29XUzhNZ1dFelM4UkJRZmxYRlJjbUQ2NUV6T0EyRjVTanBwQWtTZjVLaTZtbw=='&#xD;
end&#xD;
from dual &#xD;
&lt;/parameter>&#xD;
&lt;parameter name=&quot;../AuthorizationAlma&quot; type=&quot;String&quot;>&#xD;
select case substr('${~/p_id_cde}$',10,5) &#xD;
when '00600' then 'OTIzMjIxODI6cHJvZHBhc3N3b3JkX2U4cFgyNmM5S25iNTMwNG1ONzJSdkJOUVM5TzNkanB5RGNJSnRvQ1NYNGVHbA==' &#xD;
when '02600' then 'NzkwMDg1MjI6cHJvZHBhc3N3b3JkX0Q5V1NlVDFVZVowanpyam9Uak5FTkNhbkhHRUdiS1VzdkFtRVZuVHVmaGNNZA=='&#xD;
end&#xD;
from dual &#xD;
&lt;/parameter>&#xD;
&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LPBJgEfGpb7QiJEquyg" isBeginAction="false" name="Cde_Du_jour" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LPRJgEfGpb7QiJEquyg" executionCondition="${P_RAF}$ == 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LOBJgEfGpb7QiJEquyg"/>
    <link id="_oU2LPhJgEfGpb7QiJEquyg" executionCondition="${P_RAF}$ == 0" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LQRJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LPxJgEfGpb7QiJEquyg" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <parameter id="_oU2LQBJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_RAF&quot; type=&quot;String&quot;>&#xD;
select &#xD;
case when trunc(dath_cde) = trunc(sysdate) &#xD;
then 0 &#xD;
else 1 end&#xD;
from %x{$CDE/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LQRJgEfGpb7QiJEquyg" isBeginAction="false" name="Stop" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.EmptyActionCodeI"/>
  <actionCode id="_oU2LQhJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="Mail_Renseigne" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LQxJgEfGpb7QiJEquyg" executionCondition="${MAIL_CDE}$ == 1" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU2LnxJgEfGpb7QiJEquyg"/>
    <link id="_oU2LRBJgEfGpb7QiJEquyg" executionCondition="${MAIL_CDE}$ == 0" executionType="OK" generationType="OK_KO" mandatory="0" targetId="_oU2LphJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LRRJgEfGpb7QiJEquyg" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <parameter id="_oU2LRhJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../MAIL_CDE&quot; type=&quot;Integer&quot;>&#xD;
select case when nvl(EMAIL,'NON RENSEIGNE') = 'NON RENSEIGNE' then 0 &#xD;
else 1 &#xD;
end&#xD;
from %x{$CDE/tech:physicalPath()}x% &#xD;
where id_cde = '${~/p_id_cde}$' &#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters>&#xD;
</code>
  </actionCode>
  <actionCode id="_oU2LRxJgEfGpb7QiJEquyg" isBeginAction="false" name="Enseigne" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.sqlToParameters">
    <link id="_oU2LSBJgEfGpb7QiJEquyg" executionType="OK" generationType="OK_KO" mandatory="1" targetId="_oU1jyhJgEfGpb7QiJEquyg"/>
    <metaDataLink id="_oU2LSRJgEfGpb7QiJEquyg" name="CDE" target="resource.md#_28IsgQ6xEe6ij7bjoy0aqA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=CDE?"/>
    <metaDataLink id="_oU2LShJgEfGpb7QiJEquyg" name="ENSEIGNE" target="resource.md#_RkabAPsoEe6-gJSJ1VYtiA?fileId=_IJFpcNk4Ee2_W6r6SMVqFA$type=md$name=ENSEIGNE?"/>
    <parameter id="_oU2LSxJgEfGpb7QiJEquyg" name="SQL_CONNECTION" type="String"/>
    <code>&lt;sqlToParameters>&#xD;
&lt;parameter name=&quot;../P_ENSEIGNE&quot; type=&quot;String&quot;>&#xD;
select ens.libmarque&#xD;
from %x{$CDE/tech:physicalPath()}x% cde , &#xD;
%x{$ENSEIGNE/tech:physicalPath()}x% ens &#xD;
where cde.id_cde = '${~/p_id_cde}$' &#xD;
and cde.id_enseigne = ens.id_enseigne&#xD;
&lt;/parameter>&#xD;
&lt;/sqlToParameters></code>
  </actionCode>
  <actionCode id="_oU2LTBJgEfGpb7QiJEquyg" enable="true" isBeginAction="false" name="MailPayzen1KO" nbCycles="-1" toleratedError="false" technology="com.indy.engine.actionCodes.SendMailActionCodeI">
